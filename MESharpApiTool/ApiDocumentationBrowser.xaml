<UserControl
    x:Class="csharp_interop.Documentation.ApiDocumentationBrowser"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="clr-namespace:csharp_interop.Documentation.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewmodels="clr-namespace:csharp_interop.Documentation.ViewModels"
    d:DataContext="{d:DesignInstance Type=viewmodels:ApiDocBrowserViewModel}"
    d:DesignHeight="800"
    d:DesignWidth="1200"
    Background="{DynamicResource MahApps.Brushes.ThemeBackground}"
    mc:Ignorable="d">
    <UserControl.Resources>
        <converters:SyntaxHighlightConverter x:Key="SyntaxHighlightConverter" />

        <!--  Theme-aware gradient for header  -->
        <LinearGradientBrush x:Key="DocsHeaderBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Offset="0" Color="{DynamicResource MahApps.Colors.Accent}" />
            <GradientStop Offset="1" Color="{DynamicResource MahApps.Colors.Accent3}" />
        </LinearGradientBrush>

        <Style x:Key="DocsSectionHeadingStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource MahApps.Brushes.Accent}" />
            <Setter Property="Margin" Value="0,0,0,12" />
        </Style>

        <Style x:Key="DocsCardBorderStyle" TargetType="Border">
            <Setter Property="Padding" Value="20,16" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Background" Value="{DynamicResource MahApps.Brushes.ThemeBackground}" />
            <Setter Property="BorderBrush" Value="{DynamicResource MahApps.Brushes.Accent4}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Margin" Value="0,0,0,16" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <!--  Add shadow effect for depth  -->
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect
                        BlurRadius="8"
                        Direction="270"
                        Opacity="0.15"
                        ShadowDepth="2"
                        Color="Black" />
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DocsCopyButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="{DynamicResource MahApps.Brushes.Gray}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="{DynamicResource MahApps.Brushes.Gray6}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="ToolTipService.ShowDuration" Value="3000" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="border"
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource MahApps.Brushes.Accent4}" />
                                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource MahApps.Brushes.Accent}" />
                                <Setter Property="Foreground" Value="{DynamicResource MahApps.Brushes.Accent}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource MahApps.Brushes.Accent}" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  Settings toggle button style  -->
        <Style x:Key="DocsThemeToggleStyle" TargetType="ToggleButton">
            <Setter Property="Height" Value="34" />
            <Setter Property="MinWidth" Value="36" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="Foreground" Value="{DynamicResource MahApps.Brushes.Gray}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="{DynamicResource MahApps.Brushes.Gray6}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border
                            x:Name="bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource MahApps.Brushes.Accent4}" />
                                <Setter TargetName="bd" Property="BorderBrush" Value="{DynamicResource MahApps.Brushes.Accent}" />
                                <Setter Property="Foreground" Value="{DynamicResource MahApps.Brushes.Accent}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource MahApps.Brushes.Accent4}" />
                                <Setter TargetName="bd" Property="BorderBrush" Value="{DynamicResource MahApps.Brushes.Accent}" />
                                <Setter Property="Foreground" Value="{DynamicResource MahApps.Brushes.Accent}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DocsComboBoxItemStyle" TargetType="ComboBoxItem">
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="Foreground" Value="{DynamicResource MahApps.Brushes.ThemeForeground}" />
            <Setter Property="Background" Value="{DynamicResource MahApps.Brushes.ThemeBackground}" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border
                            x:Name="ItemBorder"
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource MahApps.Brushes.Accent4}" />
                                <Setter Property="Foreground" Value="{DynamicResource MahApps.Brushes.ThemeForeground}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource MahApps.Brushes.Accent}" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DocsComboBoxStyle" TargetType="ComboBox">
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Padding" Value="10,7" />
            <Setter Property="Foreground" Value="{DynamicResource MahApps.Brushes.ThemeForeground}" />
            <Setter Property="Background" Value="{DynamicResource MahApps.Brushes.ThemeBackground}" />
            <Setter Property="BorderBrush" Value="{DynamicResource MahApps.Brushes.Gray6}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="ItemContainerStyle" Value="{StaticResource DocsComboBoxItemStyle}" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton
                                x:Name="ToggleButton"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border
                                            x:Name="FieldBorder"
                                            Padding="{TemplateBinding Padding}"
                                            Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="5">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <ContentPresenter
                                                    Grid.Column="0"
                                                    Margin="4,0,0,0"
                                                    HorizontalAlignment="Left"
                                                    VerticalAlignment="Center"
                                                    Content="{Binding SelectionBoxItem, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                    ContentStringFormat="{Binding SelectionBoxItemStringFormat, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                    ContentTemplate="{Binding SelectionBoxItemTemplate, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                    RecognizesAccessKey="True"
                                                    TextElement.Foreground="{DynamicResource MahApps.Brushes.ThemeForeground}" />
                                                <Path
                                                    Grid.Column="1"
                                                    Width="8"
                                                    Height="5"
                                                    Margin="10,0,0,0"
                                                    VerticalAlignment="Center"
                                                    Data="M 0 0 L 4 5 L 8 0 Z"
                                                    Fill="{DynamicResource MahApps.Brushes.Gray}" />
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="FieldBorder" Property="BorderBrush" Value="{DynamicResource MahApps.Brushes.Accent}" />
                                                <Setter TargetName="FieldBorder" Property="Background" Value="{DynamicResource MahApps.Brushes.Gray10}" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <Popup
                                AllowsTransparency="True"
                                IsOpen="{TemplateBinding IsDropDownOpen}"
                                Placement="Bottom"
                                PopupAnimation="Fade">
                                <Border
                                    MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                    Margin="0,4,0,0"
                                    Background="{DynamicResource MahApps.Brushes.ThemeBackground}"
                                    BorderBrush="{DynamicResource MahApps.Brushes.Gray6}"
                                    BorderThickness="1"
                                    CornerRadius="5">
                                    <ScrollViewer MaxHeight="220">
                                        <ItemsPresenter />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  Badge style for tags  -->
        <Style x:Key="DocsBadgeStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource MahApps.Brushes.Accent4}" />
            <Setter Property="CornerRadius" Value="3" />
            <Setter Property="Padding" Value="8,3" />
            <Setter Property="Margin" Value="0,0,6,0" />
        </Style>

        <DataTemplate x:Key="PropertyCardTemplate">
            <Border Style="{StaticResource DocsCardBorderStyle}">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock
                                FontFamily="Consolas, 'Courier New', monospace"
                                FontSize="14"
                                TextWrapping="Wrap">
                                <Run
                                    FontWeight="Bold"
                                    Foreground="{DynamicResource MahApps.Brushes.Accent2}"
                                    Text="{Binding Type, Mode=OneWay}" />
                                <Run Text=" " />
                                <Run
                                    FontWeight="SemiBold"
                                    Foreground="{DynamicResource MahApps.Brushes.ThemeForeground}"
                                    Text="{Binding Name, Mode=OneWay}" />
                            </TextBlock>

                            <!--  Access modifiers  -->
                            <StackPanel Margin="0,8,0,0" Orientation="Horizontal">
                                <Border>
                                    <Border.Style>
                                        <Style BasedOn="{StaticResource DocsBadgeStyle}" TargetType="Border">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding CanRead}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock
                                        FontSize="10"
                                        FontWeight="SemiBold"
                                        Foreground="{DynamicResource MahApps.Brushes.Accent}"
                                        Text="get" />
                                </Border>
                                <Border>
                                    <Border.Style>
                                        <Style BasedOn="{StaticResource DocsBadgeStyle}" TargetType="Border">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding CanWrite}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock
                                        FontSize="10"
                                        FontWeight="SemiBold"
                                        Foreground="{DynamicResource MahApps.Brushes.Accent}"
                                        Text="set" />
                                </Border>
                            </StackPanel>
                        </StackPanel>

                        <Button
                            Grid.Column="1"
                            Margin="14,0,0,0"
                            VerticalAlignment="Top"
                            Command="{Binding DataContext.CopySignatureCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                            CommandParameter="{Binding}"
                            Content="📋 Copy example"
                            Style="{StaticResource DocsCopyButtonStyle}"
                            ToolTip="Copy example usage to clipboard" />
                    </Grid>

                    <TextBlock
                        Margin="0,12,0,0"
                        FontSize="13"
                        Foreground="{DynamicResource MahApps.Brushes.Text}"
                        Text="{Binding Summary}"
                        TextWrapping="Wrap">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Summary}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Summary}" Value="">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <!--  Full signature display  -->
                    <Border
                        Margin="0,12,0,0"
                        Padding="12,10"
                        Background="{DynamicResource MahApps.Brushes.Gray10}"
                        BorderBrush="{DynamicResource MahApps.Brushes.Gray6}"
                        BorderThickness="1"
                        CornerRadius="4">
                        <TextBlock
                            FontFamily="Consolas, 'Courier New', monospace"
                            FontSize="12"
                            Foreground="{DynamicResource MahApps.Brushes.Gray}"
                            Text="{Binding Signature, Mode=OneWay}"
                            TextWrapping="Wrap" />
                    </Border>

                    <!--  Example usage  -->
                    <Border
                        Margin="0,12,0,0"
                        Padding="16,14"
                        Background="{DynamicResource MahApps.Brushes.Gray10}"
                        BorderBrush="{DynamicResource MahApps.Brushes.Accent}"
                        BorderThickness="2,0,0,0"
                        CornerRadius="4">
                        <StackPanel>
                            <TextBlock
                                FontSize="13"
                                FontWeight="SemiBold"
                                Foreground="{DynamicResource MahApps.Brushes.Accent}"
                                Text="Example usage" />
                            <FlowDocumentScrollViewer
                                Margin="0,10,0,0"
                                Background="Transparent"
                                Foreground="{DynamicResource MahApps.Brushes.ThemeForeground}"
                                HorizontalScrollBarVisibility="Auto"
                                IsHitTestVisible="False"
                                VerticalScrollBarVisibility="Hidden"
                                ZoomIncrement="5">
                                <FlowDocumentScrollViewer.Document>
                                    <Binding Converter="{StaticResource SyntaxHighlightConverter}" Path="Example" />
                                </FlowDocumentScrollViewer.Document>
                            </FlowDocumentScrollViewer>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="MethodCardTemplate">
            <Border Style="{StaticResource DocsCardBorderStyle}">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock
                                FontFamily="Consolas, 'Courier New', monospace"
                                FontSize="14"
                                TextWrapping="Wrap">
                                <Run
                                    FontWeight="Bold"
                                    Foreground="{DynamicResource MahApps.Brushes.Accent2}"
                                    Text="{Binding ReturnType, Mode=OneWay}" />
                                <Run Text=" " />
                                <Run
                                    FontWeight="SemiBold"
                                    Foreground="{DynamicResource MahApps.Brushes.ThemeForeground}"
                                    Text="{Binding Name, Mode=OneWay}" />
                                <Run Foreground="{DynamicResource MahApps.Brushes.Gray}" Text="(" />
                                <Run Foreground="{DynamicResource MahApps.Brushes.Gray}" Text="{Binding ParametersString, Mode=OneWay}" />
                                <Run Foreground="{DynamicResource MahApps.Brushes.Gray}" Text=")" />
                            </TextBlock>
                        </StackPanel>

                        <Button
                            Grid.Column="1"
                            Margin="14,0,0,0"
                            VerticalAlignment="Top"
                            Command="{Binding DataContext.CopySignatureCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                            CommandParameter="{Binding}"
                            Content="📋 Copy example"
                            Style="{StaticResource DocsCopyButtonStyle}"
                            ToolTip="Copy example usage to clipboard" />
                    </Grid>

                    <!--  Summary  -->
                    <TextBlock
                        Margin="0,12,0,0"
                        FontSize="13"
                        Foreground="{DynamicResource MahApps.Brushes.Text}"
                        Text="{Binding Summary}"
                        TextWrapping="Wrap">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Summary}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Summary}" Value="">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <!--  Parameters section  -->
                    <StackPanel Margin="0,16,0,0">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Parameters.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>

                        <TextBlock
                            FontSize="13"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource MahApps.Brushes.Accent}"
                            Text="Parameters" />

                        <ItemsControl Margin="0,8,0,0" ItemsSource="{Binding Parameters}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border
                                        Margin="0,0,0,8"
                                        Padding="12,8"
                                        Background="{DynamicResource MahApps.Brushes.Gray10}"
                                        BorderBrush="{DynamicResource MahApps.Brushes.Gray6}"
                                        BorderThickness="1"
                                        CornerRadius="4">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" MinWidth="120" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock
                                                Grid.Column="0"
                                                VerticalAlignment="Top"
                                                FontFamily="Consolas, 'Courier New', monospace"
                                                FontSize="12">
                                                <Run
                                                    FontWeight="Bold"
                                                    Foreground="{DynamicResource MahApps.Brushes.Accent2}"
                                                    Text="{Binding Type, Mode=OneWay}" />
                                                <Run Text=" " />
                                                <Run
                                                    FontWeight="SemiBold"
                                                    Foreground="{DynamicResource MahApps.Brushes.ThemeForeground}"
                                                    Text="{Binding Name, Mode=OneWay}" />
                                            </TextBlock>
                                            <TextBlock
                                                Grid.Column="1"
                                                Margin="12,0,0,0"
                                                VerticalAlignment="Top"
                                                FontSize="12"
                                                Foreground="{DynamicResource MahApps.Brushes.Gray}"
                                                Text="{Binding Description}"
                                                TextWrapping="Wrap" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <!--  Returns section  -->
                    <Border
                        Margin="0,12,0,0"
                        Padding="12,10"
                        Background="{DynamicResource MahApps.Brushes.Gray10}"
                        BorderBrush="{DynamicResource MahApps.Brushes.Accent4}"
                        BorderThickness="1"
                        CornerRadius="4">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Returns}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Returns}" Value="">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel>
                            <TextBlock
                                FontSize="12"
                                FontWeight="SemiBold"
                                Foreground="{DynamicResource MahApps.Brushes.Accent}"
                                Text="↩ Returns" />
                            <TextBlock
                                Margin="0,6,0,0"
                                FontSize="12"
                                Foreground="{DynamicResource MahApps.Brushes.Text}"
                                Text="{Binding Returns}"
                                TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <!--  Remarks section  -->
                    <Border
                        Margin="0,12,0,0"
                        Padding="12,10"
                        Background="{DynamicResource MahApps.Brushes.Gray10}"
                        BorderBrush="{DynamicResource MahApps.Brushes.Gray6}"
                        BorderThickness="1"
                        CornerRadius="4">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Remarks}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Remarks}" Value="">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel>
                            <TextBlock
                                FontSize="12"
                                FontWeight="SemiBold"
                                Foreground="{DynamicResource MahApps.Brushes.Accent}"
                                Text="💡 Remarks" />
                            <TextBlock
                                Margin="0,6,0,0"
                                FontSize="12"
                                Foreground="{DynamicResource MahApps.Brushes.Text}"
                                Text="{Binding Remarks}"
                                TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <!--  Example section  -->
                    <Border
                        Margin="0,16,0,0"
                        Padding="16,14"
                        Background="{DynamicResource MahApps.Brushes.Gray10}"
                        BorderBrush="{DynamicResource MahApps.Brushes.Accent}"
                        BorderThickness="2,0,0,0"
                        CornerRadius="4">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Example}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Example}" Value="">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel>
                            <TextBlock
                                FontSize="13"
                                FontWeight="SemiBold"
                                Foreground="{DynamicResource MahApps.Brushes.Accent}"
                                Text="📝 Example" />
                            <FlowDocumentScrollViewer
                                Margin="0,10,0,0"
                                Background="Transparent"
                                Foreground="{DynamicResource MahApps.Brushes.ThemeForeground}"
                                HorizontalScrollBarVisibility="Auto"
                                IsHitTestVisible="False"
                                VerticalScrollBarVisibility="Hidden"
                                ZoomIncrement="5">
                                <FlowDocumentScrollViewer.Document>
                                    <Binding Converter="{StaticResource SyntaxHighlightConverter}" Path="Example" />
                                </FlowDocumentScrollViewer.Document>
                            </FlowDocumentScrollViewer>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  Toolbar  -->
        <Border
            Grid.Row="0"
            Padding="22,16"
            Background="{DynamicResource MahApps.Brushes.ThemeBackground}"
            BorderBrush="{DynamicResource MahApps.Brushes.Gray6}"
            BorderThickness="0,0,0,1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Grid>
                        <TextBox
                            x:Name="SearchBox"
                            MinWidth="160"
                            MinHeight="42"
                            Padding="38,8,14,8"
                            VerticalContentAlignment="Center"
                            Background="{DynamicResource MahApps.Brushes.ThemeBackground}"
                            BorderBrush="{DynamicResource MahApps.Brushes.Gray6}"
                            BorderThickness="2"
                            CaretBrush="{DynamicResource MahApps.Brushes.ThemeForeground}"
                            FontSize="14"
                            Foreground="{DynamicResource MahApps.Brushes.ThemeForeground}"
                            Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}">
                            <TextBox.Style>
                                <Style BasedOn="{StaticResource {x:Type TextBox}}" TargetType="TextBox">
                                    <Setter Property="Margin" Value="0" />
                                    <Style.Triggers>
                                        <Trigger Property="IsKeyboardFocused" Value="True">
                                            <Setter Property="BorderBrush" Value="{DynamicResource MahApps.Brushes.Accent}" />
                                            <Setter Property="Background" Value="{DynamicResource MahApps.Brushes.Gray10}" />
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBox.Style>
                        </TextBox>

                        <TextBlock
                            Margin="15,0,0,0"
                            VerticalAlignment="Center"
                            FontSize="14"
                            Foreground="{DynamicResource MahApps.Brushes.Gray}"
                            IsHitTestVisible="False"
                            Text="🔍" />
                        <TextBlock
                            Margin="40,0,12,0"
                            VerticalAlignment="Center"
                            Foreground="{DynamicResource MahApps.Brushes.Gray}"
                            IsHitTestVisible="False"
                            Text="Search classes, methods, properties… Ctrl+K">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SearchText}" Value="">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding SearchText}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>

                    <StackPanel
                        Grid.Column="1"
                        Margin="14,0,0,0"
                        VerticalAlignment="Center"
                        Orientation="Horizontal">
                        <Button
                            Width="36"
                            Height="36"
                            Command="{Binding ClearSearchCommand}"
                            Content="✕"
                            FontSize="16"
                            ToolTip="Clear search">
                            <Button.Style>
                                <Style BasedOn="{StaticResource DocsCopyButtonStyle}" TargetType="Button">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SearchText}" Value="">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding SearchText}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <ToggleButton
                            Width="42"
                            Height="42"
                            Margin="8,0,0,0"
                            Content="☾"
                            IsChecked="{Binding IsDarkMode, Mode=TwoWay}"
                            Style="{StaticResource DocsThemeToggleStyle}"
                            ToolTip="Toggle dark theme" />
                        <ToggleButton
                            x:Name="SettingsButton"
                            Width="42"
                            Height="42"
                            Margin="8,0,0,0"
                            Content="⚙"
                            IsChecked="{Binding IsSettingsOpen, Mode=TwoWay}"
                            Style="{StaticResource DocsThemeToggleStyle}"
                            ToolTip="Viewer settings" />
                        <Popup
                            AllowsTransparency="True"
                            IsOpen="{Binding IsSettingsOpen, Mode=TwoWay}"
                            Placement="Bottom"
                            PlacementTarget="{Binding ElementName=SettingsButton}"
                            PopupAnimation="Fade"
                            StaysOpen="False">
                            <Border
                                Width="280"
                                Margin="0,8,0,0"
                                Padding="16"
                                Background="{DynamicResource MahApps.Brushes.ThemeBackground}"
                                BorderBrush="{DynamicResource MahApps.Brushes.Gray6}"
                                BorderThickness="1"
                                CornerRadius="8">
                                <Border.Effect>
                                    <DropShadowEffect
                                        BlurRadius="14"
                                        Direction="270"
                                        Opacity="0.28"
                                        ShadowDepth="4"
                                        Color="Black" />
                                </Border.Effect>
                                <StackPanel>
                                    <TextBlock
                                        FontSize="14"
                                        FontWeight="SemiBold"
                                        Foreground="{DynamicResource MahApps.Brushes.Text}"
                                        Text="Settings" />

                                    <TextBlock
                                        Margin="0,14,0,6"
                                        FontSize="11"
                                        FontWeight="SemiBold"
                                        Foreground="{DynamicResource MahApps.Brushes.Gray}"
                                        Text="Theme" />
                                    <ToggleButton
                                        Height="34"
                                        HorizontalContentAlignment="Stretch"
                                        IsChecked="{Binding IsDarkMode, Mode=TwoWay}"
                                        ToolTip="Switch between light and dark theme">
                                        <ToggleButton.Template>
                                            <ControlTemplate TargetType="ToggleButton">
                                                <Border
                                                    Background="{DynamicResource MahApps.Brushes.Gray10}"
                                                    BorderBrush="{DynamicResource MahApps.Brushes.Gray6}"
                                                    BorderThickness="1"
                                                    CornerRadius="5">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>
                                                        <Border
                                                            x:Name="DarkTrack"
                                                            Grid.Column="0"
                                                            Margin="3"
                                                            Background="{DynamicResource MahApps.Brushes.Accent}"
                                                            CornerRadius="4" />
                                                        <Border
                                                            x:Name="LightTrack"
                                                            Grid.Column="1"
                                                            Margin="3"
                                                            Background="Transparent"
                                                            CornerRadius="4" />
                                                        <TextBlock
                                                            x:Name="DarkLabel"
                                                            Grid.Column="0"
                                                            HorizontalAlignment="Center"
                                                            VerticalAlignment="Center"
                                                            FontSize="12"
                                                            FontWeight="SemiBold"
                                                            Foreground="White"
                                                            Text="Dark" />
                                                        <TextBlock
                                                            x:Name="LightLabel"
                                                            Grid.Column="1"
                                                            HorizontalAlignment="Center"
                                                            VerticalAlignment="Center"
                                                            FontSize="12"
                                                            FontWeight="SemiBold"
                                                            Foreground="{DynamicResource MahApps.Brushes.Gray}"
                                                            Text="Light" />
                                                    </Grid>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsChecked" Value="False">
                                                        <Setter TargetName="DarkTrack" Property="Background" Value="Transparent" />
                                                        <Setter TargetName="LightTrack" Property="Background" Value="{DynamicResource MahApps.Brushes.Accent}" />
                                                        <Setter TargetName="DarkLabel" Property="Foreground" Value="{DynamicResource MahApps.Brushes.Gray}" />
                                                        <Setter TargetName="LightLabel" Property="Foreground" Value="White" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </ToggleButton.Template>
                                    </ToggleButton>

                                    <TextBlock
                                        Margin="0,16,0,6"
                                        FontSize="11"
                                        FontWeight="SemiBold"
                                        Foreground="{DynamicResource MahApps.Brushes.Gray}"
                                        Text="Viewer size" />
                                    <ComboBox
                                        DisplayMemberPath="DisplayName"
                                        ItemsSource="{Binding SizeOptions}"
                                        SelectedItem="{Binding SelectedSizeOption, Mode=TwoWay}"
                                        SelectionChanged="SizePreset_SelectionChanged"
                                        Style="{StaticResource DocsComboBoxStyle}" />
                                    <TextBlock
                                        Margin="0,8,0,0"
                                        FontSize="11"
                                        Foreground="{DynamicResource MahApps.Brushes.Gray}"
                                        Text="Window size persists between launches."
                                        TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                        </Popup>
                    </StackPanel>
                </Grid>

                <DockPanel Grid.Row="1" Margin="0,10,0,0" LastChildFill="False">
                    <Border
                        Padding="10,6"
                        DockPanel.Dock="Left"
                        Background="{DynamicResource MahApps.Brushes.Accent4}"
                        CornerRadius="4">
                        <TextBlock
                            FontSize="12"
                            Foreground="{DynamicResource MahApps.Brushes.Text}"
                            Text="{Binding ResultsSummary}" />
                    </Border>
                    <Border
                        Padding="10,6"
                        DockPanel.Dock="Right"
                        Background="{DynamicResource MahApps.Brushes.Gray10}"
                        BorderBrush="{DynamicResource MahApps.Brushes.Gray6}"
                        BorderThickness="1"
                        CornerRadius="4">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock
                                Margin="0,0,10,0"
                                VerticalAlignment="Center"
                                FontSize="11"
                                FontWeight="SemiBold"
                                Foreground="{DynamicResource MahApps.Brushes.Gray}"
                                Text="Search in" />
                            <CheckBox
                                Margin="0,0,12,0"
                                VerticalAlignment="Center"
                                Content="Classes"
                                Foreground="{DynamicResource MahApps.Brushes.Text}"
                                IsChecked="{Binding IncludeClasses, Mode=TwoWay}" />
                            <CheckBox
                                Margin="0,0,12,0"
                                VerticalAlignment="Center"
                                Content="Methods"
                                Foreground="{DynamicResource MahApps.Brushes.Text}"
                                IsChecked="{Binding IncludeMethods, Mode=TwoWay}" />
                            <CheckBox
                                VerticalAlignment="Center"
                                Content="Properties"
                                Foreground="{DynamicResource MahApps.Brushes.Text}"
                                IsChecked="{Binding IncludeProperties, Mode=TwoWay}" />
                        </StackPanel>
                    </Border>
                </DockPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition
                    x:Name="SidebarColumn"
                    Width="320"
                    MinWidth="250"
                    MaxWidth="500" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!--  Sidebar navigation  -->
            <Border
                Grid.Column="0"
                Padding="20,18"
                Background="{DynamicResource MahApps.Brushes.ThemeBackground}"
                BorderBrush="{DynamicResource MahApps.Brushes.Gray6}"
                BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,0,0,16">
                        <TextBlock
                            FontSize="18"
                            FontWeight="Bold"
                            Foreground="{DynamicResource MahApps.Brushes.Text}"
                            Text="API Classes" />
                        <TextBlock
                            Margin="0,6,0,0"
                            FontSize="12"
                            Foreground="{DynamicResource MahApps.Brushes.Gray}"
                            Text="Browse and select a class to view documentation"
                            TextWrapping="Wrap" />
                    </StackPanel>

                    <ListBox
                        Grid.Row="1"
                        Padding="0,0,8,0"
                        Background="Transparent"
                        BorderThickness="0"
                        ItemsSource="{Binding DisplayedClasses}"
                        ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                        SelectedItem="{Binding SelectedClass, Mode=TwoWay}">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="Margin" Value="0,0,4,8" />
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="Foreground" Value="{DynamicResource MahApps.Brushes.ThemeForeground}" />
                                <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border
                                                x:Name="ItemBorder"
                                                Padding="0"
                                                Background="{TemplateBinding Background}"
                                                BorderBrush="{DynamicResource MahApps.Brushes.Gray6}"
                                                BorderThickness="1"
                                                CornerRadius="6">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="3" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <Border
                                                        x:Name="SelectedRail"
                                                        Grid.Column="0"
                                                        Background="Transparent"
                                                        CornerRadius="6,0,0,6" />
                                                    <ContentPresenter Grid.Column="1" Margin="12,10,14,10" />
                                                </Grid>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource MahApps.Brushes.Accent4}" />
                                                    <Setter TargetName="ItemBorder" Property="BorderBrush" Value="{DynamicResource MahApps.Brushes.Accent}" />
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource MahApps.Brushes.Accent4}" />
                                                    <Setter TargetName="ItemBorder" Property="BorderBrush" Value="{DynamicResource MahApps.Brushes.Accent}" />
                                                    <Setter TargetName="SelectedRail" Property="Background" Value="{DynamicResource MahApps.Brushes.Accent}" />
                                                    <Setter Property="Foreground" Value="{DynamicResource MahApps.Brushes.ThemeForeground}" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel>
                                    <TextBlock
                                        FontSize="14"
                                        FontWeight="SemiBold"
                                        Foreground="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=Foreground}"
                                        Text="{Binding Name}"
                                        TextTrimming="CharacterEllipsis" />
                                    <TextBlock
                                        Margin="0,6,0,0"
                                        FontSize="11"
                                        Foreground="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=Foreground}"
                                        Opacity="0.9"
                                        Text="{Binding Summary}"
                                        TextTrimming="WordEllipsis"
                                        TextWrapping="Wrap">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Setter Property="MaxHeight" Value="40" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Summary}" Value="{x:Null}">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Summary}" Value="">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <StackPanel Margin="0,9,0,0" Orientation="Horizontal">
                                        <Border
                                            Margin="0,0,6,0"
                                            Padding="7,3"
                                            Background="{DynamicResource MahApps.Brushes.Accent4}"
                                            CornerRadius="3">
                                            <TextBlock
                                                FontSize="10"
                                                FontWeight="SemiBold"
                                                Foreground="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=Foreground}"
                                                Opacity="0.85">
                                                <Run Text="{Binding Methods.Count, Mode=OneWay}" />
                                                <Run Text="methods" />
                                            </TextBlock>
                                        </Border>
                                        <Border
                                            Padding="7,3"
                                            Background="{DynamicResource MahApps.Brushes.Accent4}"
                                            CornerRadius="3">
                                            <TextBlock
                                                FontSize="10"
                                                FontWeight="SemiBold"
                                                Foreground="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=Foreground}"
                                                Opacity="0.85">
                                                <Run Text="{Binding Properties.Count, Mode=OneWay}" />
                                                <Run Text="props" />
                                            </TextBlock>
                                        </Border>
                                    </StackPanel>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!--  Stats footer  -->
                    <Border
                        Grid.Row="2"
                        Margin="0,12,0,0"
                        Padding="12,10"
                        Background="{DynamicResource MahApps.Brushes.Accent4}"
                        CornerRadius="6">
                        <TextBlock
                            FontSize="11"
                            Foreground="{DynamicResource MahApps.Brushes.Text}"
                            Text="{Binding ResultsSummary}"
                            TextAlignment="Center"
                            TextWrapping="Wrap" />
                    </Border>
                </Grid>
            </Border>

            <GridSplitter
                Grid.Column="1"
                Width="5"
                HorizontalAlignment="Center"
                VerticalAlignment="Stretch"
                Background="{DynamicResource MahApps.Brushes.Gray6}"
                DragCompleted="SidebarSplitter_DragCompleted"
                ShowsPreview="False" />

            <!--  Detail panel  -->
            <ScrollViewer
                Grid.Column="2"
                Padding="36,32"
                Background="{DynamicResource MahApps.Brushes.ThemeBackground}"
                HorizontalScrollBarVisibility="Disabled"
                VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <!--  Empty state  -->
                    <Border
                        Padding="48"
                        Background="{DynamicResource MahApps.Brushes.ThemeBackground}"
                        CornerRadius="12">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedClass}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding NoResults}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock
                                HorizontalAlignment="Center"
                                FontSize="24"
                                FontWeight="SemiBold"
                                Foreground="{DynamicResource MahApps.Brushes.Text}"
                                Text="📚 Select a Class" />
                            <TextBlock
                                Width="320"
                                Margin="0,16,0,0"
                                FontSize="13"
                                Foreground="{DynamicResource MahApps.Brushes.Gray}"
                                Text="Choose a class from the sidebar to explore its properties, methods, and examples."
                                TextAlignment="Center"
                                TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <!--  No-results state  -->
                    <Border
                        Padding="48"
                        Background="{DynamicResource MahApps.Brushes.ThemeBackground}"
                        CornerRadius="12">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding NoResults}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock
                                HorizontalAlignment="Center"
                                FontSize="24"
                                FontWeight="SemiBold"
                                Foreground="{DynamicResource MahApps.Brushes.Text}"
                                Text="No Results" />
                            <TextBlock
                                Width="420"
                                Margin="0,16,0,0"
                                FontSize="13"
                                Foreground="{DynamicResource MahApps.Brushes.Gray}"
                                Text="{Binding ResultsSummary}"
                                TextAlignment="Center"
                                TextWrapping="Wrap" />
                            <TextBlock
                                Width="420"
                                Margin="0,8,0,0"
                                FontSize="12"
                                Foreground="{DynamicResource MahApps.Brushes.Gray}"
                                Text="Try a broader term or enable more result filters."
                                TextAlignment="Center"
                                TextWrapping="Wrap" />
                            <Button
                                Margin="0,18,0,0"
                                Command="{Binding ClearSearchCommand}"
                                Content="Clear search"
                                Style="{StaticResource DocsCopyButtonStyle}" />
                        </StackPanel>
                    </Border>

                    <!--  Class detail  -->
                    <StackPanel>
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedClass}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>

                        <!--  Class header  -->
                        <Border
                            Padding="24,18"
                            Background="{StaticResource DocsHeaderBrush}"
                            CornerRadius="10">
                            <StackPanel>
                                <TextBlock
                                    FontSize="11"
                                    Foreground="White"
                                    Opacity="0.75"
                                    Text="MESharp API" />
                                <TextBlock
                                    Margin="0,6,0,0"
                                    FontSize="26"
                                    FontWeight="Bold"
                                    Foreground="White"
                                    Text="{Binding SelectedClass.Name}" />
                                <TextBlock
                                    Margin="0,8,0,0"
                                    FontSize="13"
                                    Foreground="White"
                                    Opacity="0.9"
                                    Text="{Binding SelectedClass.Summary}"
                                    TextWrapping="Wrap">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedClass.Summary}" Value="{x:Null}">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding SelectedClass.Summary}" Value="">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <!--  Class-level information  -->
                        <Border
                            Margin="0,12,0,0"
                            Padding="16,14"
                            Background="{DynamicResource MahApps.Brushes.Gray10}"
                            BorderBrush="{DynamicResource MahApps.Brushes.Accent}"
                            BorderThickness="2,0,0,0"
                            CornerRadius="4">
                            <StackPanel>
                                <TextBlock
                                    FontSize="13"
                                    FontWeight="SemiBold"
                                    Foreground="{DynamicResource MahApps.Brushes.Accent}"
                                    Text="Class-level information" />
                                <TextBlock
                                    Margin="0,12,0,0"
                                    FontSize="11"
                                    FontWeight="SemiBold"
                                    Foreground="{DynamicResource MahApps.Brushes.Gray}"
                                    Text="Remarks" />
                                <TextBlock
                                    Margin="0,5,0,0"
                                    FontSize="12"
                                    Foreground="{DynamicResource MahApps.Brushes.Text}"
                                    Text="{Binding SelectedClass.RemarksDisplay}"
                                    TextWrapping="Wrap" />
                                <TextBlock
                                    Margin="0,14,0,0"
                                    FontSize="11"
                                    FontWeight="SemiBold"
                                    Foreground="{DynamicResource MahApps.Brushes.Gray}"
                                    Text="Top-level example" />
                                <Border
                                    Margin="0,6,0,0"
                                    Padding="12,10"
                                    Background="{DynamicResource MahApps.Brushes.ThemeBackground}"
                                    BorderBrush="{DynamicResource MahApps.Brushes.Gray6}"
                                    BorderThickness="1"
                                    CornerRadius="4">
                                    <TextBlock
                                        FontFamily="Consolas, 'Courier New', monospace"
                                        FontSize="12"
                                        Foreground="{DynamicResource MahApps.Brushes.ThemeForeground}"
                                        Text="{Binding SelectedClass.ExampleDisplay}"
                                        TextWrapping="Wrap" />
                                </Border>
                            </StackPanel>
                        </Border>

                        <!--  Active member filter summary  -->
                        <Border
                            Margin="0,16,0,0"
                            Padding="14,10"
                            Background="{DynamicResource MahApps.Brushes.Accent4}"
                            BorderBrush="{DynamicResource MahApps.Brushes.Accent}"
                            BorderThickness="1"
                            CornerRadius="4">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding HasSearchText}" Value="True" />
                                                <Condition Binding="{Binding HasResults}" Value="True" />
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="Visibility" Value="Visible" />
                                        </MultiDataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock
                                FontSize="12"
                                Foreground="{DynamicResource MahApps.Brushes.Text}"
                                Text="{Binding SelectedClassFilterSummary}"
                                TextWrapping="Wrap" />
                        </Border>

                        <!--  Selected class has no matching members  -->
                        <Border
                            Margin="0,16,0,0"
                            Padding="14,12"
                            Background="{DynamicResource MahApps.Brushes.Gray10}"
                            BorderBrush="{DynamicResource MahApps.Brushes.Gray6}"
                            BorderThickness="1"
                            CornerRadius="4">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding HasSearchText}" Value="True" />
                                                <Condition Binding="{Binding DisplayedMemberCount}" Value="0" />
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="Visibility" Value="Visible" />
                                        </MultiDataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock
                                FontSize="12"
                                Foreground="{DynamicResource MahApps.Brushes.Gray}"
                                Text="This class matched the search, but no members match the active method/property filters."
                                TextWrapping="Wrap" />
                        </Border>

                        <!--  Properties section  -->
                        <StackPanel Margin="0,18,0,0">
                            <TextBlock Text="Properties">
                                <TextBlock.Style>
                                    <Style BasedOn="{StaticResource DocsSectionHeadingStyle}" TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Visible" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding DisplayedProperties.Count}" Value="0">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <ItemsControl ItemTemplate="{StaticResource PropertyCardTemplate}" ItemsSource="{Binding DisplayedProperties}" />
                        </StackPanel>

                        <!--  Methods section  -->
                        <StackPanel Margin="0,18,0,0">
                            <TextBlock Text="Methods">
                                <TextBlock.Style>
                                    <Style BasedOn="{StaticResource DocsSectionHeadingStyle}" TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Visible" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding DisplayedMethods.Count}" Value="0">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <ItemsControl ItemTemplate="{StaticResource MethodCardTemplate}" ItemsSource="{Binding DisplayedMethods}" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
