<UserControl
    x:Class="MESharp.Views.DoActionSignalsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:MESharp.ViewModels"
    d:DataContext="{d:DesignInstance Type=vm:DoActionSignalsViewModel}"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <!--  Segmented view-toggle button: a flat pill that fills with the primary color when its view is active.  -->
        <Style x:Key="ViewToggle" TargetType="ToggleButton">
            <Setter Property="Padding" Value="12,5" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Foreground" Value="{DynamicResource App.SubtleForegroundBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border
                            x:Name="Chip"
                            Padding="{TemplateBinding Padding}"
                            Background="Transparent"
                            BorderBrush="{DynamicResource App.BorderBrush}"
                            BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Chip" Property="Background" Value="{DynamicResource PrimaryBrush}" />
                                <Setter TargetName="Chip" Property="BorderBrush" Value="{DynamicResource PrimaryBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource PrimaryForegroundBrush}" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsChecked" Value="False" />
                                    <Condition Property="IsMouseOver" Value="True" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Chip" Property="Background" Value="{DynamicResource PrimarySoftBrush}" />
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  Click-history cards in a ListBox: strip the default selection chrome and let the card border show selection itself.  -->
        <Style x:Key="ClickHistoryItem" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <ContentPresenter />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <Border
            Grid.Row="0"
            Grid.ColumnSpan="2"
            Margin="0,0,0,8"
            Padding="10"
            Background="{DynamicResource App.CardBrush}"
            CornerRadius="6">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <!--
                    Capture toggle: master switch for the native DoAction hook. Far left and
                    loud on purpose — without it the feed only shows tool-dispatched calls.
                    The dot reports the actual native bridge state (green live / gray off /
                    red unreachable); hover for the diagnostic.
                -->
                <ToggleButton
                    Margin="0,0,14,0"
                    Padding="0"
                    VerticalAlignment="Center"
                    Cursor="Hand"
                    IsChecked="{Binding CaptureEnabled}"
                    ToolTip="{Binding NativeBridgeText}">
                    <ToggleButton.Template>
                        <ControlTemplate TargetType="ToggleButton">
                            <Border
                                x:Name="Pill"
                                Padding="12,5"
                                Background="#33555555"
                                BorderBrush="#55777777"
                                BorderThickness="1.5"
                                CornerRadius="14">
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse x:Name="StateDot" Width="10" Height="10" Margin="0,0,7,0" VerticalAlignment="Center" Fill="#9E9E9E" />
                                    <TextBlock
                                        x:Name="PillText"
                                        VerticalAlignment="Center"
                                        FontWeight="Bold"
                                        Foreground="{DynamicResource App.ForegroundBrush}"
                                        Text="CAPTURE OFF" />
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter TargetName="Pill" Property="Background" Value="#2A4CAF50" />
                                    <Setter TargetName="Pill" Property="BorderBrush" Value="#4CAF50" />
                                    <Setter TargetName="PillText" Property="Text" Value="CAPTURE ON" />
                                </Trigger>
                                <DataTrigger Binding="{Binding NativeBridgeState}" Value="ok">
                                    <Setter TargetName="StateDot" Property="Fill" Value="#4CAF50" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding NativeBridgeState}" Value="error">
                                    <Setter TargetName="StateDot" Property="Fill" Value="#F44336" />
                                    <Setter TargetName="Pill" Property="BorderBrush" Value="#F44336" />
                                </DataTrigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Pill" Property="Background" Value="#4A555555" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </ToggleButton.Template>
                </ToggleButton>

                <iconPacks:PackIconMaterial Margin="0,0,6,0" Kind="ChartTimelineVariant" />
                <TextBlock Margin="0,0,18,0" VerticalAlignment="Center" FontSize="15" FontWeight="SemiBold" Text="DoAction Signals" />

                <!--  View toggle: swap the full content area between the raw Signals grid and the parsed Click History list.  -->
                <Border Margin="0,0,18,0" VerticalAlignment="Center" CornerRadius="4" ClipToBounds="True">
                    <StackPanel Orientation="Horizontal">
                        <ToggleButton
                            Content="Signals"
                            IsChecked="{Binding ShowSignalsView}"
                            Style="{StaticResource ViewToggle}"
                            ToolTip="Show the full DoAction signal data grid." />
                        <ToggleButton
                            Content="Click History"
                            IsChecked="{Binding ShowClickHistoryView}"
                            Style="{StaticResource ViewToggle}"
                            ToolTip="Show the full parsed in-game click history list." />
                    </StackPanel>
                </Border>

                <TextBlock VerticalAlignment="Center" Text="Max:" />
                <TextBox Width="60" Margin="6,0,12,0" Text="{Binding MaxCount, UpdateSourceTrigger=PropertyChanged}" />

                <CheckBox Margin="0,0,12,0" VerticalAlignment="Center" Content="Include Failed" IsChecked="{Binding IncludeFailed}" />
                <CheckBox Margin="0,0,12,0" VerticalAlignment="Center" Content="Auto Refresh" IsChecked="{Binding AutoRefresh}" />
                <CheckBox Margin="0,0,12,0" VerticalAlignment="Center" Content="Echo To Console" IsChecked="{Binding EchoToConsole}" />

                <Button Margin="0,0,8,0" Padding="10,4" Command="{Binding RefreshCommand}" Content="Refresh" Style="{StaticResource AccentButton}" />
                <Button
                    Margin="0,0,8,0"
                    Padding="10,4"
                    Command="{Binding CopyAsApiCallCommand}"
                    Content="Copy API call"
                    ToolTip="Copy the selected click as a ready-to-paste C# API call (Objects.DoActionByIds / NPC.DoActionByIds / ...)." />
                <Button Margin="0,0,8,0" Padding="10,4" Command="{Binding CopySelectedCommand}" Content="Copy Selected" />
                <Button Margin="0,0,8,0" Padding="10,4" Command="{Binding CopyAllCommand}" Content="Copy All" />
                <Button Padding="10,4" Command="{Binding ClearBufferCommand}" Content="Clear Buffer" />
            </StackPanel>
        </Border>

        <DataGrid
            Grid.Row="1"
            Grid.Column="0"
            Grid.ColumnSpan="2"
            AutoGenerateColumns="False"
            Background="{DynamicResource App.BackgroundBrush}"
            BorderThickness="0"
            CanUserAddRows="False"
            CanUserDeleteRows="False"
            CanUserSortColumns="True"
            Foreground="{DynamicResource App.ForegroundBrush}"
            GridLinesVisibility="Horizontal"
            HeadersVisibility="Column"
            IsReadOnly="True"
            ItemsSource="{Binding Signals}"
            ScrollViewer.HorizontalScrollBarVisibility="Auto"
            ScrollViewer.CanContentScroll="True"
            SelectedItem="{Binding SelectedSignal}"
            Visibility="{Binding ShowSignalsView, Converter={StaticResource BoolToVis}}">
            <DataGrid.Columns>
                <DataGridTextColumn Width="200" Binding="{Binding TimestampUtc, StringFormat={}{0:O}}" Header="Timestamp UTC" />
                <!-- Kind chip: color-coded by signal type, ● = real player click (native hook), ○ = tool-dispatched -->
                <DataGridTemplateColumn Width="110" Header="Kind" SortMemberPath="Kind">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Ellipse Width="9" Height="9" Margin="2,0,6,0" VerticalAlignment="Center">
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Setter Property="Fill" Value="#9E9E9E" />
                                            <Setter Property="Stroke" Value="Transparent" />
                                            <Setter Property="StrokeThickness" Value="0" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Kind}" Value="Object">
                                                    <Setter Property="Fill" Value="#FFB74D" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Kind}" Value="NPC">
                                                    <Setter Property="Fill" Value="#E57373" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Kind}" Value="Walk">
                                                    <Setter Property="Fill" Value="#64B5F6" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Kind}" Value="GroundItem">
                                                    <Setter Property="Fill" Value="#A1887F" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Kind}" Value="Interface">
                                                    <Setter Property="Fill" Value="#BA68C8" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Kind}" Value="Inventory">
                                                    <Setter Property="Fill" Value="#81C784" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Kind}" Value="Bank">
                                                    <Setter Property="Fill" Value="#4DB6AC" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Kind}" Value="Player">
                                                    <Setter Property="Fill" Value="#F06292" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Kind}" Value="Tool">
                                                    <Setter Property="Fill" Value="#90A4AE" />
                                                </DataTrigger>
                                                <!-- Player clicks get a white ring so they stand out from tool-dispatched signals of the same kind -->
                                                <DataTrigger Binding="{Binding IsPlayerClick}" Value="True">
                                                    <Setter Property="Stroke" Value="{DynamicResource App.ForegroundBrush}" />
                                                    <Setter Property="StrokeThickness" Value="1.5" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>
                                <TextBlock VerticalAlignment="Center" Text="{Binding Kind}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsPlayerClick}" Value="True">
                                                    <Setter Property="FontWeight" Value="SemiBold" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Width="120" Binding="{Binding Surface}" Header="Surface" />
                <DataGridTextColumn Width="120" Binding="{Binding Operation}" Header="Operation" />
                <DataGridTextColumn Width="110" Binding="{Binding TileText}" Header="Player Tile" />
                <DataGridTextColumn Width="80" Binding="{Binding Result}" Header="Result" />
                <DataGridTextColumn Width="900" MinWidth="600" Binding="{Binding Snippet}" Header="Snippet">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="FontFamily" Value="Consolas" />
                            <Setter Property="TextWrapping" Value="NoWrap" />
                            <Setter Property="TextTrimming" Value="None" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!--  Click History: parsed real in-game clicks (newest first) showing the exact action opcode + route offset,
              plus a one-click "Copy API" to paste a calibrated API call straight into a script.  -->
        <Border
            Grid.Row="1"
            Grid.Column="0"
            Grid.ColumnSpan="2"
            Padding="10"
            Background="{DynamicResource App.CardBrush}"
            CornerRadius="6"
            Visibility="{Binding ShowClickHistoryView, Converter={StaticResource BoolToVis}}">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal">
                    <iconPacks:PackIconMaterial Margin="0,0,6,0" VerticalAlignment="Center" Kind="History" />
                    <TextBlock VerticalAlignment="Center" FontWeight="SemiBold" Text="Click History" />
                </StackPanel>
                <TextBlock
                    DockPanel.Dock="Top"
                    Margin="0,2,0,8"
                    Foreground="{DynamicResource App.MutedBrush}"
                    Text="Last 50 in-game clicks — select a card to copy via the toolbar, or click ⧉ on a card to copy a ready-to-paste API call." />
                <ListBox
                    Background="Transparent"
                    BorderThickness="0"
                    HorizontalContentAlignment="Stretch"
                    ItemContainerStyle="{StaticResource ClickHistoryItem}"
                    ItemsSource="{Binding ClickHistory}"
                    ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                    ScrollViewer.VerticalScrollBarVisibility="Auto"
                    SelectedItem="{Binding SelectedClick}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                                <Border
                                    Margin="0,0,0,6"
                                    Padding="8"
                                    BorderThickness="1"
                                    CornerRadius="4">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#22808080" />
                                            <Setter Property="BorderBrush" Value="#33808080" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Kind}" Value="Object">
                                                    <Setter Property="Background" Value="#224CAF50" />
                                                    <Setter Property="BorderBrush" Value="#4CAF50" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Kind}" Value="NPC">
                                                    <Setter Property="Background" Value="#22E57373" />
                                                    <Setter Property="BorderBrush" Value="#E57373" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Kind}" Value="Interface">
                                                    <Setter Property="Background" Value="#22BA68C8" />
                                                    <Setter Property="BorderBrush" Value="#BA68C8" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Kind}" Value="GroundItem">
                                                    <Setter Property="Background" Value="#22A1887F" />
                                                    <Setter Property="BorderBrush" Value="#A1887F" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Kind}" Value="Walk">
                                                    <Setter Property="Background" Value="#2264B5F6" />
                                                    <Setter Property="BorderBrush" Value="#64B5F6" />
                                                </DataTrigger>
                                                <!--  Selected card: brighten + thicken to mark the row the toolbar copy acts on.  -->
                                                <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                                    <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}" />
                                                    <Setter Property="BorderThickness" Value="2" />
                                                    <Setter Property="Background" Value="{DynamicResource PrimarySoftBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock
                                                    Margin="0,0,6,0"
                                                    FontFamily="Consolas"
                                                    FontWeight="Bold"
                                                    Foreground="{DynamicResource App.SubtleForegroundBrush}"
                                                    Text="{Binding Tag}" />
                                                <!--  Player-click ring: white-ringed dot = real native hook click, matching the grid's Kind column.  -->
                                                <Ellipse
                                                    Width="9"
                                                    Height="9"
                                                    Margin="0,0,6,0"
                                                    VerticalAlignment="Center"
                                                    Fill="Transparent"
                                                    Stroke="{DynamicResource App.ForegroundBrush}"
                                                    StrokeThickness="1.5"
                                                    Visibility="{Binding IsPlayerClick, Converter={StaticResource BoolToVis}}" />
                                                <TextBlock
                                                    FontWeight="SemiBold"
                                                    Foreground="{DynamicResource App.ForegroundBrush}"
                                                    Text="{Binding Title}" />
                                            </StackPanel>
                                            <!--  Grid-parity metadata line: time · surface.operation · result · player tile.  -->
                                            <StackPanel Margin="0,3,0,0" Orientation="Horizontal">
                                                <TextBlock
                                                    Margin="0,0,8,0"
                                                    FontFamily="Consolas"
                                                    FontSize="11"
                                                    Foreground="{DynamicResource App.MutedBrush}"
                                                    Text="{Binding TimeText}" />
                                                <TextBlock
                                                    Margin="0,0,8,0"
                                                    FontFamily="Consolas"
                                                    FontSize="11"
                                                    Foreground="{DynamicResource App.MutedBrush}">
                                                    <Run Text="{Binding Surface, Mode=OneWay}" /><Run Text="." /><Run Text="{Binding Operation, Mode=OneWay}" />
                                                </TextBlock>
                                                <TextBlock
                                                    Margin="0,0,8,0"
                                                    FontFamily="Consolas"
                                                    FontSize="11"
                                                    FontWeight="SemiBold"
                                                    Text="{Binding ResultText}">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="{DynamicResource StatusTrueBrush}" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Result}" Value="False">
                                                                    <Setter Property="Foreground" Value="{DynamicResource StatusFalseBrush}" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                                <TextBlock
                                                    FontFamily="Consolas"
                                                    FontSize="11"
                                                    Foreground="{DynamicResource App.MutedBrush}"
                                                    Text="{Binding TileText}" />
                                            </StackPanel>
                                            <TextBlock
                                                Margin="0,2,0,0"
                                                FontFamily="Consolas"
                                                FontSize="11"
                                                Foreground="{DynamicResource App.MutedBrush}"
                                                Text="{Binding Detail}"
                                                TextWrapping="Wrap" />
                                            <!--  Raw captured snippet (the grid's Snippet column).  -->
                                            <TextBlock
                                                Margin="0,2,0,0"
                                                FontFamily="Consolas"
                                                FontSize="11"
                                                Foreground="{DynamicResource App.MutedBrush}"
                                                Opacity="0.8"
                                                Text="{Binding Snippet}"
                                                TextTrimming="CharacterEllipsis"
                                                ToolTip="{Binding Snippet}" />
                                            <TextBlock
                                                Margin="0,4,0,0"
                                                FontFamily="Consolas"
                                                FontSize="11"
                                                Foreground="{DynamicResource App.SubtleForegroundBrush}"
                                                Text="{Binding ApiSnippet}"
                                                TextWrapping="Wrap" />
                                        </StackPanel>
                                        <Button
                                            Grid.Column="1"
                                            VerticalAlignment="Top"
                                            Padding="6,2"
                                            Command="{Binding DataContext.CopyClickCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                            CommandParameter="{Binding}"
                                            Content="⧉"
                                            FontSize="13"
                                            ToolTip="Copy ready-to-paste API call" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
            </DockPanel>
        </Border>

        <Border
            Grid.Row="2"
            Grid.ColumnSpan="2"
            Margin="0,8,0,0"
            Padding="10"
            Background="{DynamicResource App.CardBrush}"
            CornerRadius="6">
            <StackPanel>
                <TextBlock FontWeight="SemiBold" TextWrapping="Wrap" Text="{Binding NativeBridgeText}">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="{DynamicResource App.SubtleForegroundBrush}" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding NativeBridgeState}" Value="ok">
                                    <Setter Property="Foreground" Value="#4CAF50" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding NativeBridgeState}" Value="error">
                                    <Setter Property="Foreground" Value="#F44336" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <TextBlock Margin="0,4,0,0" Foreground="{DynamicResource App.SubtleForegroundBrush}" Text="{Binding StatusMessage}" />
                <TextBlock
                    Margin="0,6,0,0"
                    Foreground="{DynamicResource App.MutedBrush}"
                    Text="Unified feed: tool-dispatched API DoAction calls plus real player clicks streamed live from the native DoAction hook (ringed dots, with the player's tile at click time). Color = signal kind: orange object, red NPC, blue walk, purple interface, green inventory, teal bank. Select a row and 'Copy API call', or copy any click-history card, to paste a calibrated API call straight into a script."
                    TextWrapping="Wrap" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
