<UserControl
    x:Class="MESharp.Views.TraceRecorderView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:MESharp.ViewModels"
    d:DataContext="{d:DesignInstance Type=vm:TraceRecorderViewModel}"
    d:DesignHeight="600"
    d:DesignWidth="800"
    mc:Ignorable="d">

    <UserControl.Resources>
        <Style x:Key="Stat" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Consolas" />
            <Setter Property="FontSize" Value="18" />
            <Setter Property="Foreground" Value="{DynamicResource App.ForegroundBrush}" />
        </Style>
        <Style x:Key="StatLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Opacity" Value="0.7" />
            <Setter Property="Foreground" Value="{DynamicResource App.ForegroundBrush}" />
        </Style>
        <Style x:Key="LogLine" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Consolas" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Margin" Value="0,1" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="Foreground" Value="{DynamicResource App.ForegroundBrush}" />
        </Style>
    </UserControl.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock
            Grid.Row="0"
            Margin="0,0,0,10"
            Text="Record a hand-played session (heartbeat + clicks + screenshots) to a trace folder for agent analysis."
            TextWrapping="Wrap"
            Opacity="0.8" />

        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="180" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <ComboBox
                Grid.Column="0"
                MinWidth="200"
                VerticalContentAlignment="Center"
                DisplayMemberPath="Display"
                ItemsSource="{Binding Profiles}"
                SelectedItem="{Binding SelectedProfile}" />
            <TextBlock
                Grid.Column="1"
                Margin="12,0,12,0"
                VerticalAlignment="Center"
                Opacity="0.72"
                Text="{Binding ProfileDescription}"
                TextTrimming="CharacterEllipsis" />
            <TextBox
                Grid.Column="2"
                Margin="0,0,8,0"
                VerticalContentAlignment="Center"
                Text="{Binding CustomProfileName, UpdateSourceTrigger=PropertyChanged}" />
            <Button
                Grid.Column="3"
                Padding="10,6"
                Cursor="Hand"
                Command="{Binding SaveProfileCommand}"
                Content="Save Profile" />
            <Button
                Grid.Column="4"
                Margin="8,0,0,0"
                Padding="10,6"
                Cursor="Hand"
                Command="{Binding RefreshProfilesCommand}"
                Content="Refresh" />
            <Button
                Grid.Column="5"
                Margin="8,0,0,0"
                Padding="10,6"
                Cursor="Hand"
                Command="{Binding OpenProfilesFolderCommand}"
                Content="Profiles Folder" />
        </Grid>

        <WrapPanel Grid.Row="2" Orientation="Horizontal">
            <Button
                MinWidth="150"
                Padding="16,8"
                Cursor="Hand"
                Command="{Binding ToggleCommand}"
                Content="{Binding ToggleLabel}" />
            <CheckBox
                Margin="16,0,0,0"
                VerticalAlignment="Center"
                IsChecked="{Binding ExtendedReads}"
                Content="Force all extended reads" />
            <CheckBox
                Margin="16,0,0,0"
                VerticalAlignment="Center"
                IsChecked="{Binding CaptureScreenshots}"
                Content="Screenshots" />
            <TextBlock
                Margin="16,0,6,0"
                VerticalAlignment="Center"
                Opacity="0.72"
                Text="Mode" />
            <ComboBox
                MinWidth="150"
                VerticalContentAlignment="Center"
                ItemsSource="{Binding ScreenshotModeOptions}"
                SelectedItem="{Binding SelectedScreenshotMode}" />
            <Button
                Margin="16,0,0,0"
                Padding="12,8"
                Cursor="Hand"
                Command="{Binding OpenFolderCommand}"
                Content="Open Folder" />
        </WrapPanel>

        <UniformGrid Grid.Row="3" Margin="0,16,0,0" Columns="4" Rows="1">
            <StackPanel>
                <TextBlock Style="{StaticResource Stat}" Text="{Binding Heartbeats}" />
                <TextBlock Style="{StaticResource StatLabel}" Text="heartbeats" />
            </StackPanel>
            <StackPanel>
                <TextBlock Style="{StaticResource Stat}" Text="{Binding Clicks}" />
                <TextBlock Style="{StaticResource StatLabel}" Text="clicks" />
            </StackPanel>
            <StackPanel>
                <TextBlock Style="{StaticResource Stat}" Text="{Binding Screenshots}" />
                <TextBlock Style="{StaticResource StatLabel}" Text="screenshots" />
            </StackPanel>
            <StackPanel>
                <TextBlock Style="{StaticResource Stat}" Text="{Binding Samples}" />
                <TextBlock Style="{StaticResource StatLabel}" Text="total samples" />
            </StackPanel>
        </UniformGrid>

        <TextBlock
            Grid.Row="4"
            Margin="0,14,0,6"
            FontFamily="Consolas"
            FontSize="11"
            Opacity="0.7"
            TextTrimming="CharacterEllipsis"
            Text="{Binding SessionDir}" />

        <Expander
            Grid.Row="5"
            Margin="0,4,0,0"
            IsExpanded="True"
            Header="Saved traces (cleanup)">
            <StackPanel Margin="0,8,0,0">
                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                    <Button Padding="10,4" Cursor="Hand" Command="{Binding RefreshTracesCommand}" Content="Refresh" />
                    <Button Margin="8,0,0,0" Padding="10,4" Cursor="Hand" Command="{Binding OpenTraceCommand}" Content="Open" />
                    <Button Margin="8,0,0,0" Padding="10,4" Cursor="Hand" Command="{Binding DeleteSelectedCommand}" Content="Delete Selected" />
                    <Button Margin="8,0,0,0" Padding="10,4" Cursor="Hand" Command="{Binding DeleteAllCommand}" Content="Delete All" />
                    <TextBlock Margin="12,0,0,0" VerticalAlignment="Center" Opacity="0.7" Text="{Binding TracesSummary}" />
                </StackPanel>
                <ListBox
                    MaxHeight="150"
                    FontFamily="Consolas"
                    FontSize="12"
                    SelectedItem="{Binding SelectedTrace}"
                    ItemsSource="{Binding Traces}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Display}" />
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </StackPanel>
        </Expander>

        <Border
            Grid.Row="6"
            BorderThickness="1"
            BorderBrush="{DynamicResource App.ForegroundBrush}"
            Opacity="0.95">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="8">
                <ItemsControl ItemsSource="{Binding LogLines}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Style="{StaticResource LogLine}" Text="{Binding}" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
