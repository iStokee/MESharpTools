<UserControl
    x:Class="MESharp.Views.NamedVerbTesterView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:MESharp.ViewModels"
    d:DataContext="{d:DesignInstance Type=vm:NamedVerbTesterViewModel}"
    d:DesignHeight="600"
    d:DesignWidth="800"
    mc:Ignorable="d">

    <UserControl.Resources>
        <Style x:Key="VerbButton" TargetType="Button">
            <Setter Property="Margin" Value="0,0,8,8" />
            <Setter Property="Padding" Value="14,6" />
            <Setter Property="MinWidth" Value="76" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style x:Key="ObsLine" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Consolas" />
            <Setter Property="Margin" Value="0,2" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="Foreground" Value="{DynamicResource App.ForegroundBrush}" />
        </Style>
    </UserControl.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  Target selection  -->
        <StackPanel
            Grid.Row="0"
            Margin="0,0,0,10"
            Orientation="Horizontal">
            <RadioButton
                VerticalAlignment="Center"
                Content="NPC"
                GroupName="Kind"
                IsChecked="{Binding IsNpc, Mode=TwoWay}" />
            <RadioButton
                Margin="12,0,0,0"
                VerticalAlignment="Center"
                Content="Object"
                GroupName="Kind"
                IsChecked="{Binding IsObject, Mode=TwoWay}" />
            <TextBlock
                Margin="20,0,6,0"
                VerticalAlignment="Center"
                Foreground="{DynamicResource App.SubtleForegroundBrush}"
                Text="Definition id:" />
            <TextBox
                Width="120"
                VerticalAlignment="Center"
                Text="{Binding TargetId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            <Button
                Margin="10,0,0,0"
                Padding="12,4"
                Command="{Binding RefreshActionsCommand}"
                Content="Refresh actions" />
        </StackPanel>

        <TextBlock
            Grid.Row="1"
            Margin="0,0,0,8"
            Foreground="{DynamicResource App.SubtleForegroundBrush}"
            Text="{Binding ResolveStatus}" />

        <!--  Resolved cache actions  -->
        <ListView
            Grid.Row="2"
            BorderBrush="{DynamicResource App.BorderBrush}"
            BorderThickness="1"
            ItemsSource="{Binding Actions}">
            <ListView.View>
                <GridView>
                    <GridViewColumn Width="60" Header="Index" DisplayMemberBinding="{Binding Index}" />
                    <GridViewColumn Width="220" Header="Name" DisplayMemberBinding="{Binding Name}" />
                    <GridViewColumn Width="120" Header="ActionParam" DisplayMemberBinding="{Binding ActionParamHex}" />
                    <GridViewColumn Width="100" Header="Route" DisplayMemberBinding="{Binding Route}" />
                </GridView>
            </ListView.View>
        </ListView>

        <!--  Verb buttons  -->
        <StackPanel Grid.Row="3" Margin="0,12,0,0">
            <TextBlock
                Margin="0,0,0,6"
                Foreground="{DynamicResource App.SubtleForegroundBrush}"
                Text="Fire a named verb (resolves the action by name from the cache, then dispatches):" />
            <WrapPanel>
                <Button
                    Command="{Binding FireCommand}"
                    CommandParameter="Attack"
                    Content="Attack"
                    Style="{StaticResource VerbButton}" />
                <Button
                    Command="{Binding FireCommand}"
                    CommandParameter="Talk"
                    Content="Talk"
                    Style="{StaticResource VerbButton}" />
                <Button
                    Command="{Binding FireCommand}"
                    CommandParameter="Trade"
                    Content="Trade"
                    Style="{StaticResource VerbButton}" />
                <Border Width="1" Margin="6,2,12,2" Background="{DynamicResource App.BorderBrush}" />
                <Button
                    Command="{Binding FireCommand}"
                    CommandParameter="Open"
                    Content="Open"
                    Style="{StaticResource VerbButton}" />
                <Button
                    Command="{Binding FireCommand}"
                    CommandParameter="Bank"
                    Content="Bank"
                    Style="{StaticResource VerbButton}" />
                <Button
                    Command="{Binding FireCommand}"
                    CommandParameter="Climb"
                    Content="Climb"
                    Style="{StaticResource VerbButton}" />
                <Button
                    Command="{Binding FireCommand}"
                    CommandParameter="Enter"
                    Content="Enter"
                    Style="{StaticResource VerbButton}" />
            </WrapPanel>
            <TextBlock
                Margin="0,2,0,0"
                FontFamily="Consolas"
                Foreground="{DynamicResource App.ForegroundBrush}"
                Text="{Binding LastResult}"
                TextWrapping="Wrap" />
        </StackPanel>

        <Border
            Grid.Row="4"
            Margin="0,12,0,0"
            Padding="10"
            BorderBrush="{DynamicResource App.BorderBrush}"
            BorderThickness="1">
            <StackPanel>
                <TextBlock
                    Margin="0,0,0,4"
                    FontWeight="SemiBold"
                    Foreground="{DynamicResource App.SubtleForegroundBrush}"
                    Text="Live postcondition observables (refreshing) — watch these flip after firing:" />
                <TextBlock Style="{StaticResource ObsLine}" Text="{Binding ObsInteract}" />
                <TextBlock Style="{StaticResource ObsLine}" Text="{Binding ObsBank}" />
                <TextBlock Style="{StaticResource ObsLine}" Text="{Binding ObsTile}" />
            </StackPanel>
        </Border>

        <TextBlock
            Grid.Row="5"
            Margin="0,8,0,0"
            FontSize="11"
            Foreground="{DynamicResource App.SubtleForegroundBrush}"
            Text="Attack/Talk → InCombat/Interacting · Open/Bank → Bank.IsOpen · Climb/Enter → Tile/plane change"
            TextWrapping="Wrap" />
    </Grid>
</UserControl>
