<UserControl x:Class="MESharp.Views.NavigationHubView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:conv="clr-namespace:MESharp.Converters"
             xmlns:views="clr-namespace:MESharp.Views"
             xmlns:vm="clr-namespace:MESharp.ViewModels"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="1100">
    <UserControl.Resources>
        <!-- Local converter: hosted mode (WpfScriptHost) never applies App.xaml, so
             app-level converters don't exist there. Same pattern as ApiDocsView. -->
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <Style x:Key="HubNavButton" TargetType="ToggleButton" BasedOn="{StaticResource {x:Type ToggleButton}}">
            <Setter Property="Margin" Value="0,0,0,6" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="170" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- ── Live status strip: shared context for every section ─────────── -->
        <Border Grid.Row="0" Grid.ColumnSpan="2" Margin="0,0,0,8" Padding="12,6"
                Background="{DynamicResource App.CardBrush}" CornerRadius="8">
            <DockPanel>
                <!-- Recording chip — visible whenever either recorder is running -->
                <Border DockPanel.Dock="Left" Margin="0,0,12,0" Padding="8,2" CornerRadius="10"
                        Background="#2AF44336" BorderBrush="#F44336" BorderThickness="1"
                        Visibility="{Binding IsRecordingActive, Converter={StaticResource BoolToVisibilityConverter}}">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Style="{StaticResource Hub.StatusDot}" Fill="#F44336" />
                        <TextBlock Text="REC" FontWeight="Bold" FontSize="11" Foreground="#F44336" VerticalAlignment="Center" />
                    </StackPanel>
                </Border>

                <TextBlock DockPanel.Dock="Right" VerticalAlignment="Center" FontSize="11"
                           Foreground="{DynamicResource App.SubtleForegroundBrush}" Text="{Binding GraphStatsText}" />

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <iconPacks:PackIconMaterial Kind="MapMarkerAccount" Width="14" Height="14" Margin="0,0,6,0"
                                                VerticalAlignment="Center" Foreground="{DynamicResource PrimaryBrush}" />
                    <TextBlock Text="{Binding PlayerTileText}" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"
                               Foreground="{DynamicResource App.ForegroundBrush}" />

                    <Rectangle Width="1" Height="14" Margin="14,0" Fill="{DynamicResource App.BorderBrush}" />

                    <Ellipse>
                        <Ellipse.Style>
                            <Style TargetType="Ellipse" BasedOn="{StaticResource Hub.StatusDot}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CollisionState}" Value="ok">
                                        <Setter Property="Fill" Value="#4CAF50" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding CollisionState}" Value="warn">
                                        <Setter Property="Fill" Value="#FFC107" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock Text="{Binding CollisionText}" FontSize="11" VerticalAlignment="Center"
                               Foreground="{DynamicResource App.SubtleForegroundBrush}" />

                    <Rectangle Width="1" Height="14" Margin="14,0" Fill="{DynamicResource App.BorderBrush}" />

                    <TextBlock Text="{Binding NearestNodeText}" FontSize="11" VerticalAlignment="Center"
                               Foreground="{DynamicResource App.SubtleForegroundBrush}" />
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ── Left nav rail ─────────────────────────────────────────────── -->
        <Border Grid.Row="1" Grid.Column="0" Background="{DynamicResource App.CardBrush}" CornerRadius="8" Padding="10" Margin="0,0,8,0">
            <DockPanel>
                <!-- Auto-validate status chip -->
                <Button DockPanel.Dock="Top" Command="{Binding RefreshValidationCommand}"
                        Margin="0,0,0,12" Padding="8,6" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                        Background="{DynamicResource App.BackgroundBrush}" BorderBrush="{DynamicResource App.BorderBrush}"
                        ToolTip="{Binding ValidationDetail}">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="10" Height="10" Margin="0,0,7,0" VerticalAlignment="Center">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="#9E9E9E" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ValidationState}" Value="ok">
                                            <Setter Property="Fill" Value="#4CAF50" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding ValidationState}" Value="warn">
                                            <Setter Property="Fill" Value="#FFC107" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding ValidationState}" Value="error">
                                            <Setter Property="Fill" Value="#F44336" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                        <TextBlock Text="{Binding ValidationText}" FontSize="11" VerticalAlignment="Center"
                                   Foreground="{DynamicResource App.ForegroundBrush}" TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </Button>

                <StackPanel DockPanel.Dock="Top">
                    <ToggleButton Style="{StaticResource HubNavButton}"
                                  Command="{Binding ShowMapCommand}"
                                  IsChecked="{Binding IsMapSelected, Mode=OneWay}"
                                  ToolTip="Live world map — player marker, nodes, edges, routes, click-to-author, path generation, travel">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="Map" Width="16" Height="16" Margin="0,0,8,0" VerticalAlignment="Center"
                                                        Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}" />
                            <TextBlock Text="Map" />
                        </StackPanel>
                    </ToggleButton>
                    <ToggleButton Style="{StaticResource HubNavButton}"
                                  Command="{Binding ShowTravelCommand}"
                                  IsChecked="{Binding IsTravelSelected, Mode=OneWay}"
                                  ToolTip="Movement, walking and teleport probes">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="CompassOutline" Width="16" Height="16" Margin="0,0,8,0" VerticalAlignment="Center"
                                                        Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}" />
                            <TextBlock Text="Travel" />
                        </StackPanel>
                    </ToggleButton>
                    <ToggleButton Style="{StaticResource HubNavButton}"
                                  Command="{Binding ShowRoutesCommand}"
                                  IsChecked="{Binding IsRoutesSelected, Mode=OneWay}"
                                  ToolTip="Route editor, recorder and execution">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="MapMarkerPath" Width="16" Height="16" Margin="0,0,8,0" VerticalAlignment="Center"
                                                        Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}" />
                            <TextBlock Text="Routes" />
                        </StackPanel>
                    </ToggleButton>
                    <ToggleButton Style="{StaticResource HubNavButton}"
                                  Command="{Binding ShowGraphCommand}"
                                  IsChecked="{Binding IsGraphSelected, Mode=OneWay}"
                                  ToolTip="Graph nodes, edges and recorder (table/bulk view)">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="Graph" Width="16" Height="16" Margin="0,0,8,0" VerticalAlignment="Center"
                                                        Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}" />
                            <TextBlock Text="Graph Data" />
                        </StackPanel>
                    </ToggleButton>
                </StackPanel>

                <TextBlock DockPanel.Dock="Bottom" VerticalAlignment="Bottom" FontSize="10" TextWrapping="Wrap"
                           Foreground="{DynamicResource App.MutedBrush}"
                           Text="The map is the primary authoring surface; Routes and Graph Data are the table/detail editors." />
            </DockPanel>
        </Border>

        <!-- ── Content ───────────────────────────────────────────────────── -->
        <Grid Grid.Row="1" Grid.Column="1">
            <!-- Map stays alive while hidden so WebView2 keeps its pan/zoom state -->
            <views:MapView DataContext="{Binding Map}" Visibility="{Binding DataContext.MapVisibility, RelativeSource={RelativeSource AncestorType={x:Type views:NavigationHubView}}}" />
            <ContentControl Content="{Binding CurrentDetailViewModel}" Visibility="{Binding DetailVisibility}" />
        </Grid>
    </Grid>
</UserControl>
