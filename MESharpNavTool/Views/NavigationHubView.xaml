<UserControl
    x:Class="MESharp.Views.NavigationHubView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="clr-namespace:MESharp.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:views="clr-namespace:MESharp.Views"
    xmlns:vm="clr-namespace:MESharp.ViewModels"
    d:DesignHeight="700"
    d:DesignWidth="1100"
    mc:Ignorable="d">
    <UserControl.Resources>
        <!--
            Local converter: hosted mode (WpfScriptHost) never applies App.xaml, so
            app-level converters don't exist there. Same pattern as ApiDocsView.
        -->
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <Style
            x:Key="HubNavButton"
            BasedOn="{StaticResource {x:Type ToggleButton}}"
            TargetType="ToggleButton">
            <Setter Property="Margin" Value="0,0,0,6" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="170" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!--  ── Live status strip: shared context for every section ───────────  -->
        <Border
            Grid.Row="0"
            Grid.ColumnSpan="2"
            Margin="0,0,0,8"
            Padding="12,6"
            Background="{DynamicResource App.CardBrush}"
            CornerRadius="8">
            <DockPanel>
                <!--  Recording chip — visible whenever either recorder is running  -->
                <Border
                    Margin="0,0,12,0"
                    Padding="8,2"
                    Background="#2AF44336"
                    BorderBrush="#F44336"
                    BorderThickness="1"
                    CornerRadius="10"
                    DockPanel.Dock="Left"
                    Visibility="{Binding IsRecordingActive, Converter={StaticResource BoolToVisibilityConverter}}">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Fill="#F44336" Style="{StaticResource Hub.StatusDot}" />
                        <TextBlock
                            VerticalAlignment="Center"
                            FontSize="11"
                            FontWeight="Bold"
                            Foreground="#F44336"
                            Text="REC" />
                    </StackPanel>
                </Border>

                <TextBlock
                    VerticalAlignment="Center"
                    DockPanel.Dock="Right"
                    FontSize="11"
                    Foreground="{DynamicResource App.SubtleForegroundBrush}"
                    Text="{Binding GraphStatsText}" />

                <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                    <iconPacks:PackIconMaterial
                        Width="14"
                        Height="14"
                        Margin="0,0,6,0"
                        VerticalAlignment="Center"
                        Foreground="{DynamicResource PrimaryBrush}"
                        Kind="MapMarkerAccount" />
                    <TextBlock
                        VerticalAlignment="Center"
                        FontSize="12"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource App.ForegroundBrush}"
                        Text="{Binding PlayerTileText}" />

                    <Rectangle
                        Width="1"
                        Height="14"
                        Margin="14,0"
                        Fill="{DynamicResource App.BorderBrush}" />

                    <Ellipse>
                        <Ellipse.Style>
                            <Style BasedOn="{StaticResource Hub.StatusDot}" TargetType="Ellipse">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CollisionState}" Value="ok">
                                        <Setter Property="Fill" Value="#4CAF50" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding CollisionState}" Value="warn">
                                        <Setter Property="Fill" Value="#FFC107" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock
                        VerticalAlignment="Center"
                        FontSize="11"
                        Foreground="{DynamicResource App.SubtleForegroundBrush}"
                        Text="{Binding CollisionText}" />

                    <Rectangle
                        Width="1"
                        Height="14"
                        Margin="14,0"
                        Fill="{DynamicResource App.BorderBrush}" />

                    <TextBlock
                        VerticalAlignment="Center"
                        FontSize="11"
                        Foreground="{DynamicResource App.SubtleForegroundBrush}"
                        Text="{Binding NearestNodeText}" />
                </StackPanel>
            </DockPanel>
        </Border>

        <!--  ── Left nav rail ───────────────────────────────────────────────  -->
        <Border
            Grid.Row="1"
            Grid.Column="0"
            Margin="0,0,8,0"
            Padding="10"
            Background="{DynamicResource App.CardBrush}"
            CornerRadius="8">
            <DockPanel LastChildFill="False">
                <!--  Auto-validate status chip  -->
                <Button
                    Margin="0,0,0,12"
                    Padding="8,6"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Left"
                    Background="{DynamicResource App.BackgroundBrush}"
                    BorderBrush="{DynamicResource App.BorderBrush}"
                    Command="{Binding RefreshValidationCommand}"
                    DockPanel.Dock="Top"
                    ToolTip="{Binding ValidationDetail}">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse
                            Width="10"
                            Height="10"
                            Margin="0,0,7,0"
                            VerticalAlignment="Center">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="#9E9E9E" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ValidationState}" Value="ok">
                                            <Setter Property="Fill" Value="#4CAF50" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding ValidationState}" Value="warn">
                                            <Setter Property="Fill" Value="#FFC107" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding ValidationState}" Value="error">
                                            <Setter Property="Fill" Value="#F44336" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                        <TextBlock
                            VerticalAlignment="Center"
                            FontSize="11"
                            Foreground="{DynamicResource App.ForegroundBrush}"
                            Text="{Binding ValidationText}"
                            TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </Button>

                <StackPanel DockPanel.Dock="Top">
                    <ToggleButton
                        Command="{Binding ShowMapCommand}"
                        IsChecked="{Binding IsMapSelected, Mode=OneWay}"
                        Style="{StaticResource HubNavButton}"
                        ToolTip="Live world map — player marker, nodes, edges, routes, click-to-author, path generation, travel">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial
                                Width="16"
                                Height="16"
                                Margin="0,0,8,0"
                                VerticalAlignment="Center"
                                Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"
                                Kind="Map" />
                            <TextBlock Text="Map" />
                        </StackPanel>
                    </ToggleButton>
                    <ToggleButton
                        Command="{Binding ShowTravelCommand}"
                        IsChecked="{Binding IsTravelSelected, Mode=OneWay}"
                        Style="{StaticResource HubNavButton}"
                        ToolTip="Movement, walking and teleport probes">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial
                                Width="16"
                                Height="16"
                                Margin="0,0,8,0"
                                VerticalAlignment="Center"
                                Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"
                                Kind="CompassOutline" />
                            <TextBlock Text="Travel" />
                        </StackPanel>
                    </ToggleButton>
                    <ToggleButton
                        Command="{Binding ShowRoutesCommand}"
                        IsChecked="{Binding IsRoutesSelected, Mode=OneWay}"
                        Style="{StaticResource HubNavButton}"
                        ToolTip="Route editor, recorder and execution">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial
                                Width="16"
                                Height="16"
                                Margin="0,0,8,0"
                                VerticalAlignment="Center"
                                Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"
                                Kind="MapMarkerPath" />
                            <TextBlock Text="Routes" />
                        </StackPanel>
                    </ToggleButton>
                    <ToggleButton
                        Command="{Binding ShowGraphCommand}"
                        IsChecked="{Binding IsGraphSelected, Mode=OneWay}"
                        Style="{StaticResource HubNavButton}"
                        ToolTip="Graph nodes, edges and recorder (table/bulk view)">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial
                                Width="16"
                                Height="16"
                                Margin="0,0,8,0"
                                VerticalAlignment="Center"
                                Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"
                                Kind="Graph" />
                            <TextBlock Text="Graph Data" />
                        </StackPanel>
                    </ToggleButton>
                    <ToggleButton
                        Command="{Binding ShowDungeonsCommand}"
                        IsChecked="{Binding IsDungeonsSelected, Mode=OneWay}"
                        Style="{StaticResource HubNavButton}"
                        ToolTip="Dungeon-aware graph imports from RuneScape Wiki maps">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial
                                Width="16"
                                Height="16"
                                Margin="0,0,8,0"
                                VerticalAlignment="Center"
                                Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"
                                Kind="MapSearch" />
                            <TextBlock Text="Dungeons" />
                        </StackPanel>
                    </ToggleButton>
                    <ToggleButton
                        Command="{Binding ShowVerifyCommand}"
                        IsChecked="{Binding IsVerifySelected, Mode=OneWay}"
                        Style="{StaticResource HubNavButton}"
                        ToolTip="Service desk: confirm unverified curated/synthetic nav data in-game">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial
                                Width="16"
                                Height="16"
                                Margin="0,0,8,0"
                                VerticalAlignment="Center"
                                Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"
                                Kind="ClipboardCheckOutline" />
                            <TextBlock Text="Verify" />
                        </StackPanel>
                    </ToggleButton>
                    <ToggleButton
                        Command="{Binding ShowStatusCommand}"
                        DockPanel.Dock="Bottom"
                        IsChecked="{Binding IsStatusSelected, Mode=OneWay}"
                        Style="{StaticResource HubNavButton}"
                        ToolTip="Navigation data health, collision/cache regeneration, and reload actions">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial
                                Width="16"
                                Height="16"
                                Margin="0,0,8,0"
                                VerticalAlignment="Center"
                                Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"
                                Kind="DatabaseCog" />
                            <TextBlock Text="Status" />
                        </StackPanel>
                    </ToggleButton>

                </StackPanel>


                <TextBlock
                    VerticalAlignment="Bottom"
                    DockPanel.Dock="Bottom"
                    FontSize="10"
                    Foreground="{DynamicResource App.MutedBrush}"
                    Text="Use Routes for manual draft edits; use Graph Data Recorder for a captured trail, then link it with an edge."
                    TextWrapping="Wrap" />
            </DockPanel>
        </Border>

        <!--  ── Content ─────────────────────────────────────────────────────  -->
        <Grid Grid.Row="1" Grid.Column="1">
            <!--  Map stays alive while hidden so WebView2 keeps its pan/zoom state  -->
            <views:MapView DataContext="{Binding Map}" Visibility="{Binding DataContext.MapVisibility, RelativeSource={RelativeSource AncestorType={x:Type views:NavigationHubView}}}" />
            <ContentControl Content="{Binding CurrentDetailViewModel}" Visibility="{Binding DetailVisibility}" />
        </Grid>
    </Grid>
</UserControl>
