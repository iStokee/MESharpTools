<UserControl
    x:Class="MESharp.Views.WebwalkingView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:MESharp.Views.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:MESharp.ViewModels"
    mc:Ignorable="d"
    d:DataContext="{d:DesignInstance Type=vm:WebwalkingViewModel}"
    d:DesignHeight="800"
    d:DesignWidth="1100">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <!-- Local aliases kept for existing usages; values come from Themes/NavHubResources.xaml -->
        <Style x:Key="Card" TargetType="Border" BasedOn="{StaticResource Hub.Card}">
            <!-- This view spaces its cards with explicit element margins -->
            <Setter Property="Margin" Value="0" />
        </Style>
        <Style x:Key="HintText" TargetType="TextBlock" BasedOn="{StaticResource Hub.HintText}" />
        <Style x:Key="FieldLabelText" TargetType="TextBlock" BasedOn="{StaticResource Hub.FieldLabel}" />

        <Style x:Key="ListPanel" TargetType="ListBox">
            <Setter Property="Background" Value="{DynamicResource App.BackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource App.BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="4" />
        </Style>

        <Style x:Key="RouteListItemStyle" TargetType="ListBoxItem">
            <Setter Property="Margin" Value="0,0,0,4" />
            <Setter Property="Padding" Value="8" />
            <Setter Property="Background" Value="{DynamicResource App.BackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource App.BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource PrimarySoftBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}" />
                    <Setter Property="Foreground" Value="{DynamicResource PrimaryForegroundBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <controls:SectionHeader
                Grid.Row="0"
                Margin="0,0,0,8"
                Title="Routes"
                Description="Linear route authoring and execution. Use Graph Data for node/edge topology, and Travel for low-level API tests."
                IconKind="MapSearch"
                ShowExpandCollapseAll="False"
                ShowHelp="True"
                HelpCommand="{Binding ShowHelpCommand}"
                HelpToolTip="What is webwalking? What does each panel do?">
                <controls:SectionHeader.RightContent>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Margin="0,0,14,0" VerticalAlignment="Center" FontFamily="Consolas" Style="{StaticResource HintText}" Text="{Binding CurrentTile, StringFormat=Tile: {0}}" />
                        <TextBlock Margin="0,0,14,0" VerticalAlignment="Center" FontFamily="Consolas" Style="{StaticResource HintText}" Text="{Binding RunStatus}" />
                        <TextBlock VerticalAlignment="Center" FontFamily="Consolas" Style="{StaticResource HintText}" Text="{Binding LastStatus}" />
                    </StackPanel>
                </controls:SectionHeader.RightContent>
            </controls:SectionHeader>

            <Border Grid.Row="1" Margin="0,0,0,8" Style="{StaticResource Card}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="1.2*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Margin="0,0,12,0" VerticalAlignment="Center" FontWeight="SemiBold" Text="Checklist" />
                    <StackPanel Grid.Column="1" Margin="0,0,14,0">
                        <ItemsControl ItemsSource="{Binding WorkflowSteps}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,6,4" Padding="7,3" BorderBrush="{DynamicResource App.BorderBrush}" BorderThickness="1" CornerRadius="4" Background="{DynamicResource App.BackgroundBrush}" ToolTip="{Binding Detail}">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Margin="0,0,5,0" FontFamily="Consolas" FontSize="11" Foreground="{DynamicResource App.SubtleForegroundBrush}" Text="{Binding StatusText}" />
                                            <TextBlock FontSize="11" FontWeight="SemiBold" Text="{Binding Title}" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock Margin="0,2,0,0" Style="{StaticResource HintText}" Text="{Binding WorkflowSummary}" />
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock FontWeight="SemiBold" Text="Current Checks" />
                        <TextBlock Margin="0,3,0,0" Style="{StaticResource HintText}" Text="{Binding ValidationSummary}" />
                        <TextBlock Margin="0,2,0,0" Style="{StaticResource HintText}" Text="{Binding PreflightSummary}" />
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.1*" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="1.5*" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="1.2*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource Card}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Margin="0,0,0,8">
                            <TextBlock FontWeight="SemiBold" Text="1 · Route Catalog" />
                            <TextBlock Margin="0,2,0,6" Style="{StaticResource HintText}" Text="Search by route name, category, or tags. Double-click a route to load it into the editor." />
                            <TextBox Padding="6" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>

                        <ListBox
                            Grid.Row="1"
                            Style="{StaticResource ListPanel}"
                            ItemContainerStyle="{StaticResource RouteListItemStyle}"
                            ItemsSource="{Binding FilteredRoutes}"
                            MouseDoubleClick="RouteCatalog_MouseDoubleClick"
                            SelectedItem="{Binding SelectedRoute}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel>
                                        <TextBlock FontWeight="SemiBold" Text="{Binding Name}" TextTrimming="CharacterEllipsis" />
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Style="{StaticResource HintText}" Text="{Binding Category}" />
                                            <TextBlock Style="{StaticResource HintText}" Text="{Binding Waypoints.Count, StringFormat= · {0} waypoints}" />
                                        </StackPanel>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <WrapPanel Grid.Row="2" Margin="0,8,0,0">
                            <Button Margin="0,0,6,0" Command="{Binding NewRouteCommand}" Style="{StaticResource SecondaryCommandButton}" Content="New Draft" ToolTip="Start a blank route draft" />
                            <Button Margin="0,0,6,0" Command="{Binding LoadRouteCommand}" Style="{StaticResource SecondaryCommandButton}" Content="Load To Editor" ToolTip="Load selected route into editor" />
                            <Button Margin="0,0,6,0" Command="{Binding DuplicateRouteCommand}" Style="{StaticResource SecondaryCommandButton}" Content="Clone" ToolTip="Create a copy of selected route" />
                            <Button Margin="0,0,6,0" Command="{Binding ShowRouteOnMapCommand}" Style="{StaticResource SecondaryCommandButton}" Content="Show on Map" ToolTip="Switch to the Map section centered on this route's start" />
                            <Button Margin="0,0,6,0" Command="{Binding DeleteRouteCommand}" Style="{StaticResource SecondaryCommandButton}" Content="Delete" ToolTip="Delete selected route (asks for confirmation; built-in core routes cannot be deleted)" />
                        </WrapPanel>
                    </Grid>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource Card}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Margin="0,0,0,8">
                            <TextBlock FontWeight="SemiBold" Text="2 · Route Setup" />
                            <TextBlock Margin="0,2,0,6" Style="{StaticResource HintText}" Text="Define route metadata. Use stable names for scripts (e.g. core.wildy_wall.to_green_dragons)." />
                        </StackPanel>

                        <Grid Grid.Row="1" Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="150" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                <TextBlock Style="{StaticResource FieldLabelText}" Text="Route Name" />
                                <TextBox Padding="6" Text="{Binding RouteName, UpdateSourceTrigger=PropertyChanged}" ToolTip="Route name/id used by scripts (keep stable after adoption)" />
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Style="{StaticResource FieldLabelText}" Text="Category" />
                                <ComboBox IsEditable="True"
                                          ItemsSource="{Binding CategoryOptions}"
                                          Text="{Binding RouteCategory, UpdateSourceTrigger=PropertyChanged}"
                                          ToolTip="Grouping label. Pick a known category or type a new one." />
                            </StackPanel>
                        </Grid>

                        <Grid Grid.Row="2" Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="160" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                <TextBlock Style="{StaticResource FieldLabelText}" Text="Description" />
                                <TextBox Padding="6" Text="{Binding RouteDescription, UpdateSourceTrigger=PropertyChanged}" ToolTip="Human-readable description" />
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Style="{StaticResource FieldLabelText}" Text="Tags" />
                                <TextBox Padding="6" Text="{Binding RouteTags, UpdateSourceTrigger=PropertyChanged}" ToolTip="Comma-separated tags for filtering" />
                            </StackPanel>
                        </Grid>

                        <ListBox
                            Grid.Row="3"
                            Style="{StaticResource ListPanel}"
                            ItemContainerStyle="{StaticResource RouteListItemStyle}"
                            ItemsSource="{Binding CurrentRoute}"
                            SelectedItem="{Binding SelectedWaypoint}"
                            AlternationCount="9999"
                            ToolTip="Select a waypoint to edit its details in Step 3.">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Width="28" Style="{StaticResource HintText}" FontFamily="Consolas" VerticalAlignment="Center"
                                                   Text="{Binding (ItemsControl.AlternationIndex), RelativeSource={RelativeSource AncestorType=ListBoxItem}, StringFormat={}{0}.}" />
                                        <StackPanel>
                                            <TextBlock FontWeight="SemiBold" Text="{Binding}" />
                                            <TextBlock Style="{StaticResource HintText}" Text="transition waypoint"
                                                       Visibility="{Binding IsTransition, Converter={StaticResource BoolToVis}}" />
                                        </StackPanel>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <StackPanel Grid.Row="4" Margin="0,8,0,0">
                            <TextBlock Style="{StaticResource HintText}" Text="Waypoint actions: current/target adds use your configured editor defaults." />
                            <TextBlock Margin="0,2,0,0" Style="{StaticResource HintText}" Text="First waypoint is usually the first click target from the expected start node. Add a bank/start tile only when that explicit preflight point is useful." />
                            <CheckBox Margin="0,6,0,0" Content="Route Enabled" IsChecked="{Binding RouteEnabled}" />
                            <WrapPanel Margin="0,4,0,0">
                                <Button Margin="0,0,6,0" Command="{Binding AddCurrentWaypointCommand}" Style="{StaticResource SecondaryCommandButton}" Content="Add Current Tile" />
                                <Button Margin="0,0,6,0" Command="{Binding AddTargetWaypointCommand}" Style="{StaticResource SecondaryCommandButton}" Content="Add Target Tile" />
                                <Button Margin="0,0,6,0" Command="{Binding InsertWaypointAboveCommand}" Style="{StaticResource SecondaryCommandButton}" Content="Insert Above" />
                                <Button Margin="0,0,6,0" Command="{Binding InsertWaypointBelowCommand}" Style="{StaticResource SecondaryCommandButton}" Content="Insert Below" />
                                <Button Margin="0,0,6,0" Command="{Binding MoveWaypointUpCommand}" Style="{StaticResource SecondaryCommandButton}" Content="Up" />
                                <Button Margin="0,0,6,0" Command="{Binding MoveWaypointDownCommand}" Style="{StaticResource SecondaryCommandButton}" Content="Down" />
                                <Button Margin="0,0,6,0" Command="{Binding RemoveWaypointCommand}" Style="{StaticResource SecondaryCommandButton}" Content="Remove WP" />
                                <Button Margin="0,0,6,0" Command="{Binding ClearCurrentRouteCommand}" Style="{StaticResource SecondaryCommandButton}" Content="Clear Draft" />
                            </WrapPanel>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Grid.Column="4" Style="{StaticResource Card}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBlock FontWeight="SemiBold" Text="3 · Waypoint + Run" />
                        <TextBlock Grid.Row="1" Margin="0,2,0,8" Style="{StaticResource HintText}" Text="Edit selected waypoint, then save route and run current or selected route." />

                        <StackPanel Grid.Row="2">
                            <GroupBox Header="Waypoint Position">
                                <StackPanel Margin="8">
                                    <TextBlock Style="{StaticResource HintText}" Text="Basic waypoint inputs. Most routes only need coordinates and an optional label." />
                                    <Grid Margin="0,8,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Margin="0,0,6,0">
                                            <TextBlock Style="{StaticResource FieldLabelText}" Text="X" />
                                            <TextBox Padding="6" Text="{Binding WaypointX}" ToolTip="Waypoint X" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Margin="0,0,6,0">
                                            <TextBlock Style="{StaticResource FieldLabelText}" Text="Y" />
                                            <TextBox Padding="6" Text="{Binding WaypointY}" ToolTip="Waypoint Y" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Style="{StaticResource FieldLabelText}" Text="Z" />
                                            <TextBox Padding="6" Text="{Binding WaypointZ}" ToolTip="Waypoint Z/plane" />
                                        </StackPanel>
                                    </Grid>
                                    <StackPanel Margin="0,8,0,0">
                                        <TextBlock Style="{StaticResource FieldLabelText}" Text="Label" />
                                        <TextBox Padding="6" Text="{Binding WaypointLabel, UpdateSourceTrigger=PropertyChanged}" ToolTip="Optional waypoint label" />
                                    </StackPanel>
                                    <WrapPanel Margin="0,8,0,0">
                                        <Button Margin="0,0,6,0" Command="{Binding UseCurrentTileForWaypointCommand}" Style="{StaticResource SecondaryCommandButton}" Content="Use Current Tile" />
                                        <Button Margin="0,0,6,0" Command="{Binding CopyTargetToWaypointCommand}" Style="{StaticResource SecondaryCommandButton}" Content="Use Target Inputs" />
                                    </WrapPanel>
                                </StackPanel>
                            </GroupBox>

                            <Expander Margin="0,8,0,0" Header="Advanced Waypoint Settings" IsExpanded="False">
                                <StackPanel Margin="8">
                                    <TextBlock Style="{StaticResource HintText}" Text="These settings tune arrival behavior, jitter, and transitions. Leave defaults unless a route needs special handling." />
                                    <Grid Margin="0,8,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Margin="0,0,6,0">
                                            <TextBlock Style="{StaticResource FieldLabelText}" Text="Area Radius" />
                                            <TextBox Padding="6" Text="{Binding WaypointAreaRadius}" ToolTip="Arrival area radius" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Margin="0,0,6,0">
                                            <TextBlock Style="{StaticResource FieldLabelText}" Text="Arrival Distance" />
                                            <TextBox Padding="6" Text="{Binding WaypointArrivalDistance}" ToolTip="Arrival tile distance" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Style="{StaticResource FieldLabelText}" Text="Timeout (ms)" />
                                            <TextBox Padding="6" Text="{Binding WaypointTimeoutMs}" ToolTip="Waypoint timeout ms" />
                                        </StackPanel>
                                    </Grid>
                                    <Grid Margin="0,8,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Margin="0,0,6,0">
                                            <TextBlock Style="{StaticResource FieldLabelText}" Text="Jitter Tiles" />
                                            <TextBox Padding="6" Text="{Binding WaypointJitterTiles}" ToolTip="Click jitter tiles" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Style="{StaticResource FieldLabelText}" Text="Transition Object IDs" />
                                            <TextBox Padding="6" Text="{Binding WaypointTransitionIds, UpdateSourceTrigger=PropertyChanged}" ToolTip="Transition object IDs (comma-separated)" />
                                        </StackPanel>
                                    </Grid>
                                    <CheckBox Content="Chain while moving" IsChecked="{Binding WaypointChainWhileMoving}" />
                                    <CheckBox Margin="0,4,0,0" Content="Transition waypoint" IsChecked="{Binding WaypointIsTransition}" />
                                    <WrapPanel Margin="0,8,0,0">
                                        <Button Margin="0,0,6,0" Command="{Binding ApplyWaypointEditsCommand}" Style="{StaticResource PrimaryCommandButton}" Content="Apply Settings" />
                                        <Button Margin="0,0,6,0" Command="{Binding ResetWaypointDefaultsCommand}" Style="{StaticResource SecondaryCommandButton}" Content="Reset Defaults" />
                                    </WrapPanel>
                                </StackPanel>
                            </Expander>

                            <GroupBox Margin="0,8,0,0" Header="Target Tile Helper">
                                <StackPanel Margin="8">
                                    <TextBlock Style="{StaticResource HintText}" Text="Use this helper to prepare a tile for Add Target Tile, or copy it into the waypoint editor." />
                                    <Grid Margin="0,8,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Margin="0,0,6,0">
                                            <TextBlock Style="{StaticResource FieldLabelText}" Text="Target X" />
                                            <TextBox Padding="6" Text="{Binding TargetX, UpdateSourceTrigger=PropertyChanged}" ToolTip="Target X for Add Target" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Margin="0,0,6,0">
                                            <TextBlock Style="{StaticResource FieldLabelText}" Text="Target Y" />
                                            <TextBox Padding="6" Text="{Binding TargetY, UpdateSourceTrigger=PropertyChanged}" ToolTip="Target Y for Add Target" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Style="{StaticResource FieldLabelText}" Text="Target Z" />
                                            <TextBox Padding="6" Text="{Binding TargetZ, UpdateSourceTrigger=PropertyChanged}" ToolTip="Target Z for Add Target" />
                                        </StackPanel>
                                    </Grid>
                                    <WrapPanel Margin="0,8,0,0">
                                        <Button Margin="0,0,6,0" Command="{Binding UseCurrentTileAsTargetCommand}" Style="{StaticResource SecondaryCommandButton}" Content="Use Current Tile" />
                                        <Button Margin="0,0,6,0" Command="{Binding CopyTargetToWaypointCommand}" Style="{StaticResource SecondaryCommandButton}" Content="Copy To Waypoint" />
                                    </WrapPanel>
                                </StackPanel>
                            </GroupBox>

                            <WrapPanel Margin="0,8,0,0">
                                <Button Margin="0,0,6,0" Command="{Binding ApplyWaypointEditsCommand}" Style="{StaticResource SecondaryCommandButton}" Content="Apply WP Changes" />
                                <Button Margin="0,0,6,0" Command="{Binding SaveRouteCommand}" Style="{StaticResource PrimaryCommandButton}" Content="Save Route" />
                                <Button Margin="0,0,6,0" Command="{Binding RenameRouteCommand}" Style="{StaticResource SecondaryCommandButton}" Content="Rename Route" />
                            </WrapPanel>

                            <WrapPanel Margin="0,8,0,0">
                                <Button Margin="0,0,6,0" Command="{Binding RunCurrentRouteCommand}" Style="{StaticResource PrimaryCommandButton}" Content="Run Draft" />
                                <Button Margin="0,0,6,0" Command="{Binding RunSelectedRouteCommand}" Style="{StaticResource SecondaryCommandButton}" Content="Run Catalog Route" />
                                <Button Margin="0,0,6,0" Command="{Binding StopRouteCommand}" Style="{StaticResource SecondaryCommandButton}" Content="Stop" />
                            </WrapPanel>

                            <TextBlock Margin="0,8,0,4" FontWeight="SemiBold" Text="Execution Log" />
                            <ListBox Style="{StaticResource ListPanel}" ItemContainerStyle="{StaticResource RouteListItemStyle}" ItemsSource="{Binding ActivityLog}" />
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>
