<UserControl
    x:Class="MESharp.Views.DungeonImportView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:MESharp.Views.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:MESharp.ViewModels"
    mc:Ignorable="d"
    d:DataContext="{d:DesignInstance Type=vm:DungeonImportViewModel}"
    d:DesignHeight="760"
    d:DesignWidth="1100">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <Style x:Key="Card" TargetType="Border" BasedOn="{StaticResource Hub.Card}" />
        <Style x:Key="HintText" TargetType="TextBlock" BasedOn="{StaticResource Hub.HintText}" />
        <Style x:Key="ToolButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Padding" Value="12,5" />
            <Setter Property="Margin" Value="0,0,6,0" />
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <controls:SectionHeader
            Grid.Row="0"
            Margin="8,8,8,8"
            Title="Dungeons"
            Description="Import dungeon-aware graph areas from RuneScape Wiki Advanced map data. Cache/live verification still owns executable entrance and shortcut edges."
            IconKind="MapSearch"
            ShowExpandCollapseAll="False"
            ShowHelp="False" />

        <Border Grid.Row="1" Style="{StaticResource Card}" Margin="8,0,8,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.2*" />
                    <ColumnDefinition Width="1.2*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,12,0">
                    <TextBlock Text="Starter Slayer Map" Style="{StaticResource Hub.FieldLabel}" />
                    <ComboBox ItemsSource="{Binding DungeonOptions}"
                              SelectedItem="{Binding SelectedDungeon}"
                              DisplayMemberPath="DisplayName" />
                    <TextBlock Margin="0,5,0,0" Style="{StaticResource HintText}"
                               Text="The first slice is intentionally small: ten high-value Slayer dungeon maps, with the same importer usable for any Map:* page." />
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="0,0,12,0">
                    <TextBlock Text="Custom Map:* Title" Style="{StaticResource Hub.FieldLabel}" />
                    <TextBox Text="{Binding CustomMapTitle, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="Optional. Example: Map:Ancient Cavern or Ancient Cavern. When filled, this overrides the starter dropdown." />
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <CheckBox Content="Replace exact IDs" IsChecked="{Binding ReplaceExactIds}" Margin="0,0,12,0" />
                        <CheckBox Content="Replace matching areas" IsChecked="{Binding ReplaceMatchingAreas}"
                                  ToolTip="When a wiki monster area confidently matches an existing area by tag/name and nearby center, reuse that existing area id so the better bounds update it." />
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="2" VerticalAlignment="Bottom">
                    <Button Command="{Binding FetchPreviewCommand}" Style="{StaticResource ToolButton}">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Width="16" Height="16" Margin="0,0,6,0" Kind="CloudDownloadOutline"
                                                        Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                            <TextBlock Text="Fetch Preview" />
                        </StackPanel>
                    </Button>
                    <Button Margin="0,6,6,0" Command="{Binding ImportPreviewCommand}" Style="{StaticResource AccentButton}">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Width="16" Height="16" Margin="0,0,6,0" Kind="DatabaseImport"
                                                        Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                            <TextBlock Text="Import" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="2" Margin="8,0,8,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource Card}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <DockPanel Grid.Row="0" Margin="0,0,0,6">
                        <Button DockPanel.Dock="Right" Command="{Binding ClearPreviewCommand}" Content="Clear" Padding="10,4" />
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="MapMarkerRadius" Width="14" Height="14" Margin="0,0,6,0"
                                                        VerticalAlignment="Center" Foreground="{DynamicResource PrimaryBrush}" />
                            <TextBlock Text="Preview" Style="{StaticResource Hub.SectionHeader}" Margin="0" />
                        </StackPanel>
                    </DockPanel>
                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding PreviewItems}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              CanUserAddRows="False"
                              FontSize="11"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Auto">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Kind" Binding="{Binding Kind}" Width="110" />
                            <DataGridTextColumn Header="Title" Binding="{Binding Title}" Width="220" />
                            <DataGridTextColumn Header="Confidence" Binding="{Binding Confidence}" Width="140" />
                            <DataGridTextColumn Header="Detail" Binding="{Binding Detail}" Width="*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1" Width="8" HorizontalAlignment="Stretch" Background="Transparent" />

            <Border Grid.Column="2" Style="{StaticResource Card}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Import Status" Style="{StaticResource Hub.SectionHeader}" />
                    <StackPanel Grid.Row="1">
                        <TextBlock Text="{Binding Summary}" Style="{StaticResource HintText}" Margin="0,0,0,6" />
                        <TextBlock Text="{Binding Status}" Style="{StaticResource HintText}" Margin="0,0,0,8" />
                        <ProgressBar IsIndeterminate="True" Height="6" Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}" />
                    </StackPanel>
                    <TextBox Grid.Row="2"
                             Text="{Binding Log}"
                             FontFamily="Consolas"
                             FontSize="11"
                             TextWrapping="Wrap"
                             IsReadOnly="True"
                             VerticalScrollBarVisibility="Auto" />
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="3" Style="{StaticResource Card}" Margin="8,4,8,8">
            <TextBlock Style="{StaticResource HintText}"
                       Text="Importer policy: world-coordinate wiki features become graph areas/nodes; local-coordinate maps stay preview-only until calibrated. Executable dungeon entrances and shortcuts should be created from cache/live verification, not trusted from map labels alone." />
        </Border>
    </Grid>
</UserControl>
