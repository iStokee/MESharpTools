<UserControl
    x:Class="MESharp.Views.VerificationDeskView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
    xmlns:vm="clr-namespace:MESharp.ViewModels"
    mc:Ignorable="d"
    d:DataContext="{d:DesignInstance Type=vm:VerificationDeskViewModel}"
    d:DesignHeight="760"
    d:DesignWidth="1100">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <Style x:Key="Card" TargetType="Border" BasedOn="{StaticResource Hub.Card}" />
        <Style x:Key="HintText" TargetType="TextBlock" BasedOn="{StaticResource Hub.HintText}" />

        <!--  Status dot colour by task lifecycle bucket (VerificationTaskRow.StateDot)  -->
        <Style x:Key="TaskDot" TargetType="Ellipse">
            <Setter Property="Width" Value="11" />
            <Setter Property="Height" Value="11" />
            <Setter Property="Margin" Value="0,3,8,0" />
            <Setter Property="VerticalAlignment" Value="Top" />
            <Setter Property="Fill" Value="#9E9E9E" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding StateDot}" Value="ok">
                    <Setter Property="Fill" Value="#4CAF50" />
                </DataTrigger>
                <DataTrigger Binding="{Binding StateDot}" Value="warn">
                    <Setter Property="Fill" Value="#FFC107" />
                </DataTrigger>
                <DataTrigger Binding="{Binding StateDot}" Value="busy">
                    <Setter Property="Fill" Value="#42A5F5" />
                </DataTrigger>
                <DataTrigger Binding="{Binding StateDot}" Value="open">
                    <Setter Property="Fill" Value="#9E9E9E" />
                </DataTrigger>
                <DataTrigger Binding="{Binding StateDot}" Value="off">
                    <Setter Property="Fill" Value="#5A5A5A" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!--  Small pill for the signal-type / tier chips  -->
        <Style x:Key="Chip" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource App.BackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource App.BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="3" />
            <Setter Property="Padding" Value="6,1" />
            <Setter Property="Margin" Value="0,0,6,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
    </UserControl.Resources>

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  ── Header: title + counts + capture toggle ──────────────────────────  -->
        <Border Grid.Row="0" Style="{StaticResource Card}">
            <DockPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                    <CheckBox VerticalAlignment="Center" Margin="0,0,12,0"
                              IsChecked="{Binding CaptureEnabled}"
                              Content="Passive capture"
                              ToolTip="When on, walking past seeded tiles / interacting with shortcuts auto-resolves tier-1 tasks." />
                    <Button Command="{Binding SyncCommand}" Content="Sync nav tasks" Padding="12,5" Margin="0,0,6,0"
                            ToolTip="Scan the nav graph and create tasks for unconfirmed seed data (idempotent)." />
                    <Button Command="{Binding RefreshCommand}" Content="Refresh" Padding="12,5" />
                </StackPanel>
                <StackPanel>
                    <TextBlock Style="{StaticResource Hub.PageTitle}" Text="Verify — Service Desk" />
                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                        <TextBlock Style="{StaticResource HintText}" Text="{Binding OpenCount, StringFormat='Open: {0}'}" Margin="0,0,12,0" />
                        <TextBlock Style="{StaticResource HintText}" Text="{Binding StagedCount, StringFormat='Staged: {0}'}" Margin="0,0,12,0" />
                        <TextBlock Style="{StaticResource HintText}" Text="{Binding ResolvedCount, StringFormat='Resolved: {0}'}" Margin="0,0,12,0" />
                        <TextBlock Style="{StaticResource HintText}" Text="{Binding AvgConfidence, StringFormat='Avg confidence: {0}%'}" />
                    </StackPanel>
                </StackPanel>
            </DockPanel>
        </Border>

        <!--  ── Filters ───────────────────────────────────────────────────────────  -->
        <Border Grid.Row="1" Style="{StaticResource Card}">
            <StackPanel Orientation="Horizontal">
                <TextBlock VerticalAlignment="Center" Style="{StaticResource HintText}" Text="State" Margin="0,0,6,0" />
                <ComboBox Width="120" Margin="0,0,16,0" VerticalAlignment="Center"
                          ItemsSource="{Binding StateFilterOptions}" SelectedItem="{Binding StateFilter}" />
                <TextBlock VerticalAlignment="Center" Style="{StaticResource HintText}" Text="Signal" Margin="0,0,6,0" />
                <ComboBox Width="150" Margin="0,0,16,0" VerticalAlignment="Center"
                          ItemsSource="{Binding SignalFilterOptions}" SelectedItem="{Binding SignalFilter}" />
                <CheckBox VerticalAlignment="Center" Content="Near me (sort by distance)" IsChecked="{Binding NearMeOnly}" />
            </StackPanel>
        </Border>

        <!--  ── Master / detail ─────────────────────────────────────────────────  -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.3*" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>

            <!--  Ticket list  -->
            <Border Grid.Column="0" Style="{StaticResource Card}">
                <ListBox ItemsSource="{Binding Tasks}" SelectedItem="{Binding Selected}"
                         HorizontalContentAlignment="Stretch"
                         Background="Transparent" BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,0,6" Padding="10"
                                    Background="{DynamicResource App.BackgroundBrush}"
                                    BorderBrush="{DynamicResource App.BorderBrush}"
                                    BorderThickness="1" CornerRadius="6">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Ellipse Grid.Column="0" Style="{StaticResource TaskDot}" />
                                    <StackPanel Grid.Column="1">
                                        <TextBlock FontWeight="SemiBold" Text="{Binding Title}" TextWrapping="Wrap" />
                                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                            <Border Style="{StaticResource Chip}">
                                                <TextBlock FontSize="10" Text="{Binding SignalType}" />
                                            </Border>
                                            <Border Style="{StaticResource Chip}">
                                                <TextBlock FontSize="10" Text="{Binding Tier}" />
                                            </Border>
                                            <Border Style="{StaticResource Chip}">
                                                <TextBlock FontSize="10" Text="{Binding State}" />
                                            </Border>
                                            <TextBlock FontSize="10" VerticalAlignment="Center"
                                                       Style="{StaticResource HintText}"
                                                       Text="{Binding DistanceText}" />
                                        </StackPanel>
                                    </StackPanel>
                                    <TextBlock Grid.Column="2" VerticalAlignment="Top"
                                               Style="{StaticResource HintText}"
                                               Text="{Binding Confidence, StringFormat='{}{0}%'}" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>

            <!--  Detail / actions  -->
            <Border Grid.Column="2" Style="{StaticResource Card}">
                <Grid>
                    <TextBlock Style="{StaticResource HintText}" TextWrapping="Wrap"
                               Text="Select a ticket to see details and confirm it."
                               Visibility="{Binding HasNoSelection, Converter={StaticResource BoolToVis}}" />
                    <StackPanel Visibility="{Binding HasSelection, Converter={StaticResource BoolToVis}}">
                        <DockPanel>
                            <Button DockPanel.Dock="Right" Padding="6,2"
                                    Command="{Binding HelpCommand}" CommandParameter="{Binding Selected}"
                                    ToolTip="How to confirm this kind of task">
                                <iconPacks:PackIconMaterial Width="14" Height="14" Kind="HelpCircleOutline" />
                            </Button>
                            <TextBlock Style="{StaticResource Hub.SectionHeader}" Text="{Binding Selected.Title}" TextWrapping="Wrap" />
                        </DockPanel>

                        <TextBlock Margin="0,6,0,0" Style="{StaticResource HintText}" Text="{Binding Selected.Body}" TextWrapping="Wrap" />

                        <TextBlock Margin="0,10,0,0" Style="{StaticResource HintText}" Text="Location" />
                        <DockPanel Margin="0,2,0,0">
                            <Button DockPanel.Dock="Right" Padding="8,3" Content="Show on map"
                                    Command="{Binding ShowOnMapCommand}" CommandParameter="{Binding Selected}" />
                            <TextBlock VerticalAlignment="Center" TextWrapping="Wrap" Text="{Binding Selected.AnchorText}" />
                        </DockPanel>

                        <TextBlock Margin="0,10,0,0" Style="{StaticResource HintText}"
                                   Text="{Binding Selected.EvidenceCount, StringFormat='Evidence captured: {0}'}" />

                        <!--  Closing notes: durable human insight (how the data is used / links to other tasks). Never purged.  -->
                        <TextBlock Margin="0,10,0,2" Style="{StaticResource HintText}" Text="Closing notes" />
                        <TextBox MinHeight="64" MaxHeight="140" AcceptsReturn="True" TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 Text="{Binding Selected.ClosingNotes, UpdateSourceTrigger=PropertyChanged}"
                                 ToolTip="How you think this captured data can be used, or how it links to other tasks." />
                        <Button HorizontalAlignment="Right" Margin="0,4,0,0" Padding="10,3" Content="Save notes"
                                Command="{Binding SaveNotesCommand}" CommandParameter="{Binding Selected}" />

                        <!--  Tier-2 staged diff preview  -->
                        <TextBox Margin="0,8,0,0" MinHeight="60" MaxHeight="120"
                                 IsReadOnly="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                                 Text="{Binding Selected.ProposedDiff, Mode=OneWay}"
                                 Visibility="{Binding Selected.IsStaged, Converter={StaticResource BoolToVis}}" />

                        <!--  Action row  -->
                        <UniformGrid Columns="1" Margin="0,12,0,0">
                            <Button Margin="0,0,0,6" Padding="12,6" Content="Confirm (capture + resolve)"
                                    Command="{Binding ConfirmCommand}" CommandParameter="{Binding Selected}"
                                    ToolTip="Capture the live signal for this task and resolve it (tier-1)." />
                            <Button Margin="0,0,0,6" Padding="12,6" Content="Capture full pack (live)"
                                    Command="{Binding CapturePackCommand}" CommandParameter="{Binding Selected}"
                                    ToolTip="Attach a full live CapturePack (nearby objects/NPCs/clicks/collision) as evidence — works on any task." />
                            <Button Margin="0,0,0,6" Padding="12,6" Content="Approve staged diff"
                                    Command="{Binding ApproveCommand}" CommandParameter="{Binding Selected}"
                                    Visibility="{Binding Selected.IsStaged, Converter={StaticResource BoolToVis}}" />
                            <Button Margin="0,0,0,6" Padding="12,6" Content="Flag for code (no auto-write)"
                                    Command="{Binding FlagCommand}" CommandParameter="{Binding Selected}" />
                            <Button Padding="12,6" Content="Close (purge evidence)"
                                    Command="{Binding CloseCommand}" CommandParameter="{Binding Selected}" />
                        </UniformGrid>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!--  ── Status line ───────────────────────────────────────────────────────  -->
        <Border Grid.Row="3" Style="{StaticResource Card}" Margin="0,8,0,0">
            <TextBlock Style="{StaticResource HintText}" Text="{Binding Status}" TextWrapping="Wrap" />
        </Border>
    </Grid>
</UserControl>
