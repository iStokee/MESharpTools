<UserControl
    x:Class="MESharp.Views.WebwalkGraphView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:MESharp.Views.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:MESharp.ViewModels"
    mc:Ignorable="d"
    d:DataContext="{d:DesignInstance Type=vm:WebwalkGraphViewModel}"
    d:DesignHeight="860"
    d:DesignWidth="1200">

    <UserControl.Resources>
        <!-- Local aliases kept for existing usages; values come from Themes/NavHubResources.xaml -->
        <Style x:Key="Card" TargetType="Border" BasedOn="{StaticResource Hub.Card}" />
        <Style x:Key="SectionHeader" TargetType="TextBlock" BasedOn="{StaticResource Hub.SectionHeader}" />
        <Style x:Key="HintText" TargetType="TextBlock" BasedOn="{StaticResource Hub.HintText}" />
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Width" Value="90" />
        </Style>
        <!-- Compact action buttons: the hub command buttons are too wide for dense editor rows -->
        <Style x:Key="ToolButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="Margin" Value="0,0,6,4" />
            <Setter Property="FontSize" Value="12" />
        </Style>
        <Style x:Key="ToolButtonAccent" TargetType="Button" BasedOn="{StaticResource AccentButton}">
            <Setter Property="Padding" Value="12,5" />
            <Setter Property="Margin" Value="0,0,6,4" />
            <Setter Property="FontSize" Value="12" />
        </Style>
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="{DynamicResource App.BackgroundBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource App.ForegroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource App.BorderBrush}" />
            <Setter Property="RowBackground" Value="{DynamicResource App.BackgroundBrush}" />
            <Setter Property="AlternatingRowBackground" Value="{DynamicResource App.CardBrush}" />
            <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource App.BorderBrush}" />
            <Setter Property="VerticalGridLinesBrush" Value="{DynamicResource App.BorderBrush}" />
        </Style>
        <Style TargetType="DataGridCell">
            <Setter Property="Foreground" Value="{DynamicResource App.ForegroundBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource App.ForegroundBrush}" />
                    <Setter Property="Background" Value="{DynamicResource PrimarySoftBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="DataGridRow">
            <Setter Property="Foreground" Value="{DynamicResource App.ForegroundBrush}" />
            <Setter Property="Background" Value="{DynamicResource App.BackgroundBrush}" />
        </Style>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <!-- Edge editor shows only the fields relevant to the selected Kind.
             Blank kind is treated as route at save time, so route fields show then too. -->
        <Style x:Key="RouteOnlyLabel" TargetType="TextBlock" BasedOn="{StaticResource FieldLabel}">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding NewEdgeKind}" Value="route">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
                <DataTrigger Binding="{Binding NewEdgeKind}" Value="">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="RouteOnlyField" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding NewEdgeKind}" Value="route">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
                <DataTrigger Binding="{Binding NewEdgeKind}" Value="">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="RouteOnlyCombo" TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding NewEdgeKind}" Value="route">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
                <DataTrigger Binding="{Binding NewEdgeKind}" Value="">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="LodestoneOnlyLabel" TargetType="TextBlock" BasedOn="{StaticResource FieldLabel}">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding NewEdgeKind}" Value="lodestone">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="LodestoneOnlyCombo" TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding NewEdgeKind}" Value="lodestone">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="ShortcutOnlyLabel" TargetType="TextBlock" BasedOn="{StaticResource FieldLabel}">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding NewEdgeKind}" Value="shortcut">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="ShortcutOnlyPanel" TargetType="Grid">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding NewEdgeKind}" Value="shortcut">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ── Header (same control as Travel/Routes) ─────────────────────────── -->
        <controls:SectionHeader
            Grid.Row="0"
            Margin="8,8,8,8"
            Title="Graph Data"
            Description="Field-level editor for the webwalk graph: nodes, edges, and the routes they execute. The Map offers the same authoring by clicking the world."
            IconKind="Graph"
            ShowExpandCollapseAll="False"
            ShowHelp="True"
            HelpCommand="{Binding ShowHelpCommand}"
            HelpToolTip="What are nodes, edges, requirements? What does each panel do?">
            <controls:SectionHeader.RightContent>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock VerticalAlignment="Center" Margin="0,0,12,0" FontFamily="Consolas"
                               Foreground="{DynamicResource App.SubtleForegroundBrush}">
                        <Run Text="Tile: " /><Run Text="{Binding CurrentTile, Mode=OneWay}" FontWeight="SemiBold" />
                    </TextBlock>
                    <Button Command="{Binding RefreshGraphCommand}" Style="{StaticResource SecondaryCommandButton}"
                            ToolTip="Reload webwalk_graph.json and routes.json from disk">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Width="16" Height="16" Margin="0,0,6,0" Kind="Refresh"
                                                        Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                            <TextBlock Text="Refresh" />
                        </StackPanel>
                    </Button>
                    <Button Margin="8,0,0,0" Command="{Binding OpenGraphFileCommand}" Style="{StaticResource SecondaryCommandButton}"
                            ToolTip="Open webwalk_graph.json for hand edits">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Width="16" Height="16" Margin="0,0,6,0" Kind="FileDocumentOutline"
                                                        Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                            <TextBlock Text="Open File" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </controls:SectionHeader.RightContent>
        </controls:SectionHeader>

        <!-- ── Main three-column layout ───────────────────────────────────────── -->
        <Grid Grid.Row="1" Margin="8,0,8,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" MinWidth="280" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="2*" MinWidth="220" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="3*" MinWidth="200" />
            </Grid.ColumnDefinitions>

            <!-- ── Col 0: tabbed editor (Recorder / Node / Edge) ─────────────── -->
            <Border Grid.Column="0" Style="{StaticResource Card}" Padding="6">
                <TabControl Background="Transparent" BorderThickness="0" Padding="4,8,4,4">

                    <!-- Recorder -->
                    <TabItem>
                        <TabItem.Header>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Recorder" />
                                <TextBlock Text=" ●" Foreground="#FF4444" FontWeight="Bold"
                                           Visibility="{Binding IsRecording, Converter={StaticResource BoolToVis}}" />
                            </StackPanel>
                        </TabItem.Header>
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <StackPanel Margin="4">
                                <TextBlock Style="{StaticResource HintText}" Margin="0,0,0,8"
                                           Text="Walk in-game while the recorder samples your trail, then save it as a route — optionally wired straight into an edge between the From/To nodes set in the Edge tab." />

                                <Grid Margin="0,0,0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="90" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Route name" Style="{StaticResource FieldLabel}" />
                                    <TextBox Grid.Column="1" Text="{Binding RecordRouteName, UpdateSourceTrigger=PropertyChanged}" />
                                </Grid>

                                <Grid Margin="0,0,0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="90" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="90" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Interval (s)" Style="{StaticResource FieldLabel}" />
                                    <TextBox Grid.Column="1" Text="{Binding RecordIntervalSeconds}" />
                                    <TextBlock Grid.Column="2" Text="Min dist" Style="{StaticResource FieldLabel}" Margin="6,0,0,0" />
                                    <TextBox Grid.Column="3" Text="{Binding MinWaypointDistance}" />
                                </Grid>

                                <WrapPanel Margin="0,6,0,6">
                                    <Button Content="▶ Start" Command="{Binding StartRecordingCommand}" Style="{StaticResource ToolButtonAccent}" />
                                    <Button Content="■ Stop" Command="{Binding StopRecordingCommand}" Style="{StaticResource ToolButton}" />
                                    <Button Content="Clear" Command="{Binding ClearRecordingCommand}" Style="{StaticResource ToolButton}" />
                                </WrapPanel>
                                <WrapPanel Margin="0,0,0,6">
                                    <Button Content="Save Route" Command="{Binding SaveRecordingAsRouteCommand}" Style="{StaticResource ToolButton}" />
                                    <Button Content="Save Route + Edge" Command="{Binding SaveRecordingAndEdgeCommand}" Style="{StaticResource ToolButton}"
                                            ToolTip="Save the trail as a route and wire it between the From/To nodes set in the Edge tab." />
                                    <Button Content="Segment &amp; Save" Command="{Binding SegmentRecordingCommand}" Style="{StaticResource ToolButton}"
                                            ToolTip="Auto-split the raw trail at teleports and dwell stops, saving each walked stretch as its own route (name_seg1..N). Teleport jumps are logged as edge candidates." />
                                </WrapPanel>

                                <TextBlock Text="Recorded tiles (newest first):" Style="{StaticResource HintText}" Margin="0,0,0,3" />
                                <TextBlock Text="{Binding RecordingSummary}" Style="{StaticResource HintText}" Margin="0,0,0,4" />
                                <ListBox ItemsSource="{Binding RecordedTiles}" MaxHeight="160" FontSize="11"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled" />
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <!-- Node editor -->
                    <TabItem Header="Node">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <StackPanel Margin="4">
                                <TextBlock Style="{StaticResource HintText}" Margin="0,0,0,8"
                                           Text="Create or update a node — a named place the planner can route to. Select a row in the Nodes table and 'Load Selected' to edit it; all fields round-trip." />

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="90" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Node ID" Style="{StaticResource FieldLabel}" Margin="0,0,0,4" />
                                    <TextBox   Grid.Row="0" Grid.Column="1" Text="{Binding NewNodeId, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,4" />

                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Name" Style="{StaticResource FieldLabel}" Margin="0,0,0,4" />
                                    <TextBox   Grid.Row="1" Grid.Column="1" Text="{Binding NewNodeName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,4" />

                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="X / Y / Z" Style="{StaticResource FieldLabel}" Margin="0,0,0,4" />
                                    <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,4">
                                        <TextBox Text="{Binding NewNodeX}" Width="70" Margin="0,0,4,0" />
                                        <TextBox Text="{Binding NewNodeY}" Width="70" Margin="0,0,4,0" />
                                        <TextBox Text="{Binding NewNodeZ}" Width="50" Margin="0,0,4,0" />
                                        <Button Content="Use Current Tile" Command="{Binding UseCurrentTileForNodeCommand}" Style="{StaticResource ToolButton}" Margin="0" />
                                    </StackPanel>

                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Tags" Style="{StaticResource FieldLabel}" Margin="0,0,0,4" />
                                    <TextBox   Grid.Row="3" Grid.Column="1" Text="{Binding NewNodeTags, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,4"
                                               ToolTip="Comma-separated, e.g.: bank, lumbridge, safe" />

                                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Notes" Style="{StaticResource FieldLabel}" Margin="0,0,0,4" />
                                    <TextBox   Grid.Row="4" Grid.Column="1" Text="{Binding NewNodeNotes, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,4"
                                               ToolTip="Optional free-form notes, kept in the graph file." />
                                </Grid>

                                <CheckBox Content="Enabled" IsChecked="{Binding NewNodeEnabled}" Margin="0,4,0,8"
                                          ToolTip="Disabled nodes are ignored by the pathfinder. Disable (don't delete) seeded nodes — deleted seeds reappear on reload." />

                                <Button Content="Save Node" Command="{Binding SaveNodeCommand}" Style="{StaticResource ToolButtonAccent}" HorizontalAlignment="Left" />

                                <Separator Margin="0,8,0,8" />
                                <TextBlock Text="Selected node (Nodes table)" Style="{StaticResource SectionHeader}" />
                                <WrapPanel>
                                    <Button Content="Load Selected" Command="{Binding LoadSelectedNodeCommand}" Style="{StaticResource ToolButton}" />
                                    <Button Content="Use as From" Command="{Binding UseSelectedNodeAsFromCommand}" Style="{StaticResource ToolButton}"
                                            ToolTip="Set the Edge tab's From node to this node" />
                                    <Button Content="Use as To" Command="{Binding UseSelectedNodeAsToCommand}" Style="{StaticResource ToolButton}"
                                            ToolTip="Set the Edge tab's To node to this node" />
                                    <Button Content="Show on Map" Command="{Binding ShowNodeOnMapCommand}" Style="{StaticResource ToolButton}"
                                            ToolTip="Switch to the Map section centered on this node" />
                                    <Button Content="Delete Node" Command="{Binding DeleteSelectedNodeCommand}" Style="{StaticResource ToolButton}" />
                                </WrapPanel>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <!-- Edge editor -->
                    <TabItem Header="Edge">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <StackPanel Margin="4">
                                <TextBlock Style="{StaticResource HintText}" Margin="0,0,0,8"
                                           Text="Create or update an edge — a way to travel between two nodes. Pick the Kind first; only the fields that kind needs are shown." />

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="90" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Edge ID" Style="{StaticResource FieldLabel}" Margin="0,0,0,4" />
                                    <TextBox   Grid.Row="0" Grid.Column="1" Text="{Binding NewEdgeId, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,4" />

                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="From node" Style="{StaticResource FieldLabel}" Margin="0,0,0,4" />
                                    <ComboBox  Grid.Row="1" Grid.Column="1" IsEditable="True" Margin="0,0,0,4"
                                               ItemsSource="{Binding NodeIdOptions}"
                                               Text="{Binding NewEdgeFrom, UpdateSourceTrigger=PropertyChanged}"
                                               ToolTip="Pick a node, or type one. * = global teleport (available from anywhere)." />

                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="To node" Style="{StaticResource FieldLabel}" Margin="0,0,0,4" />
                                    <ComboBox  Grid.Row="2" Grid.Column="1" IsEditable="True" Margin="0,0,0,4"
                                               ItemsSource="{Binding NodeIdOptions}"
                                               Text="{Binding NewEdgeTo, UpdateSourceTrigger=PropertyChanged}"
                                               ToolTip="Destination node id." />

                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Kind" Style="{StaticResource FieldLabel}" Margin="0,0,0,4" />
                                    <ComboBox  Grid.Row="3" Grid.Column="1" Text="{Binding NewEdgeKind}" IsEditable="True" Margin="0,0,0,4"
                                               ToolTip="route: walks a named route. lodestone: teleports to a lodestone network destination. shortcut: clicks a world object (agility shortcuts, tunnels) — gate with a skill requirement. Other travel networks are schema-reserved but not executable yet.">
                                        <ComboBoxItem Content="route" />
                                        <ComboBoxItem Content="lodestone" />
                                        <ComboBoxItem Content="shortcut" />
                                        <ComboBoxItem Content="teleport (deferred)" IsEnabled="False" />
                                        <ComboBoxItem Content="fairy_ring (deferred)" IsEnabled="False" />
                                        <ComboBoxItem Content="spirit_tree (deferred)" IsEnabled="False" />
                                    </ComboBox>

                                    <!-- Route fields (visible when kind=route) -->
                                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Route ID" Style="{StaticResource RouteOnlyLabel}" Margin="0,0,0,4" />
                                    <TextBox   Grid.Row="4" Grid.Column="1" Style="{StaticResource RouteOnlyField}"
                                               Text="{Binding NewEdgeRouteId, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,4"
                                               ToolTip="Required when Kind=route. Auto-filled after saving a recording." />

                                    <TextBlock Grid.Row="5" Grid.Column="0" Text="Route pick" Style="{StaticResource RouteOnlyLabel}" Margin="0,0,0,4" />
                                    <ComboBox  Grid.Row="5" Grid.Column="1" Style="{StaticResource RouteOnlyCombo}"
                                               ItemsSource="{Binding Routes}"
                                               SelectedItem="{Binding SelectedRoute}"
                                               DisplayMemberPath="Id"
                                               Margin="0,0,0,4"
                                               ToolTip="Pick a known route, then 'Use Route' to apply it to the edge." />

                                    <!-- Lodestone field (visible when kind=lodestone) -->
                                    <TextBlock Grid.Row="6" Grid.Column="0" Text="Lodestone" Style="{StaticResource LodestoneOnlyLabel}" Margin="0,0,0,4" />
                                    <ComboBox  Grid.Row="6" Grid.Column="1" Style="{StaticResource LodestoneOnlyCombo}"
                                               ItemsSource="{Binding LodestoneNames}"
                                               SelectedItem="{Binding NewEdgeLodestoneDestination}"
                                               IsEditable="True"
                                               Text="{Binding NewEdgeLodestoneDestination, UpdateSourceTrigger=PropertyChanged}"
                                               Margin="0,0,0,4"
                                               ToolTip="Required when Kind=lodestone. Pick the destination from the lodestone network." />

                                    <!-- Shortcut fields (visible when kind=shortcut) -->
                                    <TextBlock Grid.Row="7" Grid.Column="0" Text="Object" Style="{StaticResource ShortcutOnlyLabel}" Margin="0,0,0,4" />
                                    <Grid Grid.Row="7" Grid.Column="1" Style="{StaticResource ShortcutOnlyPanel}" Margin="0,0,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="44" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox Grid.Column="0" Text="{Binding NewEdgeObjectName, UpdateSourceTrigger=PropertyChanged}"
                                                 ToolTip="Required when Kind=shortcut. The world object to click (e.g. 'Underwall tunnel', 'Crumbling wall')." />
                                        <TextBlock Grid.Column="1" Text="act" VerticalAlignment="Center" Margin="6,0,4,0" Style="{StaticResource FieldLabel}" Width="Auto" />
                                        <TextBox Grid.Column="2" Text="{Binding NewEdgeActionIndex}"
                                                 ToolTip="DoAction action index for the object interaction (default 1)." />
                                    </Grid>

                                    <TextBlock Grid.Row="8" Grid.Column="0" Text="Cost (ms)" Style="{StaticResource FieldLabel}" Margin="0,0,0,4" />
                                    <TextBox   Grid.Row="8" Grid.Column="1" Text="{Binding NewEdgeCostMs}" Margin="0,0,0,4" />

                                    <TextBlock Grid.Row="9" Grid.Column="0" Text="Danger lvl" Style="{StaticResource FieldLabel}" Margin="0,0,0,4" />
                                    <TextBox   Grid.Row="9" Grid.Column="1" Text="{Binding NewEdgeDangerLevel}" Margin="0,0,0,4"
                                               ToolTip="0=safe, 1=PVP risk, 2+=wilderness" />

                                    <TextBlock Grid.Row="10" Grid.Column="0" Text="Notes" Style="{StaticResource FieldLabel}" Margin="0,0,0,4" />
                                    <TextBox   Grid.Row="10" Grid.Column="1" Text="{Binding NewEdgeNotes, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,4"
                                               ToolTip="Optional free-form notes, kept in the graph file." />
                                </Grid>

                                <StackPanel Orientation="Horizontal" Margin="0,2,0,4">
                                    <CheckBox Content="Enabled" IsChecked="{Binding NewEdgeEnabled}" Margin="0,0,14,0"
                                              ToolTip="Disabled edges are skipped by the pathfinder but stay in the file (survives seed reloads)." />
                                    <CheckBox Content="Reversible" IsChecked="{Binding NewEdgeReversible}"
                                              ToolTip="Route edges only: lets the pathfinder run the route backwards. Rejected for routes containing transition waypoints.">
                                        <CheckBox.Style>
                                            <Style TargetType="CheckBox" BasedOn="{StaticResource {x:Type CheckBox}}">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding NewEdgeKind}" Value="route">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding NewEdgeKind}" Value="">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </CheckBox.Style>
                                    </CheckBox>
                                </StackPanel>

                                <Expander Header="Requirements (JSON)" IsExpanded="False" Margin="0,0,0,4">
                                    <StackPanel Margin="0,4,0,0">
                                        <TextBlock Style="{StaticResource HintText}"
                                                   Text='Plan-time gates for this edge. Types: item, skill, quest, unlock, spellbook. Example: [{"type":"skill","name":"Agility","level":21}]' />
                                        <TextBox MinHeight="46" Margin="0,4,0,0" AcceptsReturn="True" TextWrapping="Wrap" FontFamily="Consolas" FontSize="11"
                                                 VerticalScrollBarVisibility="Auto"
                                                 Text="{Binding NewEdgeRequirementsJson, UpdateSourceTrigger=PropertyChanged}"
                                                 ToolTip="Leave empty for no requirements. Invalid JSON blocks the save with the parse error." />
                                    </StackPanel>
                                </Expander>

                                <WrapPanel Margin="0,4,0,0">
                                    <Button Content="Save Edge" Command="{Binding SaveEdgeCommand}" Style="{StaticResource ToolButtonAccent}" />
                                    <Button Content="Use Route" Command="{Binding UseSelectedRouteForEdgeCommand}" Style="{StaticResource ToolButton}"
                                            ToolTip="Apply the route picked above (or selected in the Routes table) to this edge" />
                                    <Button Content="Validate Route" Command="{Binding ValidateSelectedRouteCommand}" Style="{StaticResource ToolButton}" />
                                </WrapPanel>

                                <Separator Margin="0,8,0,8" />
                                <TextBlock Text="Selected edge (Edges table)" Style="{StaticResource SectionHeader}" />
                                <WrapPanel>
                                    <Button Content="Load Edge" Command="{Binding LoadSelectedEdgeCommand}" Style="{StaticResource ToolButton}" />
                                    <Button Content="Delete Edge" Command="{Binding DeleteSelectedEdgeCommand}" Style="{StaticResource ToolButton}" />
                                </WrapPanel>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>
                </TabControl>
            </Border>

            <!-- ── Splitter ────────────────────────────────────────────────────── -->
            <GridSplitter Grid.Column="1" Width="8" VerticalAlignment="Stretch" HorizontalAlignment="Center" Background="Transparent" />

            <!-- ── Col 2: Node list + Route list + Edge list ─────────────────── -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="150" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Nodes -->
                <Border Grid.Row="0" Style="{StaticResource Card}" Margin="0,0,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,6">
                            <iconPacks:PackIconMaterial Kind="MapMarkerRadius" Width="14" Height="14" Margin="0,0,6,0"
                                                        VerticalAlignment="Center" Foreground="{DynamicResource PrimaryBrush}" />
                            <TextBlock Style="{StaticResource SectionHeader}" Margin="0">
                                <Run Text="Nodes (" /><Run Text="{Binding Nodes.Count, Mode=OneWay}" /><Run Text=")" />
                            </TextBlock>
                        </StackPanel>
                        <DataGrid Grid.Row="1" ItemsSource="{Binding Nodes}" SelectedItem="{Binding SelectedNode}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True" CanUserAddRows="False" FontSize="11"
                                  VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="110" />
                                <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="100" />
                                <DataGridTextColumn Header="X" Binding="{Binding X}" Width="55" />
                                <DataGridTextColumn Header="Y" Binding="{Binding Y}" Width="55" />
                                <DataGridTextColumn Header="Z" Binding="{Binding Z}" Width="40" />
                                <DataGridCheckBoxColumn Header="On" Binding="{Binding Enabled}" Width="35" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>

                <GridSplitter Grid.Row="1" Height="8" HorizontalAlignment="Stretch" Background="Transparent" />

                <!-- Routes -->
                <Border Grid.Row="2" Style="{StaticResource Card}" Margin="0,0,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,6">
                            <iconPacks:PackIconMaterial Kind="ChartTimelineVariant" Width="14" Height="14" Margin="0,0,6,0"
                                                        VerticalAlignment="Center" Foreground="{DynamicResource PrimaryBrush}" />
                            <TextBlock Style="{StaticResource SectionHeader}" Margin="0">
                                <Run Text="Routes (" /><Run Text="{Binding Routes.Count, Mode=OneWay}" /><Run Text=")" />
                            </TextBlock>
                        </StackPanel>
                        <DataGrid Grid.Row="1" ItemsSource="{Binding Routes}" SelectedItem="{Binding SelectedRoute}"
                                  AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False" FontSize="11"
                                  VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="160" />
                                <DataGridTextColumn Header="Cat" Binding="{Binding Category}" Width="70" />
                                <DataGridTextColumn Header="WP" Binding="{Binding WaypointCount}" Width="42" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>

                <GridSplitter Grid.Row="3" Height="8" HorizontalAlignment="Stretch" Background="Transparent" />

                <!-- Edges -->
                <Border Grid.Row="4" Style="{StaticResource Card}" Margin="0,0,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,6">
                            <iconPacks:PackIconMaterial Kind="VectorLine" Width="14" Height="14" Margin="0,0,6,0"
                                                        VerticalAlignment="Center" Foreground="{DynamicResource PrimaryBrush}" />
                            <TextBlock Style="{StaticResource SectionHeader}" Margin="0">
                                <Run Text="Edges (" /><Run Text="{Binding Edges.Count, Mode=OneWay}" /><Run Text=")" />
                            </TextBlock>
                        </StackPanel>
                        <DataGrid Grid.Row="1" ItemsSource="{Binding Edges}" SelectedItem="{Binding SelectedEdge}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True" CanUserAddRows="False" FontSize="11"
                                  VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow">
                                    <Setter Property="Foreground" Value="{DynamicResource App.ForegroundBrush}" />
                                    <Setter Property="Background" Value="{DynamicResource App.BackgroundBrush}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasBrokenRef}" Value="True">
                                            <Setter Property="Background" Value="#40FF4444" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.RowStyle>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="100" />
                                <DataGridTextColumn Header="From" Binding="{Binding From}" Width="90" />
                                <DataGridTextColumn Header="To" Binding="{Binding To}" Width="90" />
                                <DataGridTextColumn Header="Kind" Binding="{Binding Kind}" Width="70" />
                                <DataGridTextColumn Header="Route" Binding="{Binding RouteId}" Width="80" />
                                <DataGridTextColumn Header="Cost" Binding="{Binding CostMs}" Width="55" />
                                <DataGridTextColumn Header="Obs" Binding="{Binding ObservedCostMs}" Width="55" />
                                <DataGridCheckBoxColumn Header="Rev" Binding="{Binding Reversible}" Width="38" />
                                <DataGridTextColumn Header="Src" Binding="{Binding Source}" Width="55" />
                                <DataGridTextColumn Header="Issue" Binding="{Binding IssueSummary}" Width="120" />
                                <DataGridCheckBoxColumn Header="On" Binding="{Binding Enabled}" Width="35" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>
            </Grid>

            <!-- ── Splitter ────────────────────────────────────────────────────── -->
            <GridSplitter Grid.Column="3" Width="8" VerticalAlignment="Stretch" HorizontalAlignment="Center" Background="Transparent" />

            <!-- ── Col 4: Path preview + Validation + Activity log ─────────────── -->
            <Grid Grid.Column="4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="2*" />
                </Grid.RowDefinitions>

                <!-- Path preview -->
                <Border Grid.Row="0" Style="{StaticResource Card}" Margin="0,0,0,0">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <iconPacks:PackIconMaterial Kind="RoutesClock" Width="14" Height="14" Margin="0,0,6,0"
                                                        VerticalAlignment="Center" Foreground="{DynamicResource PrimaryBrush}" />
                            <TextBlock Text="Path Preview" Style="{StaticResource SectionHeader}" Margin="0" />
                        </StackPanel>
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="50" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="30" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="From" VerticalAlignment="Center" />
                            <ComboBox Grid.Column="1" IsEditable="True" Margin="4,0,6,0"
                                      ItemsSource="{Binding NodeIdOptions}"
                                      Text="{Binding PathFromNodeId, UpdateSourceTrigger=PropertyChanged}">
                                <ComboBox.InputBindings>
                                    <KeyBinding Key="Return" Command="{Binding PreviewPathCommand}" />
                                </ComboBox.InputBindings>
                            </ComboBox>
                            <TextBlock Grid.Column="2" Text="To" VerticalAlignment="Center" />
                            <ComboBox Grid.Column="3" IsEditable="True" Margin="4,0,6,0"
                                      ItemsSource="{Binding NodeIdOptions}"
                                      Text="{Binding PathToNodeId, UpdateSourceTrigger=PropertyChanged}">
                                <ComboBox.InputBindings>
                                    <KeyBinding Key="Return" Command="{Binding PreviewPathCommand}" />
                                </ComboBox.InputBindings>
                            </ComboBox>
                            <Button Grid.Column="4" Content="Preview" Command="{Binding PreviewPathCommand}" Style="{StaticResource ToolButton}" Margin="0,0,4,0" />
                            <Button Grid.Column="5" Content="Run" Command="{Binding RunPreviewPathCommand}" Style="{StaticResource ToolButtonAccent}" Margin="0,0,4,0" />
                            <Button Grid.Column="6" Content="Stop" Command="{Binding StopPathCommand}" Style="{StaticResource ToolButton}" Margin="0" />
                        </Grid>
                        <TextBlock Text="{Binding PathPreview}" TextWrapping="Wrap" Style="{StaticResource HintText}" />
                        <TextBlock Text="{Binding PathRunStatus}" TextWrapping="Wrap" Style="{StaticResource HintText}" Margin="0,2,0,0" />
                    </StackPanel>
                </Border>

                <!-- Validation -->
                <Border Grid.Row="1" Style="{StaticResource Card}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,6">
                            <iconPacks:PackIconMaterial Kind="CheckDecagramOutline" Width="14" Height="14" Margin="0,0,6,0"
                                                        VerticalAlignment="Center" Foreground="{DynamicResource PrimaryBrush}" />
                            <TextBlock Text="Validation" Style="{StaticResource SectionHeader}" Margin="0" VerticalAlignment="Center" />
                            <Button Content="Validate" Command="{Binding ValidateGraphCommand}" Style="{StaticResource ToolButton}" Margin="8,0,0,0" />
                            <Button Content="🌍 Coverage Map" Command="{Binding OpenCoverageMapCommand}" Style="{StaticResource ToolButton}" Margin="0,0,0,0"
                                    ToolTip="Open the webwalk graph over the real world map in your browser (served locally with live data)." />
                            <Border Padding="6,2" CornerRadius="4" Background="#40FF4444" Margin="8,0,0,0" VerticalAlignment="Center"
                                    Visibility="{Binding HasValidationErrors, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="ERRORS" FontSize="11" FontWeight="Bold" Foreground="#FF6644" />
                            </Border>
                            <Border Padding="6,2" CornerRadius="4" Background="#40FFAA00" Margin="6,0,0,0" VerticalAlignment="Center"
                                    Visibility="{Binding HasValidationWarnings, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="WARNINGS" FontSize="11" FontWeight="Bold" Foreground="#FFBB44" />
                            </Border>
                        </StackPanel>
                        <ListBox Grid.Row="1" ItemsSource="{Binding ValidationIssues}" FontSize="11"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 VirtualizingPanel.IsVirtualizing="True" />
                    </Grid>
                </Border>

                <GridSplitter Grid.Row="2" Height="8" HorizontalAlignment="Stretch" Background="Transparent" />

                <!-- Activity log -->
                <Border Grid.Row="3" Style="{StaticResource Card}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,6">
                            <iconPacks:PackIconMaterial Kind="FormatListChecks" Width="14" Height="14" Margin="0,0,6,0"
                                                        VerticalAlignment="Center" Foreground="{DynamicResource PrimaryBrush}" />
                            <TextBlock Text="Activity Log" Style="{StaticResource SectionHeader}" Margin="0" />
                        </StackPanel>
                        <ListBox Grid.Row="1" ItemsSource="{Binding ActivityLog}" FontSize="11" FontFamily="Consolas"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 VirtualizingPanel.IsVirtualizing="True" />
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <!-- ── Bottom status bar ──────────────────────────────────────────────── -->
        <Border Grid.Row="2" Style="{StaticResource Card}" Margin="8,4,8,8">
            <DockPanel>
                <iconPacks:PackIconMaterial DockPanel.Dock="Left" Kind="InformationOutline" VerticalAlignment="Center" Margin="0,0,6,0"
                                            Foreground="{DynamicResource App.SubtleForegroundBrush}"
                                            ToolTip="Record a route by walking in-game, then wire it to a route edge. Lodestone edges can be authored here; fairy ring, spirit tree, glider, and generic teleport edges are deferred until execution support exists." />
                <TextBlock VerticalAlignment="Center" FontSize="11" FontFamily="Consolas"
                           Foreground="{DynamicResource App.SubtleForegroundBrush}"
                           Text="{Binding LastStatus}" TextTrimming="CharacterEllipsis" />
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
