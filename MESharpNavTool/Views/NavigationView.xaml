<UserControl
    x:Class="MESharp.Views.NavigationView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:behaviors="clr-namespace:MESharp.Views.Behaviors"
    xmlns:conv="clr-namespace:MESharp.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
    xmlns:controls="clr-namespace:MESharp.Views.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:MESharp.ViewModels"
    d:DataContext="{d:DesignInstance Type=vm:NavigationViewModel}"
    d:DesignHeight="800"
    d:DesignWidth="1100"
    mc:Ignorable="d">

    <UserControl.Resources>
        <ResourceDictionary>
            <conv:BoolToColorConverter x:Key="BoolToColorConverter" />
            <conv:BoolToStringConverter x:Key="BoolToStringConverter" />
            <conv:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />

            <!-- Local aliases kept for existing usages; values come from Themes/NavHubResources.xaml -->
            <Style x:Key="NavigationPanelCard" TargetType="Border" BasedOn="{StaticResource Hub.Card}" />
            <Style x:Key="NavigationSectionTitle" TargetType="TextBlock" BasedOn="{StaticResource Hub.PageTitle}" />
            <Style x:Key="NavigationSubtleText" TargetType="TextBlock" BasedOn="{StaticResource Hub.HintText}" />
            <Style x:Key="NavigationInsetCard" TargetType="Border" BasedOn="{StaticResource Hub.InsetCard}" />
        </ResourceDictionary>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  Header  -->
        <controls:SectionHeader
            Grid.Row="0"
            Margin="0,0,0,10"
            Title="Travel"
            Description="Webwalk travel plus diagnostics for primitive movement, wait, minimap, and teleport API calls. Reusable route authoring lives in Routes."
            IconKind="MapMarkerPath"
            ShowHelp="True"
            HelpCommand="{Binding ShowHelpCommand}"
            HelpToolTip="What does each panel and button here do?">
            <controls:SectionHeader.RightContent>
                <StackPanel
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
                    <TextBlock
                        Margin="0,0,10,0"
                        VerticalAlignment="Center"
                        FontFamily="Consolas"
                        Foreground="{DynamicResource App.SubtleForegroundBrush}"
                        Text="{Binding LastStatus}" />
                    <Button
                        Margin="8,0,0,0"
                        Command="{Binding RefreshCommand}"
                        Style="{StaticResource PrimaryCommandButton}">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial
                                Width="16"
                                Height="16"
                                Margin="0,0,6,0"
                                Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                Kind="Refresh" />
                            <TextBlock Text="Refresh position" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </controls:SectionHeader.RightContent>
        </controls:SectionHeader>

        <!--  Main content  -->
        <Grid
            Grid.Row="1"
            behaviors:GridColumnLayoutBehavior.LayoutKey="navigation-view-columns"
            behaviors:GridColumnLayoutBehavior.ColumnIndexes="0,2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="6" />
                <ColumnDefinition Width="1.1*" />
            </Grid.ColumnDefinitions>

            <StackPanel
                Grid.Column="0"
                Margin="0,0,8,0"
                behaviors:PanelLayoutBehavior.PageKey="navigation-view"
                behaviors:PanelLayoutBehavior.ColumnKey="left">
                <!--  Live status (dockable)  -->
                <Border
                    behaviors:PanelLayoutBehavior.PanelKey="live-status"
                    Style="{StaticResource NavigationPanelCard}">
                    <Expander Header="Live Status" IsExpanded="True">
                        <Grid Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock FontWeight="SemiBold" Text="Tile position" />
                                <TextBlock
                                    Margin="0,4,0,0"
                                    FontFamily="Consolas"
                                    FontSize="13"
                                    Text="{Binding TilePosition}" />
                            </StackPanel>

                            <StackPanel Grid.Column="1">
                                <TextBlock FontWeight="SemiBold" Text="Exact position" />
                                <TextBlock
                                    Margin="0,4,0,0"
                                    FontFamily="Consolas"
                                    FontSize="13"
                                    Text="{Binding ExactPosition}" />
                            </StackPanel>

                            <StackPanel
                                Grid.Column="2"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center"
                                Orientation="Horizontal">
                                <Ellipse
                                    Width="14"
                                    Height="14"
                                    Margin="0,0,6,0"
                                    Fill="{Binding IsMoving, Converter={StaticResource BoolToColorConverter}}" />
                                <TextBlock
                                    VerticalAlignment="Center"
                                    FontWeight="SemiBold"
                                    Text="{Binding IsMoving, Converter={StaticResource BoolToStringConverter}, ConverterParameter='Moving|Idle'}" />
                            </StackPanel>
                        </Grid>
                    </Expander>
                </Border>

                <!--  Walk to tile  -->
                <Border
                    behaviors:PanelLayoutBehavior.PanelKey="walk-to-tile"
                    Style="{StaticResource NavigationPanelCard}">
                    <Expander Header="Tile Movement Probe" IsExpanded="True">
                        <StackPanel Margin="0,10,0,0">
                        <TextBlock
                            Style="{StaticResource NavigationSubtleText}"
                            Text="Use this to test Traversal.WalkTo and raw click dispatch against one tile. Save reusable travel as Webwalking routes instead." />
                        <Grid Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Margin="0,0,0,0">
                                <TextBlock FontWeight="SemiBold" Text="X" />
                                <DockPanel Margin="0,4,0,0">
                                    <StackPanel
                                        Width="28"
                                        DockPanel.Dock="Right"
                                        Orientation="Vertical">
                                        <Button
                                            Height="22"
                                            Padding="0"
                                            Command="{Binding NudgeXPositiveCommand}">
                                            <iconPacks:PackIconMaterial
                                                Width="14"
                                                Height="14"
                                                Kind="ChevronUp" />
                                        </Button>
                                        <Button
                                            Height="22"
                                            Padding="0"
                                            Command="{Binding NudgeXNegativeCommand}">
                                            <iconPacks:PackIconMaterial
                                                Width="14"
                                                Height="14"
                                                Kind="ChevronDown" />
                                        </Button>
                                    </StackPanel>
                                    <TextBox Padding="6" Text="{Binding TargetX, UpdateSourceTrigger=PropertyChanged}" />
                                </DockPanel>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="0,0,10,0">
                                <TextBlock FontWeight="SemiBold" Text="Y" />
                                <DockPanel Margin="0,4,0,0">
                                    <StackPanel
                                        Width="28"
                                        DockPanel.Dock="Right"
                                        Orientation="Vertical">
                                        <Button
                                            Height="22"
                                            Padding="0"
                                            Command="{Binding NudgeYPositiveCommand}">
                                            <iconPacks:PackIconMaterial
                                                Width="14"
                                                Height="14"
                                                Kind="ChevronUp" />
                                        </Button>
                                        <Button
                                            Height="22"
                                            Padding="0"
                                            Command="{Binding NudgeYNegativeCommand}">
                                            <iconPacks:PackIconMaterial
                                                Width="14"
                                                Height="14"
                                                Kind="ChevronDown" />
                                        </Button>
                                    </StackPanel>
                                    <TextBox Padding="6" Text="{Binding TargetY, UpdateSourceTrigger=PropertyChanged}" />
                                </DockPanel>
                            </StackPanel>

                            <StackPanel Grid.Column="2" Margin="0,0,10,0">
                                <TextBlock FontWeight="SemiBold" Text="Z (optional)" />
                                <DockPanel Margin="0,4,0,0">
                                    <StackPanel
                                        Width="28"
                                        DockPanel.Dock="Right"
                                        Orientation="Vertical">
                                        <Button
                                            Height="22"
                                            Padding="0"
                                            Command="{Binding NudgeZPositiveCommand}">
                                            <iconPacks:PackIconMaterial
                                                Width="14"
                                                Height="14"
                                                Kind="ChevronUp" />
                                        </Button>
                                        <Button
                                            Height="22"
                                            Padding="0"
                                            Command="{Binding NudgeZNegativeCommand}">
                                            <iconPacks:PackIconMaterial
                                                Width="14"
                                                Height="14"
                                                Kind="ChevronDown" />
                                        </Button>
                                    </StackPanel>
                                    <TextBox Padding="6" Text="{Binding TargetZ, UpdateSourceTrigger=PropertyChanged}" />
                                </DockPanel>
                            </StackPanel>

                            <StackPanel Grid.Column="3">
                                <TextBlock FontWeight="SemiBold" Text="Stop short (tiles)" />
                                <TextBox
                                    Margin="0,4,0,0"
                                    Padding="6"
                                    Text="{Binding StopShortTiles, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                        </Grid>

                        <StackPanel
                            Margin="0,10,0,0"
                            VerticalAlignment="Center"
                            Orientation="Horizontal">
                            <Button Command="{Binding UseCurrentTileCommand}" Style="{StaticResource SecondaryCommandButton}">
                                <StackPanel Orientation="Horizontal">
                                    <iconPacks:PackIconMaterial
                                        Width="16"
                                        Height="16"
                                        Margin="0,0,6,0"
                                        Kind="CrosshairsGps" />
                                    <TextBlock Text="Use current tile" />
                                </StackPanel>
                            </Button>
                            <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                                <TextBlock
                                    VerticalAlignment="Center"
                                    FontWeight="SemiBold"
                                    Text="Nudge step" />
                                <TextBox
                                    Width="60"
                                    Padding="6"
                                    Text="{Binding NudgeStep, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                        </StackPanel>

                        <Grid Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                <TextBlock FontWeight="SemiBold" Text="Timeout (ms)" />
                                <TextBox
                                    Margin="0,4,0,0"
                                    Padding="6"
                                    Text="{Binding TimeoutMs, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="0,0,10,0">
                                <TextBlock FontWeight="SemiBold" Text="Jitter (tiles)" />
                                <TextBox
                                    Margin="0,4,0,0"
                                    Padding="6"
                                    Text="{Binding JitterTiles, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>

                            <StackPanel
                                Grid.Column="2"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Bottom"
                                Orientation="Horizontal">
                                <Button Command="{Binding WalkToCommand}" Style="{StaticResource PrimaryCommandButton}">
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial
                                            Width="20"
                                            Height="20"
                                            Margin="0,-2,6,0"
                                            Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                            Kind="Play" />
                                        <TextBlock Text="Walk" />
                                    </StackPanel>
                                </Button>
                                <Button
                                    Margin="10,0,0,0"
                                    Command="{Binding ClickToCommand}"
                                    Style="{StaticResource SecondaryCommandButton}">
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial
                                            Width="16"
                                            Height="16"
                                            Margin="0,0,6,0"
                                            Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                            Kind="CursorDefaultClick" />
                                        <TextBlock Text="Click only" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Grid>
                        </StackPanel>
                    </Expander>
                </Border>

                <!--  Path walking  -->
                <Border
                    behaviors:PanelLayoutBehavior.PanelKey="waypoint-path"
                    Style="{StaticResource NavigationPanelCard}">
                    <Expander Header="Temporary Waypoint Probe" IsExpanded="True">
                        <StackPanel Margin="0,10,0,0">
                        <TextBlock
                            Margin="0,0,0,8"
                            Style="{StaticResource NavigationSubtleText}"
                            Text="Quick multi-tile movement test only. One coordinate per line: x,y,z or x y z. Promote reusable paths through the Webwalking route editor." />
                        <TextBox
                            MinHeight="140"
                            Padding="8"
                            AcceptsReturn="True"
                            Text="{Binding PathInput, UpdateSourceTrigger=PropertyChanged}"
                            VerticalScrollBarVisibility="Auto" />
                        <StackPanel
                            Margin="0,10,0,0"
                            HorizontalAlignment="Right"
                            Orientation="Horizontal">
                            <Button Command="{Binding WalkPathCommand}" Style="{StaticResource PrimaryCommandButton}">
                                <StackPanel Orientation="Horizontal">
                                    <iconPacks:PackIconMaterial
                                        Width="16"
                                        Height="16"
                                        Margin="0,0,6,0"
                                        Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                        Kind="Walk" />
                                    <TextBlock Text="Walk path" />
                                </StackPanel>
                            </Button>
                            <Button
                                Margin="10,0,0,0"
                                Command="{Binding ClickPathCommand}"
                                Style="{StaticResource SecondaryCommandButton}">
                                <StackPanel Orientation="Horizontal">
                                    <iconPacks:PackIconMaterial
                                        Width="16"
                                        Height="16"
                                        Margin="0,0,6,0"
                                        Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                        Kind="CursorDefaultClick" />
                                    <TextBlock Text="Click path (no wait)" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                        </StackPanel>
                    </Expander>
                </Border>

            </StackPanel>

            <!--  Lodestones + log  -->
            <GridSplitter
                Grid.Column="1"
                Width="6"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                Background="{DynamicResource App.BorderBrush}"
                ResizeBehavior="PreviousAndNext"
                ResizeDirection="Columns" />

            <StackPanel
                Grid.Column="2"
                behaviors:PanelLayoutBehavior.PageKey="navigation-view"
                behaviors:PanelLayoutBehavior.ColumnKey="right">
                <Border
                    behaviors:PanelLayoutBehavior.PanelKey="webwalk-travel"
                    Style="{StaticResource NavigationPanelCard}">
                    <Expander Header="Webwalk Travel" IsExpanded="True">
                        <StackPanel Margin="0,10,0,0">
                            <TextBlock FontWeight="SemiBold" Text="Destination (node id, tag, or route name)" />
                            <TextBlock
                                Style="{StaticResource NavigationSubtleText}"
                                Text="e.g. lodestone.varrock · bank · lodestone · core.edgeville.bank_to_wildy_wall" />
                            <Grid Margin="0,6,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <ComboBox Grid.Column="0"
                                          IsEditable="True"
                                          ItemsSource="{Binding DestinationOptions}"
                                          Text="{Binding TravelDestination, UpdateSourceTrigger=PropertyChanged}"
                                          ToolTip="Pick a known node id, tag, or route — or type anything; free text is resolved the same way.">
                                    <ComboBox.InputBindings>
                                        <KeyBinding Key="Return" Command="{Binding TravelCommand}" />
                                    </ComboBox.InputBindings>
                                </ComboBox>
                                <Button
                                    Grid.Column="1"
                                    Margin="8,0,0,0"
                                    Command="{Binding TravelCommand}"
                                    Content="Travel"
                                    Style="{StaticResource PrimaryCommandButton}" />
                                <Button
                                    Grid.Column="2"
                                    Margin="6,0,0,0"
                                    Command="{Binding StopTravelCommand}"
                                    Content="Stop" />
                            </Grid>
                            <TextBlock
                                Margin="0,6,0,0"
                                Style="{StaticResource NavigationSubtleText}"
                                Text="Resolves node id → tag → route, plans over the seeded graph (lodestones included), executes with replanning. Per-edge results land in the activity log. Press Enter in the box to travel." />
                        </StackPanel>
                    </Expander>
                </Border>
                <Border
                    behaviors:PanelLayoutBehavior.PanelKey="lodestone-network"
                    Style="{StaticResource NavigationPanelCard}">
                    <Expander Header="Lodestone Network" IsExpanded="True">
                        <StackPanel Margin="0,10,0,0">
                        <Grid Margin="0,0,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock FontWeight="SemiBold" Text="Select destination" />
                                <ComboBox
                                    Margin="0,4,0,0"
                                    DisplayMemberPath="Display"
                                    ItemsSource="{Binding Lodestones}"
                                    SelectedItem="{Binding SelectedLodestone}" />
                            </StackPanel>
                            <StackPanel
                                Grid.Column="1"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Bottom"
                                Orientation="Horizontal">
                                <Button
                                    Margin="8,0,0,0"
                                    Command="{Binding TeleportSelectedCommand}"
                                    Style="{StaticResource PrimaryCommandButton}">
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial
                                            Width="24"
                                            Height="24"
                                            Margin="0,-2,6,0"
                                            Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                            Kind="RayStartArrow" />
                                        <TextBlock Text="Teleport" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Grid>

                        <Grid Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock FontWeight="SemiBold" Text="Teleport by name" />
                                <TextBox
                                    Margin="0,4,0,0"
                                    Padding="6"
                                    Text="{Binding LodestoneSearch, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock
                                    Margin="0,4,0,0"
                                    Style="{StaticResource NavigationSubtleText}"
                                    Text="Partial match is fine (e.g., 'priff', 'edge', 'lunar')." />
                            </StackPanel>
                            <StackPanel
                                Grid.Column="1"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Bottom"
                                Orientation="Horizontal">
                                <Button
                                    Margin="8,0,0,0"
                                    Command="{Binding TeleportByNameCommand}"
                                    Style="{StaticResource SecondaryCommandButton}">
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial
                                            Width="16"
                                            Height="16"
                                            Margin="0,0,6,0"
                                            Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                            Kind="ArrowDecisionAuto" />
                                        <TextBlock Text="Send" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                            <StackPanel
                                Grid.Column="2"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Bottom"
                                Orientation="Horizontal">
                                <Button Command="{Binding WaitWhileMovingCommand}" Style="{StaticResource SecondaryCommandButton}">
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial
                                            Width="16"
                                            Height="16"
                                            Margin="0,0,6,0"
                                            Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                            Kind="TimerSand" />
                                        <TextBlock Text="Wait stop" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Grid>

                        <StackPanel
                            Margin="0,10,0,0"
                            VerticalAlignment="Center"
                            Orientation="Horizontal">
                            <TextBlock FontWeight="SemiBold" Text="Teleport timeout (ms)" />
                            <TextBox
                                Width="100"
                                Margin="10,0,0,0"
                                Padding="6"
                                Text="{Binding TeleportTimeoutMs, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                        <StackPanel Margin="0,8,0,0" Orientation="Horizontal">
                            <Button Command="{Binding WaitUntilWithinCommand}" Style="{StaticResource SecondaryCommandButton}">
                                <StackPanel Orientation="Horizontal">
                                    <iconPacks:PackIconMaterial
                                        Width="16"
                                        Height="16"
                                        Margin="0,0,6,0"
                                        Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                        Kind="MapMarkerCheck" />
                                    <TextBlock Text="Wait arrival" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                        </StackPanel>
                    </Expander>
	                </Border>

                    <Border
                        behaviors:PanelLayoutBehavior.PanelKey="api-teleports"
                        Style="{StaticResource NavigationPanelCard}">
                        <Expander Header="Teleport Dispatch Probes" IsExpanded="False">
                            <StackPanel Margin="0,10,0,0">
                                <TextBlock Margin="0,0,0,8" Style="{StaticResource NavigationSubtleText}" Text="These buttons call the raw Teleports API directly. They are useful for checking whether an action recipe works before it becomes a supported webwalk graph edge." />
                                <TextBlock FontWeight="SemiBold" Text="Spellbook" />
                                <StackPanel Margin="0,6,0,0" Orientation="Horizontal">
                                    <TextBox Width="90" Padding="6" Text="{Binding ApiSpellbookIndex}" />
                                    <Button Margin="8,0,0,0" Padding="10,4" Command="{Binding ApiSpellbookByIndexCommand}" Content="Cast Index" />
                                </StackPanel>

                                <StackPanel Margin="0,10,0,0">
                                    <TextBlock FontWeight="SemiBold" Text="Teleport by name" />
                                    <TextBox Margin="0,4,0,0" Padding="6" Text="{Binding ApiTeleportName, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Margin="0,4,0,0" Style="{StaticResource NavigationSubtleText}" Text="The same destination text is passed to the selected network call: spellbook, spirit tree, glider, fairy ring, or quiver." />
                                    <StackPanel Margin="0,6,0,0" Orientation="Horizontal">
                                        <Button Margin="0,0,8,0" Padding="10,4" Command="{Binding ApiSpellbookByNameCommand}" Content="Spellbook" />
                                        <Button Margin="0,0,8,0" Padding="10,4" Command="{Binding ApiSpiritTreeCommand}" Content="Spirit Tree" />
                                        <Button Margin="0,0,8,0" Padding="10,4" Command="{Binding ApiGliderCommand}" Content="Glider" />
                                        <Button Margin="0,0,8,0" Padding="10,4" Command="{Binding ApiFairyCommand}" Content="Fairy" />
                                        <Button Padding="10,4" Command="{Binding ApiQuiver4Command}" Content="Quiver4" />
                                    </StackPanel>
                                </StackPanel>

                                <Separator Margin="0,10,0,10" />

                                <TextBlock FontWeight="SemiBold" Text="Jewelry" />
                                <TextBlock Margin="0,6,0,0" Style="{StaticResource NavigationSubtleText}" Text="Uses Teleports.Jewelry (item + 1/2 locations + menu level + offset)." />
                                <TextBox Margin="0,6,0,0" Padding="6" Text="{Binding ApiJewelryItemName}" />
                                <StackPanel Margin="0,6,0,0" Orientation="Horizontal">
                                    <TextBox Width="150" Padding="6" Text="{Binding ApiJewelryLocation1}" />
                                    <TextBox Width="150" Margin="8,0,0,0" Padding="6" Text="{Binding ApiJewelryLocation2}" />
                                </StackPanel>
                                <StackPanel Margin="0,6,0,0" Orientation="Horizontal">
                                    <TextBox Width="90" Padding="6" Text="{Binding ApiJewelryMenuLevel}" />
                                    <TextBox Width="140" Margin="8,0,0,0" Padding="6" Text="{Binding ApiJewelryOffset}" />
                                    <Button Margin="8,0,0,0" Padding="10,4" Command="{Binding ApiJewelryTeleportCommand}" Content="Teleport" />
                                </StackPanel>
                            </StackPanel>
                        </Expander>
                    </Border>

                    <Border
                        behaviors:PanelLayoutBehavior.PanelKey="api-minimap"
                        Style="{StaticResource NavigationPanelCard}">
                        <Expander Header="Minimap (API)" IsExpanded="False">
                            <StackPanel Margin="0,10,0,0">
                                <TextBlock FontWeight="SemiBold" Text="Click icon" />
                                <TextBox Margin="0,4,0,0" Padding="6" Text="{Binding ApiMinimapIconId}" />
                                <TextBlock Margin="0,10,0,0" FontWeight="SemiBold" Text="Click icon at" />
                                <StackPanel Margin="0,4,0,0" Orientation="Horizontal">
                                    <TextBox Width="90" Padding="6" Text="{Binding ApiMinimapX}" />
                                    <TextBox Width="90" Margin="8,0,0,0" Padding="6" Text="{Binding ApiMinimapY}" />
                                </StackPanel>
                                <StackPanel Margin="0,8,0,0" Orientation="Horizontal">
                                    <Button Margin="0,0,8,0" Padding="10,4" Command="{Binding ApiMinimapClickIconCommand}" Content="Click Icon" />
                                    <Button Padding="10,4" Command="{Binding ApiMinimapClickIconAtCommand}" Content="Click Icon At" />
                                </StackPanel>
                            </StackPanel>
                        </Expander>
                    </Border>
	
	                <Border
	                    behaviors:PanelLayoutBehavior.PanelKey="activity-log"
	                    Style="{StaticResource NavigationPanelCard}">
                    <Expander Header="Activity Log" IsExpanded="False">
                        <StackPanel Margin="0,10,0,0">
                        <TextBlock
                            Margin="0,0,0,0"
                            Text="No activity logged yet."
                            Visibility="Collapsed">
                            <TextBlock.Style>
                                <Style BasedOn="{StaticResource NavigationSubtleText}" TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ActivityLog.Count}" Value="0">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <ListBox
                            MaxHeight="240"
                            Margin="0,8,0,0"
                            Background="{DynamicResource App.BackgroundBrush}"
                            BorderBrush="{DynamicResource PrimarySoftBrush}"
                            BorderThickness="1"
                            FontFamily="Consolas"
                            FontSize="12"
                            Foreground="{DynamicResource App.ForegroundBrush}"
                            ItemsSource="{Binding ActivityLog}">
                            <ListBox.Style>
                                <Style TargetType="ListBox">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ActivityLog.Count}" Value="0">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ListBox.Style>
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="6,3" />
                                    <Setter Property="Background" Value="Transparent" />
                                    <Setter Property="Foreground" Value="{DynamicResource App.ForegroundBrush}" />
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <VirtualizingStackPanel />
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                        </ListBox>
                        </StackPanel>
                    </Expander>
                </Border>
            </StackPanel>
        </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>
