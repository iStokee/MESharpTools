<Window
    x:Class="MESharp.Views.SectionHelpWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
    Title="{Binding Title}"
    Width="760"
    Height="700"
    MinWidth="620"
    MinHeight="500"
    WindowStartupLocation="CenterOwner"
    Background="{DynamicResource App.BackgroundBrush}">

    <Window.Resources>
        <!-- Local copies: modal windows must be self-sufficient in hosted mode -->
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <Style x:Key="HelpCard" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource App.CardBrush}" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="14,12" />
            <Setter Property="Margin" Value="0,0,0,10" />
        </Style>
        <Style x:Key="HelpSectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="Foreground" Value="{DynamicResource App.ForegroundBrush}" />
        </Style>
        <Style x:Key="HelpBody" TargetType="TextBlock">
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{DynamicResource App.ForegroundBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style x:Key="HelpMuted" TargetType="TextBlock" BasedOn="{StaticResource HelpBody}">
            <Setter Property="Foreground" Value="{DynamicResource App.SubtleForegroundBrush}" />
        </Style>
        <!-- Chip mimicking the named button/field so users can match it visually -->
        <Style x:Key="TopicChip" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource App.BackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Padding" Value="8,3" />
            <Setter Property="Margin" Value="0,0,10,6" />
            <Setter Property="VerticalAlignment" Value="Top" />
            <Setter Property="Width" Value="140" />
        </Style>
        <Style x:Key="TopicChipText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="TextAlignment" Value="Center" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}" />
        </Style>
    </Window.Resources>

    <DockPanel LastChildFill="True">
        <!-- Footer -->
        <Border DockPanel.Dock="Bottom" Padding="16,10" Background="{DynamicResource App.CardBrush}">
            <DockPanel>
                <Button DockPanel.Dock="Right" Width="110" Height="32" IsDefault="True" IsCancel="True"
                        Content="Got it" Click="Close_Click" />
                <TextBlock Style="{StaticResource HelpMuted}" VerticalAlignment="Center"
                           Text="{Binding FooterText}" />
            </DockPanel>
        </Border>

        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="16">
            <StackPanel>
                <!-- Header -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                    <iconPacks:PackIconMaterial Kind="{Binding IconKind}" Width="24" Height="24" Margin="0,0,10,0"
                                                VerticalAlignment="Center" Foreground="{DynamicResource PrimaryBrush}" />
                    <TextBlock FontSize="20" FontWeight="Bold" Text="{Binding Title}"
                               Foreground="{DynamicResource App.ForegroundBrush}" />
                </StackPanel>
                <TextBlock Margin="0,0,0,14" Style="{StaticResource HelpMuted}" Text="{Binding Subtitle}" />

                <!-- Sections -->
                <ItemsControl ItemsSource="{Binding Sections}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource HelpCard}">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource HelpSectionTitle}" Text="{Binding Title}" />
                                    <TextBlock Style="{StaticResource HelpMuted}" Text="{Binding Intro}" Margin="0,0,0,8"
                                               Visibility="{Binding HasIntro, Converter={StaticResource BoolToVis}}" />
                                    <ItemsControl ItemsSource="{Binding Topics}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0,0,0,6">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <Border Grid.Column="0" Style="{StaticResource TopicChip}">
                                                        <TextBlock Style="{StaticResource TopicChipText}" Text="{Binding Title}" />
                                                    </Border>
                                                    <StackPanel Grid.Column="1" Margin="0,2,0,0">
                                                        <TextBlock Style="{StaticResource HelpBody}" Text="{Binding Body}" />
                                                        <Border Margin="0,4,0,0" Padding="8,4" CornerRadius="4"
                                                                Background="{DynamicResource App.BackgroundBrush}"
                                                                BorderBrush="{DynamicResource App.BorderBrush}" BorderThickness="1"
                                                                Visibility="{Binding HasCode, Converter={StaticResource BoolToVis}}">
                                                            <TextBlock Style="{StaticResource HelpBody}" FontFamily="Consolas" FontSize="11"
                                                                       Text="{Binding Code}" />
                                                        </Border>
                                                    </StackPanel>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
