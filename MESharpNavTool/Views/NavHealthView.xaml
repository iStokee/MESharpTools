<UserControl
    x:Class="MESharp.Views.NavHealthView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:MESharp.ViewModels"
    mc:Ignorable="d"
    d:DataContext="{d:DesignInstance Type=vm:NavHealthViewModel}"
    d:DesignHeight="760"
    d:DesignWidth="1100">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <Style x:Key="Card" TargetType="Border" BasedOn="{StaticResource Hub.Card}" />
        <Style x:Key="HintText" TargetType="TextBlock" BasedOn="{StaticResource Hub.HintText}" />
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Style="{StaticResource Card}">
                <DockPanel>
                    <Button DockPanel.Dock="Right" Command="{Binding RefreshCommand}" Content="Refresh" Padding="12,5" />
                    <StackPanel>
                        <TextBlock Style="{StaticResource Hub.PageTitle}" Text="Navigation Status" />
                        <TextBlock Margin="0,4,0,0" Style="{StaticResource HintText}"
                                   Text="Collision grids, cache-derived obstacle data, ladder seeds, graph health, and refresh actions." />
                    </StackPanel>
                </DockPanel>
            </Border>

            <Border Grid.Row="1" Style="{StaticResource Card}">
                <ItemsControl ItemsSource="{Binding Indicators}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Width="330" Margin="0,0,8,8" Padding="10"
                                    Background="{DynamicResource App.BackgroundBrush}"
                                    BorderBrush="{DynamicResource App.BorderBrush}"
                                    BorderThickness="1" CornerRadius="6">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Ellipse Grid.Column="0" Width="11" Height="11" Margin="0,3,8,0" VerticalAlignment="Top">
                                        <Ellipse.Style>
                                            <Style TargetType="Ellipse">
                                                <Setter Property="Fill" Value="#9E9E9E" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding State}" Value="ok">
                                                        <Setter Property="Fill" Value="#4CAF50" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding State}" Value="warn">
                                                        <Setter Property="Fill" Value="#FFC107" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding State}" Value="error">
                                                        <Setter Property="Fill" Value="#F44336" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Ellipse.Style>
                                    </Ellipse>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock FontWeight="SemiBold" Text="{Binding Title}" />
                                        <TextBlock Margin="0,3,0,0" Style="{StaticResource HintText}" Text="{Binding Detail}" TextWrapping="Wrap" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Border>

            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.2*" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="1*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource Hub.SectionHeader}" Text="Cache Dump" />
                        <TextBlock Style="{StaticResource HintText}" Text="{Binding DumpStatusText}" TextWrapping="Wrap" />
                        <TextBox Margin="0,8,0,6" Text="{Binding DumpDirectory, UpdateSourceTrigger=PropertyChanged}" />
                        <CheckBox Margin="0,2,0,8"
                                  IsChecked="{Binding TreatWildernessDitchAsCrossable}"
                                  Content="Treat Wilderness ditch as crossable when regenerating collision grids" />

                        <TextBlock Style="{StaticResource HintText}" TextWrapping="Wrap"
                                   Text="External cache-dump tool (e.g. mejrs/rs3cache — not shipped). {output} in the args is replaced with the dump folder above." />
                        <TextBox Margin="0,4,0,4" Text="{Binding DumpCommand, UpdateSourceTrigger=PropertyChanged}"
                                 ToolTip="Path to the cache dump executable, e.g. C:\tools\rs3cache.exe" />
                        <TextBox Margin="0,0,0,6" Text="{Binding DumpArguments, UpdateSourceTrigger=PropertyChanged}"
                                 ToolTip="Arguments, e.g. --output {output} --npcs --locations --tiles" />
                        <StackPanel Orientation="Horizontal">
                            <Button Command="{Binding SaveDumpPathCommand}" Content="Save Settings" Padding="12,5" Margin="0,0,6,0" />
                            <Button Command="{Binding RegenerateCollisionCommand}" Content="Regenerate Collision Grids" Padding="12,5" Margin="0,0,6,0" />
                            <Button Command="{Binding RegenerateDumpCommand}" Content="Run Cache Dump (incl. NPCs)" Padding="12,5" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource Hub.SectionHeader}" Text="Derived Navigation Data" />
                        <UniformGrid Columns="1">
                            <Button Margin="0,0,0,6" Command="{Binding RegenerateObstaclesCommand}" Content="Regenerate Obstacle Catalog + Ladder Seeds" Padding="12,5" />
                            <Button Margin="0,0,0,6" Command="{Binding ImportLadderSeedsCommand}" Content="Import Ladder Seeds Into Graph" Padding="12,5" />
                            <Button Margin="0,0,0,6" Command="{Binding RegenerateAreasCommand}" Content="Derive Areas (Banks + Skilling) From Dump" Padding="12,5" />
                            <Button Margin="0,0,0,6" Command="{Binding RegenerateNpcAreasCommand}" Content="Derive NPC Areas (Fishing/Shops/Slayer) From Dump" Padding="12,5" />
                            <Button Margin="0,0,0,6" Command="{Binding ImportAreaSeedsCommand}" Content="Import Cache-Derived Areas Into Graph" Padding="12,5" />
                            <Button Margin="0,0,0,6" Command="{Binding ReloadCollisionCommand}" Content="Reload Collision Grids" Padding="12,5" />
                            <Button Margin="0,0,0,6" Command="{Binding ReloadCatalogCommand}" Content="Reload Obstacle Catalog" Padding="12,5" />
                            <Button Command="{Binding ReloadGraphCommand}" Content="Reload Webwalk Graph" Padding="12,5" />
                        </UniformGrid>
                    </StackPanel>
                </Border>
            </Grid>

            <Border Grid.Row="3" Style="{StaticResource Card}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <DockPanel Grid.Row="0" Margin="0,0,0,6">
                        <TextBlock Style="{StaticResource Hub.SectionHeader}" Text="Activity Log" />
                        <TextBlock DockPanel.Dock="Right" Margin="12,0,0,0" Style="{StaticResource HintText}"
                                   Text="{Binding BusyOperation}"
                                   Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}" />
                    </DockPanel>
                    <TextBox Grid.Row="1" MinHeight="160"
                             Text="{Binding Log}"
                             FontFamily="Consolas" FontSize="11"
                             TextWrapping="Wrap"
                             IsReadOnly="True"
                             VerticalScrollBarVisibility="Auto" />
                </Grid>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
