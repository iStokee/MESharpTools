<UserControl
    x:Class="SharpBuilder.Editor.Wpf.Views.NodeEditorControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="http://metro.mahapps.com/winfx/xaml/controls"
    xmlns:converters="clr-namespace:SharpBuilder.Editor.Wpf.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
    xmlns:mahApps="http://metro.mahapps.com/winfx/xaml/controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="clr-namespace:SharpBuilder.Core.Models;assembly=SharpBuilder.Core"
    xmlns:utils="clr-namespace:SharpBuilder.Editor.Wpf.Utilities"
    xmlns:viewModels="clr-namespace:SharpBuilder.Editor.Wpf.ViewModels"
    x:Name="Root"
    d:DataContext="{d:DesignInstance viewModels:NodeEditorViewModel,
                                     IsDesignTimeCreatable=True}"
    d:DesignHeight="900"
    d:DesignWidth="1400"
    mc:Ignorable="d">

    <UserControl.InputBindings>
        <KeyBinding Key="Delete" Command="{Binding DeleteSelectedCommand}" />
        <KeyBinding Key="Escape" Command="{Binding CloseNodeInfoCommand}" />
        <KeyBinding Key="S" Modifiers="Control" Command="{Binding SaveScriptCommand}" />
        <KeyBinding Key="S" Modifiers="Control+Shift" Command="{Binding ExportScriptCommand}" />
        <KeyBinding Key="N" Modifiers="Control" Command="{Binding NewScriptCommand}" />
        <KeyBinding Key="O" Modifiers="Control" Command="{Binding LoadScriptCommand}" />
        <KeyBinding Key="F5" Command="{Binding StartCommand}" />
        <KeyBinding Key="F5" Modifiers="Control" Command="{Binding StepCommand}" />
        <KeyBinding Key="F5" Modifiers="Shift" Command="{Binding StopCommand}" />
    </UserControl.InputBindings>

    <UserControl.Resources>
        <converters:NodeConnectorConverter x:Key="NodeConnectorConverter" />
        <converters:NodeVisualConverter x:Key="NodeVisualConverter" />
        <converters:TransitionPortLabelConverter x:Key="TransitionPortLabelConverter" />
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <converters:DefinitionIdVisibilityConverter x:Key="DefinitionIdVisibilityConverter" />
        <converters:NodeParameterBoolConverter x:Key="NodeParameterBoolConverter" />
        <converters:EqualityToVisibilityConverter x:Key="EqualityToVisibilityConverter" />
        <converters:AccentBrushConverter x:Key="AccentBrushConverter" />
        <converters:CatalogSortModeLabelConverter x:Key="CatalogSortModeLabelConverter" />
        <SolidColorBrush x:Key="EditorPrimaryBrush" Color="#FF4AB6FF" />
        <SolidColorBrush x:Key="EditorPrimaryMutedBrush" Color="#334AB6FF" />
        <SolidColorBrush x:Key="EditorPrimarySurfaceBrush" Color="#1C4AB6FF" />

        <!--  Panel / surface palette shared by the catalog, canvas, and inspector cards  -->
        <SolidColorBrush x:Key="PanelSurfaceBrush" Color="#FF141A24" />
        <SolidColorBrush x:Key="PanelHeaderBrush" Color="#FF1A2230" />
        <SolidColorBrush x:Key="PanelBorderBrush" Color="#2A4D6A8C" />
        <SolidColorBrush x:Key="RailSurfaceBrush" Color="#FF161D29" />

        <!--  Elevated container shared by all three workspace columns  -->
        <Style x:Key="PanelCard" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource PanelSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource PanelBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect
                        BlurRadius="22"
                        Direction="270"
                        Opacity="0.34"
                        ShadowDepth="3"
                        Color="#000000" />
                </Setter.Value>
            </Setter>
        </Style>

        <!--  Circular toggle used in panel headers and collapsed rails  -->
        <Style x:Key="RailToggleButton" TargetType="ToggleButton">
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Foreground" Value="{DynamicResource MahApps.Brushes.IdealForeground}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border
                            x:Name="Bd"
                            Background="{StaticResource EditorPrimarySurfaceBrush}"
                            BorderBrush="{StaticResource EditorPrimaryMutedBrush}"
                            BorderThickness="1"
                            CornerRadius="16">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource EditorPrimaryMutedBrush}" />
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource EditorPrimaryBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource EditorPrimaryBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  Vertical caption used on collapsed rails  -->
        <Style x:Key="RailCaption" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#FFC9D6E4" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="LayoutTransform">
                <Setter.Value>
                    <RotateTransform Angle="-90" />
                </Setter.Value>
            </Setter>
        </Style>
        <DropShadowEffect
            x:Key="NodeShadow"
            BlurRadius="12"
            Opacity="0.4"
            ShadowDepth="2" />
        <DataTemplate x:Key="NodeParamStringTemplate">
            <TextBox Margin="0,4,0,0" Text="{Binding Value.RawValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
        </DataTemplate>
        <DataTemplate x:Key="NodeParamNumberTemplate">
            <TextBox Margin="0,4,0,0" Text="{Binding Value.RawValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
        </DataTemplate>
        <DataTemplate x:Key="NodeParamBoolTemplate">
            <CheckBox Margin="0,6,0,0" IsChecked="{Binding Value.BoolValue, Mode=TwoWay}" />
        </DataTemplate>
        <DataTemplate x:Key="NodeParamEnumTemplate">
            <ComboBox
                Margin="0,4,0,0"
                IsEditable="True"
                ItemsSource="{Binding Definition.EnumValues}"
                SelectedItem="{Binding Value.RawValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
        </DataTemplate>
        <!--  Enum + inline companion (e.g. Quantity dropdown with an inline Count box for "Some")  -->
        <DataTemplate x:Key="NodeParamEnumInlineTemplate">
            <Grid Margin="0,4,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <ComboBox
                    IsEditable="True"
                    ItemsSource="{Binding Definition.EnumValues}"
                    SelectedItem="{Binding Value.RawValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                <TextBox
                    Grid.Column="1"
                    Width="84"
                    Margin="6,0,0,0"
                    VerticalContentAlignment="Center"
                    mahApps:TextBoxHelper.Watermark="Count"
                    Text="{Binding InlineCompanion.Value.RawValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    ToolTip="{Binding InlineCompanion.Definition.Label}">
                    <TextBox.Visibility>
                        <MultiBinding Converter="{StaticResource EqualityToVisibilityConverter}">
                            <Binding Path="Value.RawValue" />
                            <Binding Path="Definition.InlineCompanionVisibleWhen" />
                        </MultiBinding>
                    </TextBox.Visibility>
                </TextBox>
            </Grid>
        </DataTemplate>
        <DataTemplate x:Key="NodeParamListTemplate">
            <StackPanel>
                <TextBox
                    Height="70"
                    Margin="0,4,0,0"
                    AcceptsReturn="True"
                    Text="{Binding Value.RawValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    TextWrapping="Wrap"
                    Visibility="Visible" />
                <Button
                    Margin="0,6,0,0"
                    HorizontalAlignment="Left"
                    Command="{Binding DataContext.AddListItemCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                    CommandParameter="{Binding}"
                    Content="Add line" />
                <ItemsControl ItemsSource="{Binding Value.Values}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border
                                Margin="0,4,4,0"
                                Padding="6,2"
                                Background="{DynamicResource MahApps.Brushes.Gray9}"
                                CornerRadius="4">
                                <TextBlock Text="{Binding}" />
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </DataTemplate>
        <utils:NodeParameterTemplateSelector
            x:Key="NodeParameterTemplateSelector"
            BoolTemplate="{StaticResource NodeParamBoolTemplate}"
            EnumInlineTemplate="{StaticResource NodeParamEnumInlineTemplate}"
            EnumTemplate="{StaticResource NodeParamEnumTemplate}"
            ListTemplate="{StaticResource NodeParamListTemplate}"
            NumberTemplate="{StaticResource NodeParamNumberTemplate}"
            StringTemplate="{StaticResource NodeParamStringTemplate}" />

        <!--  Shared editor card for one node parameter (used by the main + Advanced lists)  -->
        <DataTemplate x:Key="NodeParamBindingTemplate" DataType="{x:Type models:NodeParamBinding}">
            <Border
                Margin="0,0,0,8"
                Padding="8"
                Background="{DynamicResource MahApps.Brushes.Gray9}"
                CornerRadius="8">
                <StackPanel>
                    <DockPanel>
                        <TextBlock
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource MahApps.Brushes.IdealForeground}"
                            Text="{Binding Definition.Label}" />
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                            <Border
                                Margin="6,0,0,0"
                                Padding="5,1"
                                Background="{DynamicResource MahApps.Brushes.Gray8}"
                                CornerRadius="4">
                                <TextBlock
                                    FontSize="11"
                                    Foreground="{DynamicResource MahApps.Brushes.IdealForeground}"
                                    Opacity="0.82"
                                    Text="{Binding Definition.Key}" />
                            </Border>
                            <Border
                                Margin="6,0,0,0"
                                Padding="5,1"
                                Background="{DynamicResource MahApps.Brushes.Gray8}"
                                CornerRadius="4">
                                <TextBlock
                                    FontSize="11"
                                    Foreground="{DynamicResource MahApps.Brushes.IdealForeground}"
                                    Opacity="0.82"
                                    Text="{Binding Definition.Type}" />
                            </Border>
                        </StackPanel>
                    </DockPanel>
                    <TextBlock
                        FontSize="12"
                        Foreground="{DynamicResource MahApps.Brushes.IdealForeground}"
                        Opacity="0.82"
                        Text="{Binding Definition.Placeholder, StringFormat=Example: {0}}"
                        TextWrapping="Wrap" />
                    <ContentControl Content="{Binding}" ContentTemplateSelector="{StaticResource NodeParameterTemplateSelector}" />
                </StackPanel>
            </Border>
        </DataTemplate>

        <!--  Pill-style tab headers for the canvas dashboard  -->
        <Style x:Key="DashboardTabItem" TargetType="TabItem">
            <Setter Property="Foreground" Value="{DynamicResource MahApps.Brushes.IdealForeground}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border
                            x:Name="Bd"
                            Margin="0,0,6,0"
                            Padding="14,6"
                            Background="#1AFFFFFF"
                            BorderBrush="{StaticResource PanelBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8">
                            <ContentPresenter ContentSource="Header" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource EditorPrimaryMutedBrush}" />
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource EditorPrimaryBrush}" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource EditorPrimaryBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  Compact sortable table used by the XP and Items dashboard tabs  -->
        <Style x:Key="DashboardDataGrid" TargetType="DataGrid">
            <Setter Property="AutoGenerateColumns" Value="False" />
            <Setter Property="IsReadOnly" Value="True" />
            <Setter Property="CanUserAddRows" Value="False" />
            <Setter Property="CanUserDeleteRows" Value="False" />
            <Setter Property="CanUserResizeRows" Value="False" />
            <Setter Property="CanUserReorderColumns" Value="True" />
            <Setter Property="CanUserSortColumns" Value="True" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="HorizontalGridLinesBrush" Value="#22FFFFFF" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="RowBackground" Value="#14FFFFFF" />
            <Setter Property="AlternatingRowBackground" Value="#1FFFFFFF" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="SelectionMode" Value="Single" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <!--  Modern pill buttons used across the canvas toolbar  -->
        <Style x:Key="ToolbarButton" TargetType="Button">
            <Setter Property="Foreground" Value="{DynamicResource MahApps.Brushes.IdealForeground}" />
            <Setter Property="Background" Value="#FF1E2838" />
            <Setter Property="BorderBrush" Value="{StaticResource PanelBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="12,7" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="8"
                            SnapsToDevicePixels="True">
                            <ContentPresenter
                                Margin="{TemplateBinding Padding}"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.85" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.7" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.4" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style
            x:Key="ToolbarRunButton"
            BasedOn="{StaticResource ToolbarButton}"
            TargetType="Button">
            <Setter Property="BorderBrush" Value="#FF6EE86E" />
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Offset="0" Color="#FF2FA85A" />
                        <GradientStop Offset="1" Color="#FF1F7E42" />
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
        </Style>

        <Style
            x:Key="ToolbarStopButton"
            BasedOn="{StaticResource ToolbarButton}"
            TargetType="Button">
            <Setter Property="BorderBrush" Value="#FFE86E6E" />
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Offset="0" Color="#FF8F3030" />
                        <GradientStop Offset="1" Color="#FF6A2020" />
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
        </Style>

        <Style
            x:Key="ToolbarDeleteButton"
            BasedOn="{StaticResource ToolbarButton}"
            TargetType="Button">
            <Setter Property="Background" Value="#33A83A3A" />
            <Setter Property="BorderBrush" Value="#66E86E6E" />
        </Style>

        <Style x:Key="EditorColumnHeader" TargetType="Border">
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="Background" Value="{StaticResource PanelHeaderBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource PanelBorderBrush}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="CornerRadius" Value="13,13,0,0" />
        </Style>
        <Style x:Key="DashboardMetricCard" TargetType="Border">
            <Setter Property="Margin" Value="0,0,8,8" />
            <Setter Property="Padding" Value="8" />
            <Setter Property="Background" Value="#24101824" />
            <Setter Property="BorderBrush" Value="#334AB6FF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
        </Style>
        <Style x:Key="DashboardMetricLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10" />
            <Setter Property="Foreground" Value="{DynamicResource MahApps.Brushes.Gray6}" />
        </Style>
        <Style x:Key="DashboardMetricValue" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,2,0,0" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontFamily" Value="Consolas" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource MahApps.Brushes.IdealForeground}" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>
        <Style x:Key="DashboardXpText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontFamily" Value="Consolas" />
            <Setter Property="Foreground" Value="{DynamicResource MahApps.Brushes.IdealForeground}" />
            <Setter Property="TextAlignment" Value="Center" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>
        <DataTemplate x:Key="DashboardSkillRowTemplate">
            <Border
                Margin="0,0,0,6"
                Padding="1.5"
                BorderThickness="1.5"
                CornerRadius="7">
                <Border.BorderBrush>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Offset="0" Color="{Binding PrimaryBrush.Color}" />
                        <GradientStop Offset="0.5" Color="{Binding SecondaryBrush.Color}" />
                        <GradientStop Offset="1" Color="{Binding PrimaryBrush.Color}" />
                    </LinearGradientBrush>
                </Border.BorderBrush>
                <Border Background="#D9141820" CornerRadius="5" Padding="7">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="34" />
                            <ColumnDefinition Width="86" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border
                            Width="28"
                            Height="28"
                            Background="{Binding SecondaryBrush}"
                            CornerRadius="5"
                            Opacity="0.72">
                            <TextBlock
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                FontFamily="Consolas"
                                FontSize="13"
                                FontWeight="SemiBold"
                                Foreground="{DynamicResource MahApps.Brushes.IdealForeground}"
                                Text="{Binding Level}" />
                        </Border>
                        <TextBlock
                            Grid.Column="1"
                            Margin="8,0,4,0"
                            VerticalAlignment="Center"
                            FontSize="12"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource MahApps.Brushes.IdealForeground}"
                            Text="{Binding Name}"
                            TextTrimming="CharacterEllipsis" />
                        <UniformGrid Grid.Column="2" Columns="5">
                            <StackPanel Margin="3,0">
                                <TextBlock Style="{StaticResource DashboardXpText}" Text="XP" />
                                <TextBlock Style="{StaticResource DashboardXpText}" Text="{Binding Xp, StringFormat=N0}" />
                            </StackPanel>
                            <StackPanel Margin="3,0">
                                <TextBlock Style="{StaticResource DashboardXpText}" Text="Gained" />
                                <TextBlock Style="{StaticResource DashboardXpText}" Text="{Binding XpGained, StringFormat=N0}" />
                            </StackPanel>
                            <StackPanel Margin="3,0">
                                <TextBlock Style="{StaticResource DashboardXpText}" Text="XP/hr" />
                                <TextBlock Style="{StaticResource DashboardXpText}" Text="{Binding XpPerHour, StringFormat=N0}" />
                            </StackPanel>
                            <StackPanel Margin="3,0">
                                <TextBlock Style="{StaticResource DashboardXpText}" Text="To next" />
                                <TextBlock Style="{StaticResource DashboardXpText}" Text="{Binding XpToNext, StringFormat=N0}" />
                            </StackPanel>
                            <StackPanel Margin="3,0">
                                <TextBlock Style="{StaticResource DashboardXpText}" Text="ETA" />
                                <TextBlock Style="{StaticResource DashboardXpText}" Text="{Binding Eta}" />
                            </StackPanel>
                        </UniformGrid>
                    </Grid>
                </Border>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border
            Padding="16,12"
            BorderBrush="{StaticResource PanelBorderBrush}"
            BorderThickness="1"
            CornerRadius="14">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Offset="0" Color="#FF1B2738" />
                    <GradientStop Offset="0.55" Color="#FF161D29" />
                    <GradientStop Offset="1" Color="#FF141A24" />
                </LinearGradientBrush>
            </Border.Background>
            <Border.Effect>
                <DropShadowEffect
                    BlurRadius="22"
                    Direction="270"
                    Opacity="0.34"
                    ShadowDepth="3"
                    Color="#000000" />
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!--  Accent logo tile  -->
                <Border
                    Width="46"
                    Height="46"
                    BorderBrush="{StaticResource EditorPrimaryBrush}"
                    BorderThickness="1.5"
                    CornerRadius="12">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Offset="0" Color="#FF2E6FB0" />
                            <GradientStop Offset="1" Color="#FF1C3A57" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <iconPacks:PackIconMaterial
                        Width="26"
                        Height="26"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Foreground="{DynamicResource MahApps.Brushes.IdealForeground}"
                        Kind="GraphOutline" />
                </Border>

                <StackPanel
                    Grid.Column="1"
                    Margin="14,0,0,0"
                    VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock
                            FontSize="22"
                            FontWeight="Bold"
                            Foreground="{DynamicResource MahApps.Brushes.IdealForeground}"
                            Text="SharpBuilder" />
                        <Border
                            Margin="10,2,0,0"
                            Padding="7,2"
                            VerticalAlignment="Center"
                            Background="{StaticResource EditorPrimaryMutedBrush}"
                            BorderBrush="{StaticResource EditorPrimaryBrush}"
                            BorderThickness="1"
                            CornerRadius="8">
                            <TextBlock
                                FontSize="10"
                                FontWeight="SemiBold"
                                Foreground="{DynamicResource MahApps.Brushes.IdealForeground}"
                                Text="STUDIO" />
                        </Border>
                    </StackPanel>
                    <TextBlock
                        Margin="0,2,0,0"
                        FontSize="12"
                        Foreground="{DynamicResource MahApps.Brushes.IdealForeground}"
                        Opacity="0.78"
                        Text="Visual automation studio — design, validate, and run no-code flows in-game, in Orbit, or headless." />
                </StackPanel>

                <!--  Run-target hint chips  -->
                <StackPanel
                    Grid.Column="2"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
                    <Border
                        Margin="0,0,8,0"
                        Padding="9,5"
                        Background="#1AFFFFFF"
                        BorderBrush="{StaticResource PanelBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="9">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial
                                Width="13"
                                Height="13"
                                VerticalAlignment="Center"
                                Foreground="{DynamicResource MahApps.Brushes.Accent}"
                                Kind="Sword" />
                            <TextBlock
                                Margin="6,0,0,0"
                                VerticalAlignment="Center"
                                FontSize="11"
                                Foreground="{DynamicResource MahApps.Brushes.IdealForeground}"
                                Opacity="0.82"
                                Text="In-game" />
                        </StackPanel>
                    </Border>
                    <Border
                        Margin="0,0,8,0"
                        Padding="9,5"
                        Background="#1AFFFFFF"
                        BorderBrush="{StaticResource PanelBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="9">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial
                                Width="13"
                                Height="13"
                                VerticalAlignment="Center"
                                Foreground="{DynamicResource MahApps.Brushes.Accent}"
                                Kind="Orbit" />
                            <TextBlock
                                Margin="6,0,0,0"
                                VerticalAlignment="Center"
                                FontSize="11"
                                Foreground="{DynamicResource MahApps.Brushes.IdealForeground}"
                                Opacity="0.82"
                                Text="Orbit" />
                        </StackPanel>
                    </Border>
                    <Border
                        Padding="9,5"
                        Background="#1AFFFFFF"
                        BorderBrush="{StaticResource PanelBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="9">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial
                                Width="13"
                                Height="13"
                                VerticalAlignment="Center"
                                Foreground="{DynamicResource MahApps.Brushes.Accent}"
                                Kind="Console" />
                            <TextBlock
                                Margin="6,0,0,0"
                                VerticalAlignment="Center"
                                FontSize="11"
                                Foreground="{DynamicResource MahApps.Brushes.IdealForeground}"
                                Opacity="0.82"
                                Text="Headless" />
                        </StackPanel>
                    </Border>

                    <!--  Settings gear  -->
                    <ToggleButton
                        x:Name="SettingsButton"
                        Margin="12,0,0,0"
                        VerticalAlignment="Center"
                        IsChecked="{Binding IsSettingsOpen, Mode=TwoWay}"
                        Style="{StaticResource RailToggleButton}"
                        ToolTip="Settings">
                        <iconPacks:PackIconMaterial
                            Width="16"
                            Height="16"
                            Kind="Cog" />
                    </ToggleButton>
                    <Popup
                        AllowsTransparency="True"
                        HorizontalOffset="-180"
                        IsOpen="{Binding IsSettingsOpen, Mode=TwoWay}"
                        Placement="Bottom"
                        PlacementTarget="{Binding ElementName=SettingsButton}"
                        PopupAnimation="Fade"
                        StaysOpen="False"
                        VerticalOffset="8">
                        <Border
                            Width="280"
                            Padding="16"
                            Background="#F21B2432"
                            BorderBrush="{StaticResource EditorPrimaryBrush}"
                            BorderThickness="1.5"
                            CornerRadius="12">
                            <Border.Effect>
                                <DropShadowEffect
                                    BlurRadius="18"
                                    Opacity="0.4"
                                    ShadowDepth="3" />
                            </Border.Effect>
                            <StackPanel>
                                <StackPanel Margin="0,0,0,12" Orientation="Horizontal">
                                    <iconPacks:PackIconMaterial
                                        Width="16"
                                        Height="16"
                                        VerticalAlignment="Center"
                                        Foreground="{DynamicResource MahApps.Brushes.Accent}"
                                        Kind="Cog" />
                                    <TextBlock
                                        Margin="8,0,0,0"
                                        FontSize="15"
                                        FontWeight="SemiBold"
                                        Foreground="{DynamicResource MahApps.Brushes.IdealForeground}"
                                        Text="Settings" />
                                </StackPanel>

                                <TextBlock
                                    FontSize="12"
                                    FontWeight="SemiBold"
                                    Foreground="{DynamicResource MahApps.Brushes.IdealForeground}"
                                    Opacity="0.85"
                                    Text="Window size" />
                                <ComboBox
                                    Margin="0,6,0,0"
                                    DisplayMemberPath="DisplayLabel"
                                    ItemsSource="{Binding WindowSizeOptions}"
                                    SelectedItem="{Binding SelectedWindowSize, Mode=TwoWay}" />
                                <TextBlock
                                    Margin="0,8,0,0"
                                    FontSize="11"
                                    Foreground="{DynamicResource MahApps.Brushes.Gray7}"
                                    Text="Saved automatically and restored next session. Drag the window edges for a custom size."
                                    TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </Popup>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="{Binding DataContext.LeftColumnWidth, ElementName=Root, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" MinWidth="56" />
                <ColumnDefinition Width="6" />
                <ColumnDefinition Width="*" MinWidth="420" />
                <ColumnDefinition Width="6" />
                <ColumnDefinition Width="{Binding DataContext.RightColumnWidth, ElementName=Root, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" MinWidth="56" />
            </Grid.ColumnDefinitions>

            <Border
                Grid.Column="0"
                Padding="0"
                Style="{StaticResource PanelCard}">
                <Grid>
                  <!--  Expanded catalog: header + scrollable palette  -->
                  <Grid Visibility="{Binding IsLeftCollapsed, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Inverted}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border
                        Grid.Row="0"
                        Style="{StaticResource EditorColumnHeader}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ToggleButton
                                Grid.Column="0"
                                IsChecked="{Binding IsLeftCollapsed, Mode=TwoWay}"
                                Style="{StaticResource RailToggleButton}"
                                ToolTip="Collapse catalog">
                                <iconPacks:PackIconMaterial
                                    Width="16"
                                    Height="16"
                                    Kind="ChevronLeft" />
                            </ToggleButton>
                            <StackPanel
                                Grid.Column="1"
                                Margin="10,0,0,0"
                                VerticalAlignment="Center">
                                <TextBlock
                                    FontSize="16"
                                    FontWeight="SemiBold"
                                    Foreground="{DynamicResource MahApps.Brushes.IdealForeground}"
                                    Text="Catalog" />
                                <TextBlock
                                    FontSize="11"
                                    Foreground="{DynamicResource MahApps.Brushes.Gray7}"
                                    Text="Click to insert, or drag into the canvas" />
                            </StackPanel>
                            <Border
                                Grid.Column="2"
                                Padding="8,4"
                                Background="{StaticResource EditorPrimaryMutedBrush}"
                                CornerRadius="6">
                                <StackPanel Orientation="Horizontal">
                                    <iconPacks:PackIconMaterial
                                        Width="14"
                                        Height="14"
                                        Foreground="{DynamicResource MahApps.Brushes.Accent}"
                                        Kind="Puzzle" />
                                    <TextBlock
                                        Margin="6,0,0,0"
                                        FontSize="11"
                                        Foreground="{DynamicResource MahApps.Brushes.IdealForeground}"
                                        Opacity="0.75"
                                        Text="Nodes" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>

                    <!--  Content (hidden when collapsed)  -->
                    <Grid Grid.Row="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <!--  Pinned search + sort bar  -->
                        <Grid Grid.Row="0" Margin="16,12,16,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox
                                Grid.Column="0"
                                VerticalContentAlignment="Center"
                                mahApps:TextBoxHelper.ClearTextButton="True"
                                mahApps:TextBoxHelper.Watermark="Search nodes…"
                                Text="{Binding CatalogSearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <ComboBox
                                Grid.Column="1"
                                Width="124"
                                Margin="6,0,0,0"
                                ItemsSource="{Binding CatalogSortModes}"
                                SelectedItem="{Binding CatalogSortMode, Mode=TwoWay}"
                                ToolTip="Sort the catalog">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Converter={StaticResource CatalogSortModeLabelConverter}}" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </Grid>

                        <ScrollViewer
                            Grid.Row="1"
                            Margin="16,12,16,16"
                            VerticalScrollBarVisibility="Auto"
                            Visibility="{Binding IsLeftCollapsed, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Inverted}">
                            <StackPanel>
                                <ListBox
                                    Margin="0,0,0,10"
                                    BorderThickness="0"
                                    ItemsSource="{Binding Categories}"
                                    ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                    SelectedItem="{Binding SelectedCategory, Mode=TwoWay}">
                                    <ListBox.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel />
                                        </ItemsPanelTemplate>
                                    </ListBox.ItemsPanel>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border
                                                Margin="0,6,6,6"
                                                Padding="8,6"
                                                Background="{Binding AccentColor, Converter={StaticResource AccentBrushConverter}, ConverterParameter=Surface}"
                                                BorderBrush="{Binding AccentColor, Converter={StaticResource AccentBrushConverter}, ConverterParameter=Muted}"
                                                BorderThickness="1"
                                                CornerRadius="6">
                                                <StackPanel Orientation="Horizontal">
                                                    <Ellipse
                                                        Width="8"
                                                        Height="8"
                                                        Margin="0,0,6,0"
                                                        VerticalAlignment="Center"
                                                        Fill="{Binding AccentColor, Converter={StaticResource AccentBrushConverter}}" />
                                                    <TextBlock
                                                        FontWeight="SemiBold"
                                                        Foreground="{DynamicResource MahApps.Brushes.IdealForeground}"
                                                        Text="{Binding Title}" />
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                                <ItemsControl ItemsSource="{Binding FilteredDefinitions}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border
                                                Margin="0,0,0,10"
                                                Padding="10"
                                                Background="{DynamicResource MahApps.Brushes.Gray9}"
                                                BorderBrush="{DynamicResource MahApps.Brushes.Gray7}"
                                                BorderThickness="1"
                                                Cursor="Hand"
                                                MouseLeftButtonUp="PaletteDefinitionCard_MouseLeftButtonUp"
                                                CornerRadius="10">
                                                <StackPanel>
                                                    <StackPanel Orientation="Horizontal">
                                                        <Border
                                                            Width="22"
                                                            Height="22"
                                                            Margin="0,0,8,0"
                                                            Background="{Binding Id, Converter={StaticResource NodeVisualConverter}, ConverterParameter=SurfaceBrush}"
                                                            CornerRadius="5">
                                                            <iconPacks:PackIconMaterial
                                                                Width="14"
                                                                Height="14"
                                                                HorizontalAlignment="Center"
                                                                VerticalAlignment="Center"
                                                                Foreground="{Binding Id, Converter={StaticResource NodeVisualConverter}, ConverterParameter=Brush}"
                                                                Kind="{Binding Id, Converter={StaticResource NodeVisualConverter}, ConverterParameter=Icon}" />
                                                        </Border>
                                                        <TextBlock
                                                            VerticalAlignment="Center"
                                                            FontWeight="SemiBold"
                                                            Foreground="{DynamicResource MahApps.Brushes.IdealForeground}"
                                                            Text="{Binding Title}" />
                                                        <Border
                                                            Margin="8,0,0,0"
                                                            Padding="6,2"
                                                            Background="{DynamicResource MahApps.Brushes.Accent}"
                                                            CornerRadius="6"
                                                            Visibility="{Binding HasQuery, Converter={StaticResource BoolToVisibilityConverter}}">
                                                            <TextBlock
                                                                FontSize="10"
                                                                FontWeight="Bold"
                                                                Foreground="{DynamicResource MahApps.Brushes.AccentForeground}"
                                                                Text="Query" />
                                                        </Border>
                                                    </StackPanel>
                                                    <TextBlock
                                                        MaxHeight="54"
                                                        Margin="0,4,0,6"
                                                        Foreground="{DynamicResource MahApps.Brushes.IdealForeground}"
                                                        Opacity="0.8"
                                                        Text="{Binding ShortDescription}"
                                                        TextTrimming="CharacterEllipsis"
                                                        TextWrapping="Wrap" />
                                                    <StackPanel Orientation="Horizontal">
                                                        <Button
                                                            Command="{Binding DataContext.CreateNodeFromDefinitionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}"
                                                            Content="Add node" />
                                                        <Button
                                                            Margin="6,0,0,0"
                                                            Click="PaletteDefinitionInfoButton_Click"
                                                            Content="Info" />
                                                    </StackPanel>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </ScrollViewer>

                        <Popup
                            x:Name="NodeInfoPopup"
                            AllowsTransparency="True"
                            Closed="NodeInfoPopup_OnClosed"
                            IsOpen="{Binding IsNodeInfoOpen, Mode=TwoWay}"
                            Placement="Right"
                            PopupAnimation="Fade"
                            StaysOpen="False">
                            <Border
                                Width="380"
                                MaxHeight="520"
                                Padding="12"
                                Background="#F21B2432"
                                BorderBrush="{StaticResource EditorPrimaryBrush}"
                                BorderThickness="1.5"
                                CornerRadius="10">
                                <Border.Effect>
                                    <DropShadowEffect
                                        BlurRadius="16"
                                        Opacity="0.35"
                                        ShadowDepth="2" />
                                </Border.Effect>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock
                                        Grid.Row="0"
                                        Grid.Column="0"
                                        FontSize="15"
                                        FontWeight="SemiBold"
                                        Foreground="{DynamicResource MahApps.Brushes.IdealForeground}"
                                        Text="{Binding NodeInfoTitle}" />

                                    <Button
                                        Grid.Row="0"
                                        Grid.Column="1"
                                        Width="26"
                                        Height="26"
                                        Margin="8,0,0,0"
                                        Padding="0"
                                        Background="Transparent"
                                        BorderBrush="{StaticResource EditorPrimaryMutedBrush}"
                                        BorderThickness="1"
                                        Command="{Binding CloseNodeInfoCommand}"
                                        ToolTip="Close (Esc)">
                                        <iconPacks:PackIconMaterial
                                            Width="14"
                                            Height="14"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Kind="Close" />
                                    </Button>

                                    <TextBlock
                                        Grid.Row="1"
                                        Grid.ColumnSpan="2"
                                        Margin="0,8,0,0"
                                        Foreground="{DynamicResource MahApps.Brushes.IdealForeground}"
                                        Opacity="0.92"
                                        Text="{Binding NodeInfoDescription}"
                                        TextWrapping="Wrap" />

                                    <ScrollViewer Grid.Row="2" Grid.ColumnSpan="2" Margin="0,10,0,0" VerticalScrollBarVisibility="Auto">
                                        <ItemsControl ItemsSource="{Binding NodeInfoUsageTips}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border
                                                        Margin="0,0,0,6"
                                                        Padding="8,6"
                                                        Background="#1AFFFFFF"
                                                        CornerRadius="6">
                                                        <TextBlock
                                                            FontSize="12"
                                                            Foreground="{DynamicResource MahApps.Brushes.IdealForeground}"
                                                            Text="{Binding}"
                                                            TextWrapping="Wrap" />
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>

                                    <TextBlock
                                        Grid.Row="3"
                                        Grid.ColumnSpan="2"
                                        Margin="0,6,0,0"
                                        FontSize="11"
                                        Foreground="{DynamicResource MahApps.Brushes.IdealForeground}"
                                        Opacity="0.72"
                                        Text="Click another catalog item to move this info panel near that item."
                                        TextWrapping="Wrap" />
                                </Grid>
                            </Border>
                        </Popup>
                    </Grid>
                  </Grid>

                  <!--  Collapsed catalog rail  -->
                  <Border
                      Background="{StaticResource RailSurfaceBrush}"
                      CornerRadius="13"
                      Visibility="{Binding IsLeftCollapsed, Converter={StaticResource BoolToVisibilityConverter}}">
                      <Grid Margin="0,14">
                          <Grid.RowDefinitions>
                              <RowDefinition Height="Auto" />
                              <RowDefinition Height="*" />
                              <RowDefinition Height="Auto" />
                          </Grid.RowDefinitions>
                          <ToggleButton
                              Grid.Row="0"
                              HorizontalAlignment="Center"
                              IsChecked="{Binding IsLeftCollapsed, Mode=TwoWay}"
                              Style="{StaticResource RailToggleButton}"
                              ToolTip="Expand catalog">
                              <iconPacks:PackIconMaterial
                                  Width="16"
                                  Height="16"
                                  Kind="ChevronRight" />
                          </ToggleButton>
                          <TextBlock
                              Grid.Row="1"
                              Margin="0,16"
                              VerticalAlignment="Center"
                              Style="{StaticResource RailCaption}"
                              Text="CATALOG" />
                          <Border
                              Grid.Row="2"
                              Width="32"
                              Height="32"
                              HorizontalAlignment="Center"
                              Background="{StaticResource EditorPrimaryMutedBrush}"
                              CornerRadius="9">
                              <iconPacks:PackIconMaterial
                                  Width="16"
                                  Height="16"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  Foreground="{DynamicResource MahApps.Brushes.Accent}"
                                  Kind="Puzzle" />
                          </Border>
                      </Grid>
                  </Border>
                </Grid>
            </Border>

            <GridSplitter
                Grid.Column="1"
                Width="6"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                Background="{StaticResource EditorPrimaryMutedBrush}"
                ResizeBehavior="PreviousAndNext"
                ResizeDirection="Columns"
                ShowsPreview="True"
                Visibility="{Binding IsLeftCollapsed, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Inverted}" />

            <Border
                Grid.Column="2"
                Padding="0"
                Style="{StaticResource PanelCard}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border
                        Grid.Row="0"
                        Style="{StaticResource EditorColumnHeader}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center" Orientation="Horizontal">
                                <Border
                                    Width="28"
                                    Height="28"
                                    Background="{StaticResource EditorPrimaryMutedBrush}"
                                    CornerRadius="6">
                                    <iconPacks:PackIconMaterial
                                        Width="18"
                                        Height="18"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Foreground="{DynamicResource MahApps.Brushes.Accent}"
                                        Kind="Graph" />
                                </Border>
                                <StackPanel Margin="8,0,0,0">
                                    <TextBlock
                                        FontSize="16"
                                        FontWeight="SemiBold"
                                        Foreground="{DynamicResource MahApps.Brushes.IdealForeground}"
                                        Text="Canvas" />
                                    <TextBlock
                                        FontSize="11"
                                        Foreground="{DynamicResource MahApps.Brushes.Gray7}"
                                        Text="Run, step, or edit nodes inline" />
                                </StackPanel>
                            </StackPanel>

                            <StackPanel
                                Grid.Column="1"
                                Margin="12,0,0,0"
                                VerticalAlignment="Center"
                                Orientation="Horizontal">
                                <!--  Transport group  -->
                                <Border
                                    Padding="4"
                                    Background="#22000000"
                                    BorderBrush="{StaticResource PanelBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="9">
                                    <StackPanel Orientation="Horizontal">
                                        <Button
                                            Command="{Binding StartCommand}"
                                            Style="{StaticResource ToolbarRunButton}"
                                            ToolTip="Validate and run the graph — respects the Loop toggle (F5)">
                                            <Button.Content>
                                                <StackPanel Orientation="Horizontal">
                                                    <iconPacks:PackIconMaterial
                                                        Width="14"
                                                        Height="14"
                                                        Kind="Play" />
                                                    <TextBlock Margin="6,0,0,0" Text="Run" />
                                                </StackPanel>
                                            </Button.Content>
                                        </Button>
                                        <Button
                                            Margin="4,0,0,0"
                                            Command="{Binding StepCommand}"
                                            Style="{StaticResource ToolbarButton}"
                                            ToolTip="Run a single pass through the graph without looping (Ctrl+F5)">
                                            <Button.Content>
                                                <StackPanel Orientation="Horizontal">
                                                    <iconPacks:PackIconMaterial
                                                        Width="14"
                                                        Height="14"
                                                        Kind="SkipNext" />
                                                    <TextBlock Margin="6,0,0,0" Text="Run Once" />
                                                </StackPanel>
                                            </Button.Content>
                                        </Button>
                                        <Button
                                            Margin="4,0,0,0"
                                            Command="{Binding StopCommand}"
                                            Style="{StaticResource ToolbarStopButton}"
                                            ToolTip="Stop the running graph (Shift+F5)">
                                            <Button.Content>
                                                <StackPanel Orientation="Horizontal">
                                                    <iconPacks:PackIconMaterial
                                                        Width="14"
                                                        Height="14"
                                                        Kind="Stop" />
                                                    <TextBlock Margin="6,0,0,0" Text="Stop" />
                                                </StackPanel>
                                            </Button.Content>
                                        </Button>
                                    </StackPanel>
                                </Border>

                                <Button
                                    Margin="8,0,0,0"
                                    Command="{Binding DeleteSelectedCommand}"
                                    Style="{StaticResource ToolbarDeleteButton}"
                                    ToolTip="Delete selected nodes (Del)">
                                    <Button.Content>
                                        <StackPanel Orientation="Horizontal">
                                            <iconPacks:PackIconMaterial
                                                Width="14"
                                                Height="14"
                                                Kind="Delete" />
                                            <TextBlock Margin="6,0,0,0" Text="Delete" />
                                        </StackPanel>
                                    </Button.Content>
                                </Button>

                                <Border
                                    Margin="8,0,0,0"
                                    Padding="8,3"
                                    Background="#22000000"
                                    BorderBrush="{StaticResource PanelBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="9">
                                    <controls:ToggleSwitch
                                        VerticalAlignment="Center"
                                        Header="Loop"
                                        IsOn="{Binding IsLooping}"
                                        OffContent=""
                                        OnContent="" />
                                </Border>
                            </StackPanel>

                            <StackPanel
                                Grid.Column="2"
                                VerticalAlignment="Center"
                                Orientation="Horizontal">
                                <Border
                                    Margin="0,0,8,0"
                                    Padding="6,2"
                                    Background="{StaticResource EditorPrimaryMutedBrush}"
                                    CornerRadius="4"
                                    ToolTip="Hold Space or Middle Mouse to pan the canvas">
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial
                                            Width="12"
                                            Height="12"
                                            Kind="CursorMove"
                                            Opacity="0.7" />
                                        <TextBlock
                                            Margin="4,0,0,0"
                                            FontSize="11"
                                            Foreground="{DynamicResource MahApps.Brushes.IdealForeground}"
                                            Opacity="0.7"
                                            Text="Space to pan" />
                                    </StackPanel>
                                </Border>
                                <Border
                                    Margin="0,0,12,0"
                                    Padding="4,2"
                                    Background="{StaticResource EditorPrimaryMutedBrush}"
                                    CornerRadius="4"
                                    ToolTip="Use Ctrl+Scroll to zoom, or click buttons">
                                    <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                                        <Button
                                            x:Name="ZoomOutButton"
                                            Padding="4,2"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Click="ZoomOutButton_Click">
                                            <iconPacks:PackIconMaterial
                                                Width="14"
                                                Height="14"
                                                Kind="MagnifyMinus" />
                                        </Button>
                                        <TextBlock
                                            x:Name="ZoomLevelText"
                                            Width="44"
                                            VerticalAlignment="Center"
                                            FontSize="11"
                                            Foreground="{DynamicResource MahApps.Brushes.IdealForeground}"
                                            Text="100%"
                                            TextAlignment="Center" />
                                        <Button
                                            x:Name="ZoomInButton"
                                            Padding="4,2"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Click="ZoomInButton_Click">
                                            <iconPacks:PackIconMaterial
                                                Width="14"
                                                Height="14"
                                                Kind="MagnifyPlus" />
                                        </Button>
                                        <Button
                                            x:Name="ZoomResetButton"
                                            Margin="4,0,0,0"
                                            Padding="4,2"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Click="ZoomResetButton_Click"
                                            ToolTip="Reset zoom to 100%">
                                            <iconPacks:PackIconMaterial
                                                Width="14"
                                                Height="14"
                                                Kind="MagnifyRemoveOutline" />
                                        </Button>
                                    </StackPanel>
                                </Border>
                                <Border
                                    Margin="0,0,8,0"
                                    Padding="8,4"
                                    VerticalAlignment="Center"
                                    Background="#33FFC857"
                                    BorderBrush="#66FFC857"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    ToolTip="The graph has changes that are not saved to disk yet (Ctrl+S)"
                                    Visibility="{Binding IsDirty, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial
                                            Width="12"
                                            Height="12"
                                            VerticalAlignment="Center"
                                            Foreground="#FFC857"
                                            Kind="ContentSaveAlert" />
                                        <TextBlock
                                            Margin="6,0,0,0"
                                            VerticalAlignment="Center"
                                            FontSize="11"
                                            Foreground="#FFC857"
                                            Text="Unsaved" />
                                    </StackPanel>
                                </Border>
                                <Border
                                    Padding="8,4"
                                    VerticalAlignment="Center"
                                    Background="{StaticResource EditorPrimarySurfaceBrush}"
                                    BorderBrush="{StaticResource EditorPrimaryMutedBrush}"
                                    BorderThickness="1"
                                    CornerRadius="6">
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial
                                            Width="12"
                                            Height="12"
                                            VerticalAlignment="Center"
                                            Foreground="{DynamicResource MahApps.Brushes.Accent}"
                                            Kind="InformationOutline" />
                                        <TextBlock
                                            Margin="6,0,0,0"
                                            MaxWidth="260"
                                            VerticalAlignment="Center"
                                            Foreground="{DynamicResource MahApps.Brushes.Accent}"
                                            Text="{Binding Status}"
                                            TextTrimming="CharacterEllipsis"
                                            ToolTip="{Binding Status}" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border
                        Grid.Row="1"
                        ClipToBounds="True"
                        CornerRadius="0,0,13,13">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Offset="0" Color="#1a1f2a" />
                                <GradientStop Offset="1" Color="#11151e" />
                            </LinearGradientBrush>
                        </Border.Background>

                        <ScrollViewer
                            x:Name="CanvasScrollViewer"
                            Margin="8"
                            HorizontalScrollBarVisibility="Auto"
                            PanningMode="Both"
                            PreviewMouseDown="CanvasScrollViewer_OnPreviewMouseDown"
                            PreviewMouseMove="CanvasScrollViewer_OnPreviewMouseMove"
                            PreviewMouseUp="CanvasScrollViewer_OnPreviewMouseUp"
                            PreviewMouseWheel="CanvasScrollViewer_OnPreviewMouseWheel"
                            VerticalScrollBarVisibility="Auto">
                            <Grid
                                x:Name="CanvasContainer"
                                MinWidth="2000"
                                MinHeight="1500">
                                <Grid.Background>
                                    <!--  Cache the rasterized dot tile so panning/zooming/dragging over the 2000x1500
                                          canvas doesn't re-tile thousands of dots every render pass.  -->
                                    <DrawingBrush
                                        RenderOptions.CachingHint="Cache"
                                        TileMode="Tile"
                                        Viewport="0,0,24,24"
                                        ViewportUnits="Absolute">
                                        <DrawingBrush.Drawing>
                                            <GeometryDrawing Brush="#1FFFFFFF">
                                                <GeometryDrawing.Geometry>
                                                    <EllipseGeometry
                                                        Center="2,2"
                                                        RadiusX="1"
                                                        RadiusY="1" />
                                                </GeometryDrawing.Geometry>
                                            </GeometryDrawing>
                                        </DrawingBrush.Drawing>
                                    </DrawingBrush>
                                </Grid.Background>
                                <Grid.LayoutTransform>
                                    <ScaleTransform x:Name="CanvasScaleTransform" ScaleX="1" ScaleY="1" />
                                </Grid.LayoutTransform>
                                <ItemsControl IsHitTestVisible="False" ItemsSource="{Binding AllTransitions}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <Canvas />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Path StrokeDashCap="Round" StrokeThickness="2.5">
                                                <Path.Data>
                                                    <MultiBinding Converter="{StaticResource NodeConnectorConverter}">
                                                        <Binding Path="FromNodeId" />
                                                        <Binding Path="ToNodeId" />
                                                        <Binding Path="DataContext.Script.Nodes" RelativeSource="{RelativeSource AncestorType=UserControl}" />
                                                        <Binding />
                                                    </MultiBinding>
                                                </Path.Data>
                                                <Path.Style>
                                                    <Style TargetType="Path">
                                                        <Setter Property="Stroke" Value="{DynamicResource MahApps.Brushes.Gray7}" />
                                                        <Setter Property="Opacity" Value="0.55" />
                                                        <Setter Property="StrokeDashArray" Value="2 1" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                                <Setter Property="Stroke" Value="#6EE86E" />
                                                                <Setter Property="Opacity" Value="0.95" />
                                                                <Setter Property="StrokeDashArray" Value="1" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Path.Style>
                                            </Path>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <ItemsControl x:Name="NodeCanvas" ItemsSource="{Binding Script.Nodes}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <Canvas x:Name="NodeCanvasPanel" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemContainerStyle>
                                        <Style TargetType="ContentPresenter">
                                            <Setter Property="Canvas.Left" Value="{Binding X}" />
                                            <Setter Property="Canvas.Top" Value="{Binding Y}" />
                                        </Style>
                                    </ItemsControl.ItemContainerStyle>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Thumb
                                                DragDelta="NodeDragDelta"
                                                DragStarted="NodeDragStarted"
                                                MouseLeftButtonDown="NodeMouseDown"
                                                PreviewMouseLeftButtonDown="NodeMouseDown"
                                                Tag="{Binding}">
                                                <Thumb.Template>
                                                    <ControlTemplate TargetType="Thumb">
                                                        <Grid>
                                                        <!--  234 = 220 card + 7px port overhang per side; NodeConnectorConverter anchors depend on this.  -->
                                                        <Border
                                                            Width="240"
                                                            Padding="3"
                                                            BorderBrush="Transparent"
                                                            BorderThickness="2"
                                                            CornerRadius="15"
                                                            Visibility="{Binding DefinitionId, Converter={StaticResource DefinitionIdVisibilityConverter}, ConverterParameter=ui.scriptDashboard|Invert}">
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Setter Property="BorderBrush" Value="Transparent" />
                                                                    <Setter Property="Effect" Value="{x:Null}" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsCurrent}" Value="True">
                                                                            <Setter Property="BorderBrush" Value="#9FFF9F" />
                                                                            <Setter Property="Effect">
                                                                                <Setter.Value>
                                                                                    <DropShadowEffect
                                                                                        BlurRadius="26"
                                                                                        Color="#FF6EE86E"
                                                                                        Opacity="0.8"
                                                                                        ShadowDepth="0" />
                                                                                </Setter.Value>
                                                                            </Setter>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                        <Grid Width="234">
                                                        <Border
                                                            Margin="7,0"
                                                            MinHeight="130"
                                                            Padding="10"
                                                            Background="{DynamicResource MahApps.Brushes.Gray10}"
                                                            BorderBrush="{DynamicResource MahApps.Brushes.Gray6}"
                                                            BorderThickness="2"
                                                            CornerRadius="12"
                                                            Effect="{StaticResource NodeShadow}">
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Setter Property="Background" Value="{DynamicResource MahApps.Brushes.Gray10}" />
                                                                    <Setter Property="BorderBrush" Value="{StaticResource EditorPrimaryMutedBrush}" />
                                                                    <Setter Property="BorderThickness" Value="2" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                                            <Setter Property="Background">
                                                                                <Setter.Value>
                                                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                                                        <GradientStop Offset="0" Color="#2f8f3f" />
                                                                                        <GradientStop Offset="1" Color="#1f6a2e" />
                                                                                    </LinearGradientBrush>
                                                                                </Setter.Value>
                                                                            </Setter>
                                                                            <Setter Property="BorderBrush" Value="#6EE86E" />
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding LastRunStatus}" Value="{x:Static models:NodeRunStatus.Fail}">
                                                                            <Setter Property="BorderBrush" Value="#E86E6E" />
                                                                            <Setter Property="Background">
                                                                                <Setter.Value>
                                                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                                                        <GradientStop Offset="0" Color="#8f2f2f" />
                                                                                        <GradientStop Offset="1" Color="#6a1f1f" />
                                                                                    </LinearGradientBrush>
                                                                                </Setter.Value>
                                                                            </Setter>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding Type}" Value="{x:Static models:NodeType.Start}">
                                                                            <Setter Property="BorderBrush" Value="{StaticResource EditorPrimaryBrush}" />
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                            <Setter Property="BorderBrush" Value="{StaticResource EditorPrimaryBrush}" />
                                                                            <Setter Property="BorderThickness" Value="4" />
                                                                            <Setter Property="Effect">
                                                                                <Setter.Value>
                                                                                    <DropShadowEffect
                                                                                        BlurRadius="18"
                                                                                        Color="#FF4AB6FF"
                                                                                        Opacity="0.4"
                                                                                        ShadowDepth="0" />
                                                                                </Setter.Value>
                                                                            </Setter>
                                                                        </DataTrigger>
                                                                        <!--  Currently executing node wins over every other state.  -->
                                                                        <DataTrigger Binding="{Binding IsCurrent}" Value="True">
	                                                                            <Setter Property="BorderBrush" Value="#9FFF9F" />
	                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>

                                                            <Grid>
                                                                <!--  Header/description rows are fixed so transition port anchors stay deterministic (see NodeConnectorConverter.OutPortFirstY).  -->
                                                                <Grid.RowDefinitions>
                                                                    <RowDefinition Height="34" />
                                                                    <RowDefinition Height="40" />
                                                                    <RowDefinition Height="Auto" />
                                                                    <RowDefinition Height="Auto" />
                                                                </Grid.RowDefinitions>

                                                                <Border
                                                                    Grid.RowSpan="4"
                                                                    Width="4"
                                                                    Margin="-6,-2,0,-2"
                                                                    HorizontalAlignment="Left"
                                                                    Background="{Binding DefinitionId, Converter={StaticResource NodeVisualConverter}, ConverterParameter=Brush}"
                                                                    CornerRadius="2" />

                                                                <Grid>
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="Auto" />
                                                                        <ColumnDefinition Width="*" />
                                                                        <ColumnDefinition Width="Auto" />
                                                                    </Grid.ColumnDefinitions>
                                                                    <Border
                                                                        Grid.Column="0"
                                                                        Width="24"
                                                                        Height="24"
                                                                        Background="{Binding DefinitionId, Converter={StaticResource NodeVisualConverter}, ConverterParameter=SurfaceBrush}"
                                                                        CornerRadius="4">
                                                                        <iconPacks:PackIconMaterial
                                                                            Width="16"
                                                                            Height="16"
                                                                            HorizontalAlignment="Center"
                                                                            VerticalAlignment="Center"
                                                                            Foreground="{Binding DefinitionId, Converter={StaticResource NodeVisualConverter}, ConverterParameter=Brush}"
                                                                            Kind="{Binding DefinitionId, Converter={StaticResource NodeVisualConverter}, ConverterParameter=Icon}" />
                                                                    </Border>
                                                                    <StackPanel
                                                                        Grid.Column="1"
                                                                        Margin="6,0,0,0"
                                                                        Orientation="Vertical">
                                                                        <TextBlock
                                                                            FontWeight="SemiBold"
                                                                            Foreground="{DynamicResource MahApps.Brushes.IdealForeground}"
                                                                            Text="{Binding Title}" />
                                                                        <TextBlock
                                                                            FontSize="11"
                                                                            Foreground="{DynamicResource MahApps.Brushes.IdealForeground}"
                                                                            Opacity="0.7"
                                                                            Text="{Binding DefinitionTitle}" />
                                                                    </StackPanel>
                                                                    <Border
                                                                        Grid.Column="2"
                                                                        Padding="6,2"
                                                                        HorizontalAlignment="Right"
                                                                        Background="{DynamicResource MahApps.Brushes.Accent}"
                                                                        CornerRadius="4">
                                                                        <Border.Visibility>
                                                                            <MultiBinding Converter="{StaticResource EqualityToVisibilityConverter}">
                                                                                <Binding Path="Id" />
                                                                                <Binding Path="DataContext.Script.StartNodeId" RelativeSource="{RelativeSource AncestorType=UserControl}" />
                                                                            </MultiBinding>
                                                                        </Border.Visibility>
                                                                        <TextBlock
                                                                            FontSize="10"
                                                                            FontWeight="Bold"
                                                                            Foreground="{DynamicResource MahApps.Brushes.AccentForeground}"
                                                                            Text="Start" />
                                                                    </Border>
                                                                </Grid>

                                                                <TextBlock
                                                                    Grid.Row="1"
                                                                    Margin="0,6,0,0"
                                                                    VerticalAlignment="Top"
                                                                    Foreground="{DynamicResource MahApps.Brushes.IdealForeground}"
                                                                    Opacity="0.8"
                                                                    Text="{Binding Description}"
                                                                    TextTrimming="CharacterEllipsis"
                                                                    TextWrapping="Wrap"
                                                                    ToolTip="{Binding Description}" />

                                                                <!--  Transition out-ports: one labeled row per edge; row order = evaluation priority.
                                                                      Row height must match NodeConnectorConverter.OutPortRowHeight.  -->
                                                                <StackPanel Grid.Row="2" Margin="0,4,0,0">
                                                                    <ItemsControl ItemsSource="{Binding Transitions}">
                                                                        <ItemsControl.ItemTemplate>
                                                                            <DataTemplate>
                                                                                <Grid Height="22" Background="Transparent">
                                                                                    <TextBlock
                                                                                        Margin="0,0,4,0"
                                                                                        HorizontalAlignment="Right"
                                                                                        VerticalAlignment="Center"
                                                                                        FontSize="10"
                                                                                        Foreground="{DynamicResource MahApps.Brushes.IdealForeground}"
                                                                                        Opacity="0.85"
                                                                                        TextTrimming="CharacterEllipsis">
                                                                                        <TextBlock.Text>
                                                                                            <MultiBinding Converter="{StaticResource TransitionPortLabelConverter}">
                                                                                                <Binding Path="Trigger" />
                                                                                                <Binding Path="ConditionKey" />
                                                                                                <Binding Path="ExpectedValue" />
                                                                                                <Binding Path="IsFallback" />
                                                                                                <Binding Path="Label" />
                                                                                            </MultiBinding>
                                                                                        </TextBlock.Text>
                                                                                    </TextBlock>
                                                                                    <Ellipse
                                                                                        Width="14"
                                                                                        Height="14"
                                                                                        Margin="0,0,-19,0"
                                                                                        HorizontalAlignment="Right"
                                                                                        VerticalAlignment="Center"
                                                                                        Cursor="Hand"
                                                                                        Fill="{Binding DataContext.DefinitionId, RelativeSource={RelativeSource AncestorType=Thumb}, Converter={StaticResource NodeVisualConverter}, ConverterParameter=Brush}"
                                                                                        PreviewMouseLeftButtonDown="TransitionPort_OnMouseDown"
                                                                                        Stroke="{DynamicResource MahApps.Brushes.Gray9}"
                                                                                        StrokeThickness="1.5"
                                                                                        ToolTip="Drag to retarget this transition; click to edit its criteria in the inspector" />
                                                                                </Grid>
                                                                            </DataTemplate>
                                                                        </ItemsControl.ItemTemplate>
                                                                    </ItemsControl>
                                                                    <Grid Height="20" Background="Transparent">
                                                                        <TextBlock
                                                                            Margin="0,0,4,0"
                                                                            HorizontalAlignment="Right"
                                                                            VerticalAlignment="Center"
                                                                            FontSize="10"
                                                                            Foreground="{DynamicResource MahApps.Brushes.IdealForeground}"
                                                                            Opacity="0.5"
                                                                            Text="new" />
                                                                        <Ellipse
                                                                            Width="14"
                                                                            Height="14"
                                                                            Margin="0,0,-19,0"
                                                                            HorizontalAlignment="Right"
                                                                            VerticalAlignment="Center"
                                                                            Cursor="Hand"
                                                                            Fill="{DynamicResource MahApps.Brushes.Gray9}"
                                                                            Opacity="0.7"
                                                                            PreviewMouseLeftButtonDown="OutPort_OnMouseDown"
                                                                            Stroke="{Binding DefinitionId, Converter={StaticResource NodeVisualConverter}, ConverterParameter=Brush}"
                                                                            StrokeDashArray="2 1"
                                                                            StrokeThickness="1.5"
                                                                            ToolTip="Drag to another node to add a transition" />
                                                                    </Grid>
                                                                </StackPanel>

                                                                <StackPanel Grid.Row="3" Orientation="Horizontal">
                                                                    <Border
                                                                        Padding="6,2"
                                                                        Background="{Binding DefinitionId, Converter={StaticResource NodeVisualConverter}, ConverterParameter=SurfaceBrush}"
                                                                        CornerRadius="4">
                                                                        <TextBlock
                                                                            FontSize="10"
                                                                            FontWeight="SemiBold"
                                                                            Foreground="{Binding DefinitionId, Converter={StaticResource NodeVisualConverter}, ConverterParameter=Brush}"
                                                                            Text="{Binding DefinitionId, Converter={StaticResource NodeVisualConverter}, ConverterParameter=CategoryTitle}" />
                                                                    </Border>
                                                                    <TextBlock
                                                                        Margin="8,0,0,0"
                                                                        VerticalAlignment="Center"
                                                                        FontSize="11"
                                                                        Foreground="{DynamicResource MahApps.Brushes.IdealForeground}"
                                                                        Opacity="0.8"
                                                                        Text="{Binding ActionText}"
                                                                        TextWrapping="Wrap" />
                                                                    <Border
                                                                        Margin="8,0,0,0"
                                                                        Padding="6,2"
                                                                        Background="{DynamicResource MahApps.Brushes.Gray8}"
                                                                        CornerRadius="4">
                                                                        <TextBlock
                                                                            FontSize="10"
                                                                            Foreground="{DynamicResource MahApps.Brushes.IdealForeground}"
                                                                            Opacity="0.8"
                                                                            Text="{Binding DwellMilliseconds, StringFormat={}{0} ms}" />
                                                                    </Border>
                                                                </StackPanel>
                                                            </Grid>
                                                        </Border>

                                                        <!--  In-port (transition target). Center must match NodeConnectorConverter.InPortX/PortY.  -->
                                                        <Ellipse
                                                            Width="14"
                                                            Height="14"
                                                            Margin="0,24,0,0"
                                                            HorizontalAlignment="Left"
                                                            VerticalAlignment="Top"
                                                            Fill="{DynamicResource MahApps.Brushes.Gray9}"
                                                            IsHitTestVisible="False"
                                                            Stroke="{Binding DefinitionId, Converter={StaticResource NodeVisualConverter}, ConverterParameter=Brush}"
                                                            StrokeThickness="1.5" />

                                                        </Grid>
                                                        </Border>
                                                        <Border
                                                            Width="520"
                                                            MinHeight="120"
                                                            Padding="12"
                                                            Background="#EE101620"
                                                            BorderBrush="{Binding DefinitionId, Converter={StaticResource NodeVisualConverter}, ConverterParameter=Brush}"
                                                            BorderThickness="1.5"
                                                            CornerRadius="8"
                                                            Effect="{StaticResource NodeShadow}"
                                                            Visibility="{Binding DefinitionId, Converter={StaticResource DefinitionIdVisibilityConverter}, ConverterParameter=ui.scriptDashboard}">
                                                            <Grid>
                                                                <Grid.RowDefinitions>
                                                                    <RowDefinition Height="Auto" />
                                                                    <RowDefinition Height="Auto" />
                                                                </Grid.RowDefinitions>

                                                                <Grid>
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="Auto" />
                                                                        <ColumnDefinition Width="*" />
                                                                        <ColumnDefinition Width="Auto" />
                                                                    </Grid.ColumnDefinitions>
                                                                    <Border
                                                                        Width="30"
                                                                        Height="30"
                                                                        Background="{Binding DefinitionId, Converter={StaticResource NodeVisualConverter}, ConverterParameter=SurfaceBrush}"
                                                                        CornerRadius="6">
                                                                        <iconPacks:PackIconMaterial
                                                                            Width="18"
                                                                            Height="18"
                                                                            HorizontalAlignment="Center"
                                                                            VerticalAlignment="Center"
                                                                            Foreground="{Binding DefinitionId, Converter={StaticResource NodeVisualConverter}, ConverterParameter=Brush}"
                                                                            Kind="{Binding DefinitionId, Converter={StaticResource NodeVisualConverter}, ConverterParameter=Icon}" />
                                                                    </Border>
                                                                    <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                                                        <TextBlock
                                                                            FontSize="15"
                                                                            FontWeight="SemiBold"
                                                                            Foreground="{DynamicResource MahApps.Brushes.IdealForeground}"
                                                                            Text="{Binding Title}" />
                                                                        <TextBlock
                                                                            FontSize="10"
                                                                            Foreground="{DynamicResource MahApps.Brushes.Gray6}"
                                                                            Text="{Binding ActionText}"
                                                                            TextTrimming="CharacterEllipsis" />
                                                                    </StackPanel>
                                                                    <Border
                                                                        Grid.Column="2"
                                                                        Padding="7,3"
                                                                        Background="{Binding DefinitionId, Converter={StaticResource NodeVisualConverter}, ConverterParameter=SurfaceBrush}"
                                                                        CornerRadius="5">
                                                                        <TextBlock
                                                                            FontSize="10"
                                                                            FontWeight="SemiBold"
                                                                            Foreground="{Binding DefinitionId, Converter={StaticResource NodeVisualConverter}, ConverterParameter=Brush}"
                                                                            Text="Canvas UI" />
                                                                    </Border>
                                                                </Grid>

                                                                <TabControl
                                                                    Grid.Row="1"
                                                                    Height="310"
                                                                    Margin="0,12,0,0"
                                                                    Background="Transparent"
                                                                    BorderThickness="0"
                                                                    Visibility="{Binding Converter={StaticResource NodeParameterBoolConverter}, ConverterParameter=collapsed|Invert|Visibility}">
                                                                    <TabItem Header="Runtime" Style="{StaticResource DashboardTabItem}">
                                                                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                                                                            <StackPanel Margin="0,8,0,0">
                                                                                <UniformGrid Columns="3">
                                                                                    <Border Style="{StaticResource DashboardMetricCard}">
                                                                                        <StackPanel>
                                                                                            <TextBlock Style="{StaticResource DashboardMetricLabel}" Text="Runtime" />
                                                                                            <TextBlock Style="{StaticResource DashboardMetricValue}" Text="{Binding DataContext.DashboardRuntime, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                                                                                        </StackPanel>
                                                                                    </Border>
                                                                                    <Border Style="{StaticResource DashboardMetricCard}">
                                                                                        <StackPanel>
                                                                                            <TextBlock Style="{StaticResource DashboardMetricLabel}" Text="Mode" />
                                                                                            <TextBlock Style="{StaticResource DashboardMetricValue}" Text="{Binding DataContext.DashboardRunMode, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                                                                                        </StackPanel>
                                                                                    </Border>
                                                                                    <Border Style="{StaticResource DashboardMetricCard}">
                                                                                        <StackPanel>
                                                                                            <TextBlock Style="{StaticResource DashboardMetricLabel}" Text="Current node" />
                                                                                            <TextBlock Style="{StaticResource DashboardMetricValue}" Text="{Binding DataContext.DashboardCurrentNode, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                                                                                        </StackPanel>
                                                                                    </Border>
                                                                                    <Border Style="{StaticResource DashboardMetricCard}">
                                                                                        <StackPanel>
                                                                                            <TextBlock Style="{StaticResource DashboardMetricLabel}" Text="Graph" />
                                                                                            <TextBlock Style="{StaticResource DashboardMetricValue}" Text="{Binding DataContext.DashboardGraphSummary, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                                                                                        </StackPanel>
                                                                                    </Border>
                                                                                    <Border Style="{StaticResource DashboardMetricCard}">
                                                                                        <StackPanel>
                                                                                            <TextBlock Style="{StaticResource DashboardMetricLabel}" Text="Signals" />
                                                                                            <TextBlock Style="{StaticResource DashboardMetricValue}" Text="{Binding DataContext.DashboardSignalSummary, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                                                                                        </StackPanel>
                                                                                    </Border>
                                                                                    <Border Style="{StaticResource DashboardMetricCard}">
                                                                                        <StackPanel>
                                                                                            <TextBlock Style="{StaticResource DashboardMetricLabel}" Text="Updated" />
                                                                                            <TextBlock Style="{StaticResource DashboardMetricValue}" Text="{Binding DataContext.DashboardLastUpdated, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                                                                                        </StackPanel>
                                                                                    </Border>
                                                                                </UniformGrid>
                                                                                <Border
                                                                                    Margin="0,4,0,0"
                                                                                    Padding="10"
                                                                                    Background="#24101824"
                                                                                    BorderBrush="{StaticResource EditorPrimaryMutedBrush}"
                                                                                    BorderThickness="1"
                                                                                    CornerRadius="6">
                                                                                    <TextBlock
                                                                                        Foreground="{DynamicResource MahApps.Brushes.IdealForeground}"
                                                                                        Text="{Binding DataContext.Status, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                                        TextWrapping="Wrap" />
                                                                                </Border>
                                                                            </StackPanel>
                                                                        </ScrollViewer>
                                                                    </TabItem>
                                                                    <TabItem Header="XP" Style="{StaticResource DashboardTabItem}">
                                                                        <Grid Margin="0,8,0,0">
                                                                            <Grid.RowDefinitions>
                                                                                <RowDefinition Height="Auto" />
                                                                                <RowDefinition Height="*" />
                                                                            </Grid.RowDefinitions>
                                                                            <Border
                                                                                Margin="0,0,0,8"
                                                                                Padding="8"
                                                                                Background="#24101824"
                                                                                BorderBrush="{StaticResource EditorPrimaryMutedBrush}"
                                                                                BorderThickness="1"
                                                                                CornerRadius="6">
                                                                                <Grid>
                                                                                    <Grid.ColumnDefinitions>
                                                                                        <ColumnDefinition Width="*" />
                                                                                        <ColumnDefinition Width="Auto" />
                                                                                        <ColumnDefinition Width="Auto" />
                                                                                        <ColumnDefinition Width="Auto" />
                                                                                    </Grid.ColumnDefinitions>
                                                                                    <TextBlock
                                                                                        VerticalAlignment="Center"
                                                                                        Foreground="{DynamicResource MahApps.Brushes.IdealForeground}"
                                                                                        Text="{Binding DataContext.DashboardXpStatus, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                                        TextTrimming="CharacterEllipsis" />
                                                                                    <TextBlock
                                                                                        Grid.Column="1"
                                                                                        Margin="12,0,0,0"
                                                                                        VerticalAlignment="Center"
                                                                                        FontFamily="Consolas"
                                                                                        Foreground="{DynamicResource MahApps.Brushes.IdealForeground}"
                                                                                        Text="{Binding DataContext.DashboardTotalXpGained, RelativeSource={RelativeSource AncestorType=UserControl}, StringFormat=Gained {0:N0}}" />
                                                                                    <TextBlock
                                                                                        Grid.Column="2"
                                                                                        Margin="12,0,0,0"
                                                                                        VerticalAlignment="Center"
                                                                                        FontFamily="Consolas"
                                                                                        Foreground="{DynamicResource MahApps.Brushes.IdealForeground}"
                                                                                        Text="{Binding DataContext.DashboardActiveSkillCount, RelativeSource={RelativeSource AncestorType=UserControl}, StringFormat=Active {0}}" />
                                                                                    <mahApps:ToggleSwitch
                                                                                        Grid.Column="3"
                                                                                        Margin="14,0,0,0"
                                                                                        VerticalAlignment="Center"
                                                                                        Header="Active only"
                                                                                        IsOn="{Binding DataContext.DashboardXpActiveOnly, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=TwoWay}"
                                                                                        OffContent=""
                                                                                        OnContent="" />
                                                                                </Grid>
                                                                            </Border>
                                                                            <DataGrid
                                                                                Grid.Row="1"
                                                                                ItemsSource="{Binding DataContext.DashboardSkillsView, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                                Style="{StaticResource DashboardDataGrid}">
                                                                                <DataGrid.Columns>
                                                                                    <DataGridTextColumn
                                                                                        Width="*"
                                                                                        Binding="{Binding Name}"
                                                                                        Header="Skill" />
                                                                                    <DataGridTextColumn Binding="{Binding Level}" Header="Lvl" />
                                                                                    <DataGridTextColumn Binding="{Binding Xp, StringFormat=N0}" Header="XP" />
                                                                                    <DataGridTextColumn Binding="{Binding XpGained, StringFormat=N0}" Header="Gained" />
                                                                                    <DataGridTextColumn Binding="{Binding XpPerHour, StringFormat=N0}" Header="XP/hr" />
                                                                                    <DataGridTextColumn Binding="{Binding XpToNext, StringFormat=N0}" Header="To next" />
                                                                                    <DataGridTextColumn Binding="{Binding Eta}" Header="ETA" />
                                                                                </DataGrid.Columns>
                                                                            </DataGrid>
                                                                        </Grid>
                                                                    </TabItem>
                                                                    <TabItem Header="Items" Style="{StaticResource DashboardTabItem}">
                                                                        <Grid Margin="0,8,0,0">
                                                                            <Grid.RowDefinitions>
                                                                                <RowDefinition Height="Auto" />
                                                                                <RowDefinition Height="*" />
                                                                            </Grid.RowDefinitions>
                                                                            <Border
                                                                                Margin="0,0,0,8"
                                                                                Padding="8"
                                                                                Background="#24101824"
                                                                                BorderBrush="{StaticResource EditorPrimaryMutedBrush}"
                                                                                BorderThickness="1"
                                                                                CornerRadius="6">
                                                                                <Grid>
                                                                                    <Grid.ColumnDefinitions>
                                                                                        <ColumnDefinition Width="*" />
                                                                                        <ColumnDefinition Width="Auto" />
                                                                                        <ColumnDefinition Width="Auto" />
                                                                                    </Grid.ColumnDefinitions>
                                                                                    <TextBlock
                                                                                        VerticalAlignment="Center"
                                                                                        Foreground="{DynamicResource MahApps.Brushes.IdealForeground}"
                                                                                        Text="{Binding DataContext.DashboardItemsStatus, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                                        TextTrimming="CharacterEllipsis" />
                                                                                    <TextBlock
                                                                                        Grid.Column="1"
                                                                                        Margin="12,0,0,0"
                                                                                        VerticalAlignment="Center"
                                                                                        FontFamily="Consolas"
                                                                                        Foreground="{DynamicResource MahApps.Brushes.IdealForeground}"
                                                                                        Text="{Binding DataContext.DashboardItemsGpPerHour, RelativeSource={RelativeSource AncestorType=UserControl}, StringFormat=GP/hr {0:N0}}" />
                                                                                    <mahApps:ToggleSwitch
                                                                                        Grid.Column="2"
                                                                                        Margin="14,0,0,0"
                                                                                        VerticalAlignment="Center"
                                                                                        Header="Active only"
                                                                                        IsOn="{Binding DataContext.DashboardItemsActiveOnly, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=TwoWay}"
                                                                                        OffContent=""
                                                                                        OnContent="" />
                                                                                </Grid>
                                                                            </Border>
                                                                            <DataGrid
                                                                                Grid.Row="1"
                                                                                ItemsSource="{Binding DataContext.DashboardItemsView, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                                Style="{StaticResource DashboardDataGrid}">
                                                                                <DataGrid.Columns>
                                                                                    <DataGridTextColumn
                                                                                        Width="*"
                                                                                        Binding="{Binding Name}"
                                                                                        Header="Item" />
                                                                                    <DataGridTextColumn Binding="{Binding In, StringFormat=N0}" Header="In" />
                                                                                    <DataGridTextColumn Binding="{Binding Out, StringFormat=N0}" Header="Out" />
                                                                                    <DataGridTextColumn Binding="{Binding Net, StringFormat=N0}" Header="Net" />
                                                                                    <DataGridTextColumn Binding="{Binding PerHour, StringFormat=N1}" Header="/hr" />
                                                                                    <DataGridTextColumn Binding="{Binding UnitValue, StringFormat=N0}" Header="Value" />
                                                                                    <DataGridTextColumn Binding="{Binding GpPerHour, StringFormat=N0}" Header="GP/hr" />
                                                                                </DataGrid.Columns>
                                                                            </DataGrid>
                                                                        </Grid>
                                                                    </TabItem>
                                                                </TabControl>

                                                                <Border
                                                                    Grid.Row="1"
                                                                    Margin="0,10,0,0"
                                                                    Padding="8"
                                                                    Background="#24101824"
                                                                    BorderBrush="{StaticResource EditorPrimaryMutedBrush}"
                                                                    BorderThickness="1"
                                                                    CornerRadius="6"
                                                                    Visibility="{Binding Converter={StaticResource NodeParameterBoolConverter}, ConverterParameter=collapsed|Visibility}">
                                                                    <TextBlock
                                                                        FontSize="11"
                                                                        Foreground="{DynamicResource MahApps.Brushes.Gray6}"
                                                                        Text="Collapsed. Select this node and clear 'Collapse panel' to show the tabs." />
                                                                </Border>
                                                            </Grid>
                                                        </Border>
                                                        </Grid>
                                                    </ControlTemplate>
                                                </Thumb.Template>
                                            </Thumb>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <!--  Selection box overlay  -->
                                <Canvas x:Name="SelectionOverlay" IsHitTestVisible="False" />

                                <!--  Empty-state hint  -->
                                <Border
                                    MaxWidth="420"
                                    Margin="0,120,0,0"
                                    Padding="22,18"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Top"
                                    Background="#26101620"
                                    BorderBrush="{StaticResource EditorPrimaryMutedBrush}"
                                    BorderThickness="1"
                                    CornerRadius="12"
                                    IsHitTestVisible="False"
                                    Visibility="{Binding IsCanvasEmpty, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <StackPanel HorizontalAlignment="Center">
                                        <iconPacks:PackIconMaterial
                                            Width="34"
                                            Height="34"
                                            HorizontalAlignment="Center"
                                            Foreground="{StaticResource EditorPrimaryBrush}"
                                            Kind="GraphOutline"
                                            Opacity="0.85" />
                                        <TextBlock
                                            Margin="0,10,0,0"
                                            HorizontalAlignment="Center"
                                            FontSize="15"
                                            FontWeight="SemiBold"
                                            Foreground="{DynamicResource MahApps.Brushes.IdealForeground}"
                                            Text="Empty canvas" />
                                        <TextBlock
                                            Margin="0,6,0,0"
                                            HorizontalAlignment="Center"
                                            FontSize="12"
                                            Foreground="{DynamicResource MahApps.Brushes.IdealForeground}"
                                            Opacity="0.75"
                                            Text="Add a node from the Catalog on the left to get started. The first node becomes the Start node automatically."
                                            TextAlignment="Center"
                                            TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </ScrollViewer>

                    </Border>
                </Grid>
            </Border>

            <GridSplitter
                Grid.Column="3"
                Width="6"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                Background="{StaticResource EditorPrimaryMutedBrush}"
                ResizeBehavior="PreviousAndNext"
                ResizeDirection="Columns"
                ShowsPreview="True"
                Visibility="{Binding IsRightCollapsed, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Inverted}" />

            <Border
                Grid.Column="4"
                Padding="0"
                Style="{StaticResource PanelCard}">
                <Grid>
                  <!--  Expanded inspector: header + scrollable sections  -->
                  <Grid Visibility="{Binding IsRightCollapsed, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Inverted}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border
                        Grid.Row="0"
                        Style="{StaticResource EditorColumnHeader}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ToggleButton
                                Grid.Column="0"
                                IsChecked="{Binding IsRightCollapsed, Mode=TwoWay}"
                                Style="{StaticResource RailToggleButton}"
                                ToolTip="Collapse inspector">
                                <iconPacks:PackIconMaterial
                                    Width="16"
                                    Height="16"
                                    Kind="ChevronRight" />
                            </ToggleButton>
                            <StackPanel
                                Grid.Column="1"
                                Margin="10,0,0,0"
                                VerticalAlignment="Center">
                                <TextBlock
                                    FontSize="16"
                                    FontWeight="SemiBold"
                                    Foreground="{DynamicResource MahApps.Brushes.IdealForeground}"
                                    Text="Inspector" />
                                <TextBlock
                                    FontSize="11"
                                    Foreground="{DynamicResource MahApps.Brushes.Gray7}"
                                    Text="Configure script, state signals, and selected nodes" />
                            </StackPanel>
                            <Border
                                Grid.Column="2"
                                Padding="8,4"
                                VerticalAlignment="Center"
                                Background="{StaticResource EditorPrimaryMutedBrush}"
                                CornerRadius="6">
                                <StackPanel Orientation="Horizontal">
                                    <iconPacks:PackIconMaterial
                                        Width="14"
                                        Height="14"
                                        Foreground="{DynamicResource MahApps.Brushes.Accent}"
                                        Kind="Tune" />
                                    <TextBlock
                                        Margin="6,0,0,0"
                                        FontSize="11"
                                        Foreground="{DynamicResource MahApps.Brushes.IdealForeground}"
                                        Opacity="0.75"
                                        Text="Details" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>

                    <!--  Content (hidden when collapsed)  -->
                    <ScrollViewer
                        Grid.Row="1"
                        VerticalScrollBarVisibility="Auto"
                        Visibility="{Binding IsRightCollapsed, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Inverted}">
                        <StackPanel Margin="16,12,16,16">
                            <Expander
                                Margin="0,0,0,8"
                                IsExpanded="True"
                               >
                                <Expander.Header>
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial
                                            Width="16"
                                            Height="16"
                                            Foreground="{DynamicResource MahApps.Brushes.Accent}"
                                            Kind="ScriptText" />
                                        <TextBlock
                                            Margin="8,0,0,0"
                                            FontSize="14"
                                            FontWeight="SemiBold"
                                            Foreground="{DynamicResource MahApps.Brushes.IdealForeground}"
                                            Text="Script" />
                                    </StackPanel>
                                </Expander.Header>
                                <StackPanel Margin="4,6,4,0">
                                    <TextBlock
                                        Margin="0,0,0,8"
                                        FontSize="12"
                                        Foreground="{DynamicResource MahApps.Brushes.IdealForeground}"
                                        Opacity="0.85"
                                        Text="Define script metadata and file operations. Load a template to bootstrap a graph quickly."
                                        TextWrapping="Wrap" />
                                    <Grid Margin="0,2,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <TextBlock
                                            Grid.Row="0"
                                            Grid.Column="0"
                                            Foreground="{DynamicResource MahApps.Brushes.IdealForeground}"
                                            Text="Name" />
                                        <TextBox
                                            Grid.Row="0"
                                            Grid.Column="1"
                                            Margin="8,0,0,0"
                                            Text="{Binding Script.Name, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBlock
                                            Grid.Row="1"
                                            Grid.Column="0"
                                            Margin="0,8,0,0"
                                            Foreground="{DynamicResource MahApps.Brushes.IdealForeground}"
                                            Text="Description" />
                                        <TextBox
                                            Grid.Row="1"
                                            Grid.Column="1"
                                            Height="60"
                                            Margin="8,8,0,0"
                                            AcceptsReturn="True"
                                            Text="{Binding Script.Description, UpdateSourceTrigger=PropertyChanged}"
                                            TextWrapping="Wrap" />
                                    </Grid>

                                    <StackPanel Margin="0,12,0,0" Orientation="Horizontal">
                                        <Button Command="{Binding NewScriptCommand}" Content="New" />
                                        <Button
                                            Margin="6,0,0,0"
                                            Command="{Binding LoadScriptCommand}"
                                            Content="Load" />
                                        <Button
                                            Margin="6,0,0,0"
                                            Command="{Binding SaveScriptCommand}"
                                            Content="Save" />
                                        <Button
                                            Margin="6,0,0,0"
                                            Command="{Binding ExportScriptCommand}"
                                            Content="Export" />
                                    </StackPanel>
                                    <Button
                                        Margin="0,6,0,0"
                                        Command="{Binding LoadTemplateCommand}"
                                        Content="Load power fishing template" />
                                </StackPanel>
                            </Expander>

                            <Expander
                                Margin="0,0,0,8"
                                IsExpanded="False"
                               >
                                <Expander.Header>
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial
                                            Width="16"
                                            Height="16"
                                            Foreground="{DynamicResource MahApps.Brushes.Accent}"
                                            Kind="Pulse" />
                                        <TextBlock
                                            Margin="8,0,0,0"
                                            FontSize="14"
                                            FontWeight="SemiBold"
                                            Foreground="{DynamicResource MahApps.Brushes.IdealForeground}"
                                            Text="State &amp; Signals" />
                                    </StackPanel>
                                </Expander.Header>
                                <StackPanel Margin="4,6,4,0">
                                    <TextBlock
                                        Margin="0,0,0,8"
                                        FontSize="12"
                                        Foreground="{DynamicResource MahApps.Brushes.IdealForeground}"
                                        Opacity="0.85"
                                        Text="Booleans used as transition condition keys. Toggle values to set the starting state for the next run; while running they update live from node outputs."
                                        TextWrapping="Wrap" />
                                    <TextBlock
                                        Margin="0,0,0,6"
                                        Foreground="{DynamicResource MahApps.Brushes.IdealForeground}"
                                        Text="Signals" />
                                    <ItemsControl ItemsSource="{Binding Signals}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <DockPanel Margin="0,4">
                                                    <CheckBox IsChecked="{Binding Value, Mode=TwoWay}" />
                                                    <TextBox
                                                        Width="180"
                                                        Margin="8,0,0,0"
                                                        Text="{Binding Key, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                </DockPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <Button
                                        Margin="0,8,0,0"
                                        Command="{Binding ClearTrailCommand}"
                                        Content="Clear highlights" />
                                </StackPanel>
                            </Expander>

                            <Expander
                                Margin="0,0,0,8"
                                IsExpanded="True"
                               >
                                <Expander.Header>
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial
                                            Width="16"
                                            Height="16"
                                            Foreground="{DynamicResource MahApps.Brushes.Accent}"
                                            Kind="VectorDifference" />
                                        <TextBlock
                                            Margin="8,0,0,0"
                                            FontSize="14"
                                            FontWeight="SemiBold"
                                            Foreground="{DynamicResource MahApps.Brushes.IdealForeground}"
                                            Text="Node" />
                                    </StackPanel>
                                </Expander.Header>
                                <StackPanel Margin="4,6,4,0">
                                    <TextBlock
                                        Margin="0,0,0,8"
                                        FontSize="12"
                                        Foreground="{DynamicResource MahApps.Brushes.IdealForeground}"
                                        Opacity="0.85"
                                        Text="Edit the selected canvas node. Choose a definition first, then fill required parameters and notes."
                                        TextWrapping="Wrap" />
                                    <DockPanel>
                                        <Border
                                            Margin="0,0,8,0"
                                            Padding="8,2"
                                            HorizontalAlignment="Left"
                                            Background="{DynamicResource MahApps.Brushes.Accent}"
                                            CornerRadius="8"
                                            Visibility="{Binding CanEditNode, Converter={StaticResource BoolToVisibilityConverter}}">
                                            <TextBlock
                                                FontSize="11"
                                                FontWeight="SemiBold"
                                                Foreground="{DynamicResource MahApps.Brushes.AccentForeground}"
                                                Text="{Binding SelectedNodes.Count, StringFormat={}{0} selected}" />
                                        </Border>
                                        <TextBlock
                                            Foreground="{DynamicResource MahApps.Brushes.Gray7}"
                                            Text="Click a node on canvas to select, or drag to box-select multiple."
                                            TextWrapping="Wrap"
                                            Visibility="{Binding CanEditNode, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=True, FallbackValue=Visible}" />
                                    </DockPanel>

                                    <TextBlock
                                        Margin="0,8,0,0"
                                        Foreground="{DynamicResource MahApps.Brushes.IdealForeground}"
                                        Text="Definition" />
                                    <ComboBox
                                        Margin="0,6,0,8"
                                        DisplayMemberPath="Title"
                                        ItemsSource="{Binding Definitions}"
                                        SelectedItem="{Binding SelectedNodeDefinition, Mode=TwoWay}" />

                                    <Grid DataContext="{Binding SelectedNode}">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Foreground="{DynamicResource MahApps.Brushes.IdealForeground}" Text="Title" />
                                        <TextBox
                                            Grid.Column="1"
                                            Margin="8,0,0,0"
                                            Text="{Binding Title, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                                        <TextBlock
                                            Grid.Row="1"
                                            Margin="0,8,0,0"
                                            Foreground="{DynamicResource MahApps.Brushes.IdealForeground}"
                                            Text="Description" />
                                        <TextBox
                                            Grid.Row="1"
                                            Grid.Column="1"
                                            Height="60"
                                            Margin="8,8,0,0"
                                            AcceptsReturn="True"
                                            Text="{Binding Description, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                            TextWrapping="Wrap" />

                                        <TextBlock
                                            Grid.Row="2"
                                            Margin="0,8,0,0"
                                            Foreground="{DynamicResource MahApps.Brushes.IdealForeground}"
                                            Text="Type" />
                                        <TextBlock
                                            Grid.Row="2"
                                            Grid.Column="1"
                                            Margin="8,8,0,0"
                                            Foreground="{DynamicResource MahApps.Brushes.IdealForeground}"
                                            Text="{Binding Type}" />

                                        <TextBlock
                                            Grid.Row="3"
                                            Margin="0,8,0,0"
                                            Foreground="{DynamicResource MahApps.Brushes.IdealForeground}"
                                            Text="Dwell (ms)" />
                                        <TextBox
                                            Grid.Row="3"
                                            Grid.Column="1"
                                            Margin="8,8,0,0"
                                            Text="{Binding DwellMilliseconds, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                                        <TextBlock
                                            Grid.Row="4"
                                            Margin="0,8,0,0"
                                            Foreground="{DynamicResource MahApps.Brushes.IdealForeground}"
                                            Text="Notes" />
                                        <TextBox
                                            Grid.Row="4"
                                            Grid.Column="1"
                                            Margin="8,8,0,0"
                                            Text="{Binding ActionText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                            TextWrapping="Wrap" />
                                    </Grid>

                                    <!--  Calibrate this interaction node from a real in-game click (action opcode + route offset vary per target)  -->
                                    <Border
                                        Margin="0,12,0,0"
                                        Padding="8"
                                        Background="{DynamicResource MahApps.Brushes.Control.Background}"
                                        BorderBrush="{DynamicResource MahApps.Brushes.Accent}"
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        Visibility="{Binding CanCaptureSelectedNode, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <StackPanel>
                                            <Button
                                                HorizontalAlignment="Left"
                                                Command="{Binding CaptureFromGameCommand}"
                                                Content="Capture from game"
                                                ToolTip="Click the object/NPC in-game, then press this to fill action opcode, route offset, id and distance from the real click." />
                                            <TextBlock
                                                Margin="0,6,0,0"
                                                FontSize="11"
                                                Text="{Binding CaptureStatus}"
                                                TextWrapping="Wrap">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{DynamicResource MahApps.Brushes.Gray6}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding CaptureDriftState}" Value="match">
                                                                <Setter Property="Foreground" Value="#6EE86E" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding CaptureDriftState}" Value="drift">
                                                                <Setter Property="Foreground" Value="#FFC857" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding CaptureDriftState}" Value="filled">
                                                                <Setter Property="Foreground" Value="#7DD3FC" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>
                                    </Border>

                                    <TextBlock
                                        Margin="0,12,0,6"
                                        FontWeight="SemiBold"
                                        Foreground="{DynamicResource MahApps.Brushes.IdealForeground}"
                                        Text="Parameters" />
                                    <ItemsControl ItemsSource="{Binding ParameterBindings}" ItemTemplate="{StaticResource NodeParamBindingTemplate}" />

                                    <!--  Advanced tuning params, collapsed by default to cut clutter on heavy nodes  -->
                                    <Expander
                                        Margin="0,2,0,0"
                                        IsExpanded="False"
                                        Visibility="{Binding HasAdvancedParameters, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <Expander.Header>
                                            <StackPanel Orientation="Horizontal">
                                                <iconPacks:PackIconMaterial
                                                    Width="14"
                                                    Height="14"
                                                    VerticalAlignment="Center"
                                                    Foreground="{DynamicResource MahApps.Brushes.Gray6}"
                                                    Kind="Tune" />
                                                <TextBlock
                                                    Margin="8,0,0,0"
                                                    FontSize="12"
                                                    FontWeight="SemiBold"
                                                    Foreground="{DynamicResource MahApps.Brushes.IdealForeground}"
                                                    Text="Advanced" />
                                            </StackPanel>
                                        </Expander.Header>
                                        <ItemsControl
                                            Margin="0,8,0,0"
                                            ItemTemplate="{StaticResource NodeParamBindingTemplate}"
                                            ItemsSource="{Binding AdvancedParameterBindings}" />
                                    </Expander>

                                    <StackPanel Margin="0,10,0,0" Orientation="Horizontal">
                                        <Button Command="{Binding AddNodeCommand}" Content="Add node" />
                                        <Button
                                            Margin="6,0,0,0"
                                            Command="{Binding RemoveNodeCommand}"
                                            Content="Remove node"
                                            IsEnabled="{Binding CanEditNode}" />
                                        <Button
                                            Margin="6,0,0,0"
                                            Command="{Binding SetAsStartCommand}"
                                            Content="Set as start"
                                            IsEnabled="{Binding CanEditNode}" />
                                    </StackPanel>
                                </StackPanel>
                            </Expander>

                            <Expander
                                Margin="0,0,0,8"
                                IsExpanded="False"
                               >
                                <Expander.Header>
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial
                                            Width="16"
                                            Height="16"
                                            Foreground="{DynamicResource MahApps.Brushes.Accent}"
                                            Kind="SignDirection" />
                                        <TextBlock
                                            Margin="8,0,0,0"
                                            FontSize="14"
                                            FontWeight="SemiBold"
                                            Foreground="{DynamicResource MahApps.Brushes.IdealForeground}"
                                            Text="Transitions" />
                                    </StackPanel>
                                </Expander.Header>
                                <StackPanel Margin="4,6,4,0">
                                    <TextBlock
                                        Margin="0,0,0,8"
                                        FontSize="12"
                                        Foreground="{DynamicResource MahApps.Brushes.IdealForeground}"
                                        Opacity="0.85"
                                        Text="Transitions evaluate top to bottom. 'On success'/'On fail' edges react to the node's result first, then condition keys, then the fallback."
                                        TextWrapping="Wrap" />
                                    <DockPanel Margin="0,0,0,6">
                                        <Button
                                            Command="{Binding AddTransitionCommand}"
                                            Content="Add transition"
                                            DockPanel.Dock="Right"
                                            IsEnabled="{Binding CanEditTransitions}" />
                                    </DockPanel>

                                    <ListBox
                                        BorderThickness="0"
                                        ItemsSource="{Binding SelectedNode.Transitions}"
                                        SelectedItem="{Binding SelectedTransition, Mode=TwoWay}">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Border
                                                    Margin="0,0,0,8"
                                                    Padding="10"
                                                    Background="{DynamicResource MahApps.Brushes.Gray9}"
                                                    BorderBrush="{DynamicResource MahApps.Brushes.Gray7}"
                                                    BorderThickness="1"
                                                    CornerRadius="8">
                                                    <Grid>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="Auto" />
                                                        </Grid.RowDefinitions>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>

                                                        <TextBlock Foreground="{DynamicResource MahApps.Brushes.IdealForeground}" Text="Target" />
                                                        <ComboBox
                                                            Grid.Column="1"
                                                            Margin="6,0,0,0"
                                                            DisplayMemberPath="Title"
                                                            ItemsSource="{Binding DataContext.Script.Nodes, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            SelectedValue="{Binding ToNodeId, Mode=TwoWay}"
                                                            SelectedValuePath="Id" />

                                                        <TextBlock
                                                            Grid.Row="1"
                                                            Margin="0,8,0,0"
                                                            Foreground="{DynamicResource MahApps.Brushes.IdealForeground}"
                                                            Text="Trigger" />
                                                        <ComboBox
                                                            Grid.Row="1"
                                                            Grid.Column="1"
                                                            Margin="6,8,0,0"
                                                            ItemsSource="{Binding DataContext.TransitionTriggers, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            SelectedItem="{Binding Trigger, Mode=TwoWay}"
                                                            ToolTip="Gate this edge on the node's execution result. 'Any' keeps signal-only behavior." />

                                                        <TextBlock
                                                            Grid.Row="2"
                                                            Margin="0,8,0,0"
                                                            Foreground="{DynamicResource MahApps.Brushes.IdealForeground}"
                                                            Text="Condition key" />
                                                        <ComboBox
                                                            Grid.Row="2"
                                                            Grid.Column="1"
                                                            Margin="6,8,0,0"
                                                            IsEditable="True"
                                                            ItemsSource="{Binding DataContext.SignalSuggestions, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            Text="{Binding ConditionKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                                                        <StackPanel
                                                            Grid.Row="3"
                                                            Grid.ColumnSpan="2"
                                                            Margin="0,8,0,0"
                                                            Orientation="Horizontal">
                                                            <CheckBox Content="Expect true" IsChecked="{Binding ExpectedValue, Mode=TwoWay}" />
                                                            <CheckBox
                                                                Margin="8,0,0,0"
                                                                Content="Fallback"
                                                                IsChecked="{Binding IsFallback, Mode=TwoWay}" />
                                                            <TextBox
                                                                Width="140"
                                                                Margin="8,0,0,0"
                                                                Text="{Binding Label, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                ToolTip="Label" />
                                                            <Button
                                                                Margin="8,0,0,0"
                                                                Padding="6,2"
                                                                Command="{Binding DataContext.MoveTransitionUpCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                CommandParameter="{Binding}"
                                                                Content="▲"
                                                                ToolTip="Move up (evaluated earlier)" />
                                                            <Button
                                                                Margin="4,0,0,0"
                                                                Padding="6,2"
                                                                Command="{Binding DataContext.MoveTransitionDownCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                CommandParameter="{Binding}"
                                                                Content="▼"
                                                                ToolTip="Move down (evaluated later)" />
                                                            <Button
                                                                Margin="8,0,0,0"
                                                                Command="{Binding DataContext.RemoveTransitionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                CommandParameter="{Binding}"
                                                                Content="Remove" />
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </StackPanel>
                            </Expander>
                        </StackPanel>
                    </ScrollViewer>
                  </Grid>

                  <!--  Collapsed inspector rail  -->
                  <Border
                      Background="{StaticResource RailSurfaceBrush}"
                      CornerRadius="13"
                      Visibility="{Binding IsRightCollapsed, Converter={StaticResource BoolToVisibilityConverter}}">
                      <Grid Margin="0,14">
                          <Grid.RowDefinitions>
                              <RowDefinition Height="Auto" />
                              <RowDefinition Height="*" />
                              <RowDefinition Height="Auto" />
                          </Grid.RowDefinitions>
                          <ToggleButton
                              Grid.Row="0"
                              HorizontalAlignment="Center"
                              IsChecked="{Binding IsRightCollapsed, Mode=TwoWay}"
                              Style="{StaticResource RailToggleButton}"
                              ToolTip="Expand inspector">
                              <iconPacks:PackIconMaterial
                                  Width="16"
                                  Height="16"
                                  Kind="ChevronLeft" />
                          </ToggleButton>
                          <TextBlock
                              Grid.Row="1"
                              Margin="0,16"
                              VerticalAlignment="Center"
                              Style="{StaticResource RailCaption}"
                              Text="INSPECTOR" />
                          <Border
                              Grid.Row="2"
                              Width="32"
                              Height="32"
                              HorizontalAlignment="Center"
                              Background="{StaticResource EditorPrimaryMutedBrush}"
                              CornerRadius="9">
                              <iconPacks:PackIconMaterial
                                  Width="16"
                                  Height="16"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  Foreground="{DynamicResource MahApps.Brushes.Accent}"
                                  Kind="Tune" />
                          </Border>
                      </Grid>
                  </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
