<UserControl
    x:Class="SharpBuilder.Editor.Wpf.Views.NodeEditorControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="http://metro.mahapps.com/winfx/xaml/controls"
    xmlns:converters="clr-namespace:SharpBuilder.Editor.Wpf.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
    xmlns:mahApps="http://metro.mahapps.com/winfx/xaml/controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="clr-namespace:SharpBuilder.Core.Models;assembly=SharpBuilder.Core"
    xmlns:utils="clr-namespace:SharpBuilder.Editor.Wpf.Utilities"
    xmlns:viewModels="clr-namespace:SharpBuilder.Editor.Wpf.ViewModels"
    xmlns:views="clr-namespace:SharpBuilder.Editor.Wpf.Views"
    x:Name="Root"
    d:DataContext="{d:DesignInstance viewModels:NodeEditorViewModel,
                                     IsDesignTimeCreatable=True}"
    d:DesignHeight="900"
    d:DesignWidth="1400"
    mc:Ignorable="d">

    <UserControl.InputBindings>
        <KeyBinding Key="Delete" Command="{Binding DeleteSelectedCommand}" />
        <KeyBinding Key="Escape" Command="{Binding CloseNodeInfoCommand}" />
        <KeyBinding
            Key="S"
            Command="{Binding SaveScriptCommand}"
            Modifiers="Control" />
        <KeyBinding
            Key="S"
            Command="{Binding ExportScriptCommand}"
            Modifiers="Control+Shift" />
        <KeyBinding
            Key="N"
            Command="{Binding NewScriptCommand}"
            Modifiers="Control" />
        <KeyBinding
            Key="O"
            Command="{Binding LoadScriptCommand}"
            Modifiers="Control" />
        <KeyBinding
            Key="Z"
            Command="{Binding UndoCommand}"
            Modifiers="Control" />
        <KeyBinding
            Key="Y"
            Command="{Binding RedoCommand}"
            Modifiers="Control" />
        <KeyBinding Key="F5" Command="{Binding StartCommand}" />
        <KeyBinding
            Key="F5"
            Command="{Binding StepCommand}"
            Modifiers="Control" />
        <KeyBinding
            Key="F5"
            Command="{Binding StopCommand}"
            Modifiers="Shift" />
    </UserControl.InputBindings>

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Themes/EditorStyles.xaml" />
                <ResourceDictionary Source="Themes/NodeParamTemplates.xaml" />
                <ResourceDictionary Source="Themes/DashboardStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border
            Padding="12,8"
            BorderBrush="{StaticResource PanelBorderBrush}"
            BorderThickness="1"
            CornerRadius="12">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Offset="0" Color="#FF1B2738" />
                    <GradientStop Offset="0.55" Color="#FF161D29" />
                    <GradientStop Offset="1" Color="#FF141A24" />
                </LinearGradientBrush>
            </Border.Background>
            <Border.Effect>
                <DropShadowEffect
                    BlurRadius="14"
                    Direction="270"
                    Opacity="0.24"
                    ShadowDepth="2"
                    Color="#000000" />
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!--  Accent logo tile  -->
                <Border
                    Width="38"
                    Height="38"
                    BorderBrush="{StaticResource EditorPrimaryBrush}"
                    BorderThickness="1.5"
                    CornerRadius="10">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Offset="0" Color="#FF2E6FB0" />
                            <GradientStop Offset="1" Color="#FF1C3A57" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <iconPacks:PackIconMaterial
                        Width="22"
                        Height="22"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Foreground="{DynamicResource MahApps.Brushes.IdealForeground}"
                        Kind="GraphOutline" />
                </Border>

                <StackPanel
                    Grid.Column="1"
                    Margin="10,0,0,0"
                    VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock
                            FontSize="18"
                            FontWeight="Bold"
                            Foreground="{DynamicResource MahApps.Brushes.IdealForeground}"
                            Text="SharpBuilder" />
                        <Border
                            Margin="8,1,0,0"
                            Padding="6,1"
                            VerticalAlignment="Center"
                            Background="{StaticResource EditorPrimaryMutedBrush}"
                            BorderBrush="{StaticResource EditorPrimaryBrush}"
                            BorderThickness="1"
                            CornerRadius="6">
                            <TextBlock
                                FontSize="9"
                                FontWeight="SemiBold"
                                Foreground="{DynamicResource MahApps.Brushes.IdealForeground}"
                                Text="STUDIO" />
                        </Border>
                    </StackPanel>
                    <TextBlock
                        Margin="0,1,0,0"
                        FontSize="11"
                        Foreground="{DynamicResource MahApps.Brushes.IdealForeground}"
                        Opacity="0.78"
                        Text="Design, validate, and run automation flows."
                        TextTrimming="CharacterEllipsis" />
                </StackPanel>

                <!--  Run-target hint chips  -->
                <StackPanel
                    Grid.Column="2"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
                    <Border
                        Margin="0,0,6,0"
                        Padding="7,4"
                        Background="#1AFFFFFF"
                        BorderBrush="{StaticResource PanelBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="9">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial
                                Width="12"
                                Height="12"
                                VerticalAlignment="Center"
                                Foreground="{DynamicResource MahApps.Brushes.Accent}"
                                Kind="Sword" />
                            <TextBlock
                                Margin="5,0,0,0"
                                VerticalAlignment="Center"
                                FontSize="10.5"
                                Foreground="{DynamicResource MahApps.Brushes.IdealForeground}"
                                Opacity="0.82"
                                Text="Game" />
                        </StackPanel>
                    </Border>
                    <Border
                        Margin="0,0,6,0"
                        Padding="7,4"
                        Background="#1AFFFFFF"
                        BorderBrush="{StaticResource PanelBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="9">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial
                                Width="12"
                                Height="12"
                                VerticalAlignment="Center"
                                Foreground="{DynamicResource MahApps.Brushes.Accent}"
                                Kind="ScriptText" />
                            <TextBlock
                                Margin="5,0,0,0"
                                VerticalAlignment="Center"
                                FontSize="10.5"
                                Foreground="{DynamicResource MahApps.Brushes.IdealForeground}"
                                Opacity="0.82"
                                Text="Host" />
                        </StackPanel>
                    </Border>
                    <Border
                        Padding="7,4"
                        Background="#1AFFFFFF"
                        BorderBrush="{StaticResource PanelBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="9">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial
                                Width="12"
                                Height="12"
                                VerticalAlignment="Center"
                                Foreground="{DynamicResource MahApps.Brushes.Accent}"
                                Kind="Console" />
                            <TextBlock
                                Margin="5,0,0,0"
                                VerticalAlignment="Center"
                                FontSize="10.5"
                                Foreground="{DynamicResource MahApps.Brushes.IdealForeground}"
                                Opacity="0.82"
                                Text="Headless" />
                        </StackPanel>
                    </Border>

                    <!--  Settings gear  -->
                    <ToggleButton
                        x:Name="SettingsButton"
                        Margin="8,0,0,0"
                        VerticalAlignment="Center"
                        IsChecked="{Binding IsSettingsOpen, Mode=TwoWay}"
                        Style="{StaticResource RailToggleButton}"
                        ToolTip="Settings">
                        <iconPacks:PackIconMaterial
                            Width="16"
                            Height="16"
                            Kind="Cog" />
                    </ToggleButton>
                    <Popup
                        AllowsTransparency="True"
                        HorizontalOffset="-180"
                        IsOpen="{Binding IsSettingsOpen, Mode=TwoWay}"
                        Placement="Bottom"
                        PlacementTarget="{Binding ElementName=SettingsButton}"
                        PopupAnimation="Fade"
                        StaysOpen="False"
                        VerticalOffset="8">
                        <Border
                            Width="280"
                            Padding="16"
                            Background="#F21B2432"
                            BorderBrush="{StaticResource EditorPrimaryBrush}"
                            BorderThickness="1.5"
                            CornerRadius="12">
                            <Border.Effect>
                                <DropShadowEffect
                                    BlurRadius="18"
                                    Opacity="0.4"
                                    ShadowDepth="3" />
                            </Border.Effect>
                            <StackPanel>
                                <StackPanel Margin="0,0,0,12" Orientation="Horizontal">
                                    <iconPacks:PackIconMaterial
                                        Width="16"
                                        Height="16"
                                        VerticalAlignment="Center"
                                        Foreground="{DynamicResource MahApps.Brushes.Accent}"
                                        Kind="Cog" />
                                    <TextBlock
                                        Margin="8,0,0,0"
                                        FontSize="15"
                                        FontWeight="SemiBold"
                                        Foreground="{DynamicResource MahApps.Brushes.IdealForeground}"
                                        Text="Settings" />
                                </StackPanel>

                                <TextBlock
                                    FontSize="12"
                                    FontWeight="SemiBold"
                                    Foreground="{DynamicResource MahApps.Brushes.IdealForeground}"
                                    Opacity="0.85"
                                    Text="Window size" />
                                <ComboBox
                                    Margin="0,6,0,0"
                                    DisplayMemberPath="DisplayLabel"
                                    ItemsSource="{Binding WindowSizeOptions}"
                                    SelectedItem="{Binding SelectedWindowSize, Mode=TwoWay}" />
                                <TextBlock
                                    Margin="0,8,0,0"
                                    FontSize="11"
                                    Foreground="{DynamicResource MahApps.Brushes.Gray7}"
                                    Text="Saved automatically and restored next session. Drag the window edges for a custom size."
                                    TextWrapping="Wrap" />

                                <Border
                                    Margin="0,14,0,0"
                                    BorderBrush="{StaticResource PanelBorderBrush}"
                                    BorderThickness="0,1,0,0" />
                                <TextBlock
                                    Margin="0,12,0,0"
                                    FontSize="12"
                                    FontWeight="SemiBold"
                                    Foreground="{DynamicResource MahApps.Brushes.IdealForeground}"
                                    Opacity="0.85"
                                    Text="Workspace" />
                                <mahApps:ToggleSwitch
                                    Margin="0,8,0,0"
                                    Header="Start with catalog collapsed"
                                    IsOn="{Binding StartLeftCollapsed, Mode=TwoWay}"
                                    OffContent=""
                                    OnContent="" />
                                <mahApps:ToggleSwitch
                                    Margin="0,4,0,0"
                                    Header="Start with inspector collapsed"
                                    IsOn="{Binding StartRightCollapsed, Mode=TwoWay}"
                                    OffContent=""
                                    OnContent="" />
                                <mahApps:ToggleSwitch
                                    Margin="0,4,0,0"
                                    Header="Mini-map always visible"
                                    IsOn="{Binding MiniMapAlwaysVisible, Mode=TwoWay}"
                                    OffContent=""
                                    OnContent="" />
                                <TextBlock
                                    Margin="0,4,0,0"
                                    FontSize="11"
                                    Foreground="{DynamicResource MahApps.Brushes.Gray7}"
                                    Text="When off, the mini-map only appears while panning and fades out after a short countdown."
                                    TextWrapping="Wrap" />

                                <Border
                                    Margin="0,14,0,0"
                                    BorderBrush="{StaticResource PanelBorderBrush}"
                                    BorderThickness="0,1,0,0" />
                                <TextBlock
                                    Margin="0,12,0,0"
                                    FontSize="12"
                                    FontWeight="SemiBold"
                                    Foreground="{DynamicResource MahApps.Brushes.IdealForeground}"
                                    Opacity="0.85"
                                    Text="Templates" />
                                <Button
                                    Margin="0,6,0,0"
                                    HorizontalContentAlignment="Left"
                                    Command="{Binding LoadTemplateCommand}"
                                    Style="{StaticResource ScriptControlButton}"
                                    ToolTip="Replace the current graph with the power-fishing starter template">
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial
                                            Width="12"
                                            Height="12"
                                            VerticalAlignment="Center"
                                            Kind="FileDocumentMultipleOutline" />
                                        <TextBlock Margin="6,0,0,0" Text="Load power fishing template" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Border>
                    </Popup>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="{Binding DataContext.LeftColumnWidth, ElementName=Root, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" MinWidth="{x:Static viewModels:NodeEditorViewModel.CollapsedRailWidth}" />
                <ColumnDefinition Width="6" />
                <ColumnDefinition Width="*" MinWidth="420" />
                <ColumnDefinition Width="6" />
                <ColumnDefinition Width="{Binding DataContext.RightColumnWidth, ElementName=Root, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" MinWidth="{x:Static viewModels:NodeEditorViewModel.CollapsedRailWidth}" />
            </Grid.ColumnDefinitions>

            <views:CatalogPanel x:Name="Catalog" Grid.Column="0" />

            <GridSplitter
                Grid.Column="1"
                Width="6"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                Background="{StaticResource EditorPrimaryMutedBrush}"
                ResizeBehavior="PreviousAndNext"
                ResizeDirection="Columns"
                ShowsPreview="True"
                Visibility="{Binding IsLeftCollapsed, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Inverted}" />

            <Border
                Grid.Column="2"
                Padding="0"
                Style="{StaticResource PanelCard}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border
                        Grid.Row="0"
                        Height="70"
                        Style="{StaticResource EditorColumnHeader}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <!--  Transport / run controls (left-aligned)  -->
                            <StackPanel
                                Grid.Column="0"
                                VerticalAlignment="Center"
                                Orientation="Horizontal">
                                <!--  Transport group  -->
                                <Border
                                    Padding="4"
                                    Background="#22000000"
                                    BorderBrush="{StaticResource PanelBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="9">
                                    <StackPanel Orientation="Horizontal">
                                        <Button
                                            Command="{Binding StartCommand}"
                                            Style="{StaticResource ToolbarRunButton}"
                                            ToolTip="Validate and run the graph — respects the Loop toggle (F5)">
                                            <Button.Content>
                                                <StackPanel Orientation="Horizontal">
                                                    <iconPacks:PackIconMaterial
                                                        Width="14"
                                                        Height="14"
                                                        Kind="Play" />
                                                    <TextBlock Margin="6,0,0,0" Text="Run" />
                                                </StackPanel>
                                            </Button.Content>
                                        </Button>
                                        <Button
                                            Margin="4,0,0,0"
                                            Command="{Binding StepCommand}"
                                            Style="{StaticResource ToolbarButton}"
                                            ToolTip="Run a single pass through the graph without looping (Ctrl+F5)">
                                            <Button.Content>
                                                <StackPanel Orientation="Horizontal">
                                                    <iconPacks:PackIconMaterial
                                                        Width="14"
                                                        Height="14"
                                                        Kind="SkipNext" />
                                                    <TextBlock Margin="6,0,0,0" Text="Run Once" />
                                                </StackPanel>
                                            </Button.Content>
                                        </Button>
                                        <Button
                                            Margin="4,0,0,0"
                                            Command="{Binding StopCommand}"
                                            Style="{StaticResource ToolbarStopButton}"
                                            ToolTip="Stop the running graph (Shift+F5)">
                                            <Button.Content>
                                                <StackPanel Orientation="Horizontal">
                                                    <iconPacks:PackIconMaterial
                                                        Width="14"
                                                        Height="14"
                                                        Kind="Stop" />
                                                    <TextBlock Margin="6,0,0,0" Text="Stop" />
                                                </StackPanel>
                                            </Button.Content>
                                        </Button>
                                        <Button
                                            Margin="4,0,0,0"
                                            Command="{Binding ExplainGraphCommand}"
                                            Style="{StaticResource ToolbarButton}"
                                            ToolTip="Explain graph requirements, warnings, signals, and advanced-node use without running it">
                                            <Button.Content>
                                                <StackPanel Orientation="Horizontal">
                                                    <iconPacks:PackIconMaterial
                                                        Width="14"
                                                        Height="14"
                                                        Kind="FileSearchOutline" />
                                                    <TextBlock Margin="6,0,0,0" Text="Explain" />
                                                </StackPanel>
                                            </Button.Content>
                                        </Button>
                                    </StackPanel>
                                </Border>

                                <Border
                                    Margin="8,0,0,0"
                                    Padding="4"
                                    Background="#22000000"
                                    BorderBrush="{StaticResource PanelBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="9">
                                    <StackPanel Orientation="Horizontal">
                                        <Button
                                            Command="{Binding UndoCommand}"
                                            Style="{StaticResource ToolbarButton}"
                                            ToolTip="Undo last graph edit (Ctrl+Z)">
                                            <Button.Content>
                                                <StackPanel Orientation="Horizontal">
                                                    <iconPacks:PackIconMaterial
                                                        Width="14"
                                                        Height="14"
                                                        Kind="Undo" />
                                                    <TextBlock Margin="6,0,0,0" Text="Undo" />
                                                </StackPanel>
                                            </Button.Content>
                                        </Button>
                                        <Button
                                            Margin="4,0,0,0"
                                            Command="{Binding RedoCommand}"
                                            Style="{StaticResource ToolbarButton}"
                                            ToolTip="Redo graph edit (Ctrl+Y)">
                                            <Button.Content>
                                                <StackPanel Orientation="Horizontal">
                                                    <iconPacks:PackIconMaterial
                                                        Width="14"
                                                        Height="14"
                                                        Kind="Redo" />
                                                    <TextBlock Margin="6,0,0,0" Text="Redo" />
                                                </StackPanel>
                                            </Button.Content>
                                        </Button>
                                    </StackPanel>
                                </Border>

                                <Button
                                    Margin="8,0,0,0"
                                    Command="{Binding DeleteSelectedCommand}"
                                    Style="{StaticResource ToolbarDeleteButton}"
                                    ToolTip="Delete selected nodes (Del)">
                                    <Button.Content>
                                        <StackPanel Orientation="Horizontal">
                                            <iconPacks:PackIconMaterial
                                                Width="14"
                                                Height="14"
                                                Kind="Delete" />
                                            <TextBlock Margin="6,0,0,0" Text="Delete" />
                                        </StackPanel>
                                    </Button.Content>
                                </Button>

                                <Border
                                    Width="80"
                                    Margin="6,0,0,0"
                                    Padding="6,1"
                                    Background="#22000000"
                                    BorderBrush="{StaticResource PanelBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8">
                                    <controls:ToggleSwitch
                                        Padding="0"
                                        VerticalAlignment="Center"
                                        Header="Loop"
                                        IsOn="{Binding IsLooping}"
                                        OffContent=""
                                        OnContent="" />
                                </Border>
                            </StackPanel>

                            <StackPanel
                                Grid.Column="2"
                                VerticalAlignment="Center"
                                Orientation="Horizontal">
                                <!--  Merged pan + zoom strip  -->
                                <Border
                                    Padding="4,2"
                                    Background="#22000000"
                                    BorderBrush="{StaticResource PanelBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="9">
                                    <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial
                                            Width="12"
                                            Height="12"
                                            Margin="3,0,5,0"
                                            VerticalAlignment="Center"
                                            Kind="CursorMove"
                                            Opacity="0.6"
                                            ToolTip="Hold Space or Middle Mouse to pan the canvas" />
                                        <Border
                                            Width="1"
                                            Margin="1,2"
                                            Background="{StaticResource PanelBorderBrush}" />
                                        <Button
                                            x:Name="ZoomOutButton"
                                            Padding="4,2"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Click="ZoomOutButton_Click"
                                            ToolTip="Zoom out (Ctrl+Scroll)">
                                            <iconPacks:PackIconMaterial
                                                Width="13"
                                                Height="13"
                                                Kind="MagnifyMinus" />
                                        </Button>
                                        <TextBlock
                                            x:Name="ZoomLevelText"
                                            Width="40"
                                            VerticalAlignment="Center"
                                            FontSize="11"
                                            Foreground="{DynamicResource MahApps.Brushes.IdealForeground}"
                                            Text="100%"
                                            TextAlignment="Center" />
                                        <Button
                                            x:Name="ZoomInButton"
                                            Padding="4,2"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Click="ZoomInButton_Click"
                                            ToolTip="Zoom in (Ctrl+Scroll)">
                                            <iconPacks:PackIconMaterial
                                                Width="13"
                                                Height="13"
                                                Kind="MagnifyPlus" />
                                        </Button>
                                        <Border
                                            Width="1"
                                            Margin="3,2"
                                            Background="{StaticResource PanelBorderBrush}" />
                                        <Button
                                            x:Name="ZoomResetButton"
                                            Padding="4,2"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Click="ZoomResetButton_Click"
                                            ToolTip="Reset zoom to 100%">
                                            <iconPacks:PackIconMaterial
                                                Width="13"
                                                Height="13"
                                                Kind="MagnifyRemoveOutline" />
                                        </Button>
                                        <Button
                                            x:Name="FitGraphButton"
                                            Padding="4,2"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Click="FitGraphButton_Click"
                                            ToolTip="Fit graph to the canvas">
                                            <iconPacks:PackIconMaterial
                                                Width="13"
                                                Height="13"
                                                Kind="FitToPageOutline" />
                                        </Button>
                                        <Button
                                            x:Name="CenterSelectionButton"
                                            Padding="4,2"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Click="CenterSelectionButton_Click"
                                            ToolTip="Center selected nodes">
                                            <iconPacks:PackIconMaterial
                                                Width="13"
                                                Height="13"
                                                Kind="CrosshairsGps" />
                                        </Button>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border
                        Grid.Row="1"
                        ClipToBounds="True"
                        CornerRadius="0,0,13,13">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Offset="0" Color="#1a1f2a" />
                                <GradientStop Offset="1" Color="#11151e" />
                            </LinearGradientBrush>
                        </Border.Background>

                        <Grid>
                            <ScrollViewer
                                x:Name="CanvasScrollViewer"
                                Margin="8"
                                HorizontalScrollBarVisibility="Auto"
                                PanningMode="Both"
                                PreviewMouseDown="CanvasScrollViewer_OnPreviewMouseDown"
                                PreviewMouseMove="CanvasScrollViewer_OnPreviewMouseMove"
                                PreviewMouseUp="CanvasScrollViewer_OnPreviewMouseUp"
                                PreviewMouseWheel="CanvasScrollViewer_OnPreviewMouseWheel"
                                ScrollChanged="CanvasScrollViewer_OnScrollChanged"
                                VerticalScrollBarVisibility="Auto">
                                <Grid
                                    x:Name="CanvasContainer"
                                    MinWidth="2000"
                                    MinHeight="1500"
                                    AllowDrop="True"
                                    DragOver="CanvasContainer_OnDragOver"
                                    Drop="CanvasContainer_OnDrop">
                                    <Grid.Background>
                                        <!--
                                            Cache the rasterized dot tile so panning/zooming/dragging over the 2000x1500
                                            canvas doesn't re-tile thousands of dots every render pass.
                                        -->
                                        <DrawingBrush
                                            RenderOptions.CachingHint="Cache"
                                            TileMode="Tile"
                                            Viewport="0,0,24,24"
                                            ViewportUnits="Absolute">
                                            <DrawingBrush.Drawing>
                                                <GeometryDrawing Brush="#1FFFFFFF">
                                                    <GeometryDrawing.Geometry>
                                                        <EllipseGeometry
                                                            Center="2,2"
                                                            RadiusX="1"
                                                            RadiusY="1" />
                                                    </GeometryDrawing.Geometry>
                                                </GeometryDrawing>
                                            </DrawingBrush.Drawing>
                                        </DrawingBrush>
                                    </Grid.Background>
                                    <Grid.LayoutTransform>
                                        <ScaleTransform x:Name="CanvasScaleTransform" ScaleX="1" ScaleY="1" />
                                    </Grid.LayoutTransform>
                                    <!--
                                        Each EdgeViewModel owns its connector geometry and refreshes it when its
                                        endpoint nodes move, so a drag re-renders only the affected paths instead
                                        of rebuilding the whole layer.
                                    -->
                                    <ItemsControl IsHitTestVisible="False" ItemsSource="{Binding Edges}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <Canvas />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Path
                                                    Data="{Binding Geometry}"
                                                    StrokeDashCap="Round"
                                                    StrokeThickness="2.5">
                                                    <Path.Style>
                                                        <Style TargetType="Path">
                                                            <Setter Property="Stroke" Value="{DynamicResource MahApps.Brushes.Gray7}" />
                                                            <Setter Property="Opacity" Value="0.55" />
                                                            <Setter Property="StrokeDashArray" Value="2 1" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Transition.IsActive}" Value="True">
                                                                    <Setter Property="Stroke" Value="#6EE86E" />
                                                                    <Setter Property="Opacity" Value="0.95" />
                                                                    <Setter Property="StrokeDashArray" Value="1" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Path.Style>
                                                </Path>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <ItemsControl x:Name="NodeCanvas" ItemsSource="{Binding Script.Nodes}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <Canvas x:Name="NodeCanvasPanel" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemContainerStyle>
                                            <Style TargetType="ContentPresenter">
                                                <Setter Property="Canvas.Left" Value="{Binding X}" />
                                                <Setter Property="Canvas.Top" Value="{Binding Y}" />
                                                <Setter Property="Panel.ZIndex" Value="0" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding DefinitionId}" Value="ui.scriptDashboard">
                                                        <Setter Property="Panel.ZIndex" Value="100" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ItemsControl.ItemContainerStyle>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Thumb
                                                    DragCompleted="NodeDragCompleted"
                                                    DragDelta="NodeDragDelta"
                                                    DragStarted="NodeDragStarted"
                                                    MouseLeftButtonDown="NodeMouseDown"
                                                    PreviewMouseLeftButtonDown="NodeMouseDown"
                                                    Tag="{Binding}">
                                                    <Thumb.Template>
                                                        <ControlTemplate TargetType="Thumb">
                                                            <Grid>
                                                                <!--  234 = 220 card + 7px port overhang per side; NodeConnectorConverter anchors depend on this.  -->
                                                                <Border
                                                                    Width="240"
                                                                    Padding="3"
                                                                    BorderBrush="Transparent"
                                                                    BorderThickness="2"
                                                                    CornerRadius="15"
                                                                    Visibility="{Binding DefinitionId, Converter={StaticResource DefinitionIdVisibilityConverter}, ConverterParameter=ui.scriptDashboard|Invert}">
                                                                    <Border.Style>
                                                                        <Style TargetType="Border">
                                                                            <Setter Property="BorderBrush" Value="Transparent" />
                                                                            <Setter Property="Effect" Value="{x:Null}" />
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                                    <Setter Property="BorderBrush" Value="#FF4AB6FF" />
                                                                                    <Setter Property="BorderThickness" Value="3" />
                                                                                    <Setter Property="Effect">
                                                                                        <Setter.Value>
                                                                                            <DropShadowEffect
                                                                                                BlurRadius="20"
                                                                                                Opacity="0.55"
                                                                                                ShadowDepth="0"
                                                                                                Color="#FF4AB6FF" />
                                                                                        </Setter.Value>
                                                                                    </Setter>
                                                                                </DataTrigger>
                                                                                <DataTrigger Binding="{Binding IsCurrent}" Value="True">
                                                                                    <Setter Property="BorderBrush" Value="#9FFF9F" />
                                                                                    <Setter Property="Effect">
                                                                                        <Setter.Value>
                                                                                            <DropShadowEffect
                                                                                                BlurRadius="26"
                                                                                                Opacity="0.8"
                                                                                                ShadowDepth="0"
                                                                                                Color="#FF6EE86E" />
                                                                                        </Setter.Value>
                                                                                    </Setter>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </Border.Style>
                                                                    <Grid Width="234">
                                                                        <Border
                                                                            MinHeight="130"
                                                                            Margin="7,0"
                                                                            Padding="10"
                                                                            Background="#FF11161F"
                                                                            BorderThickness="2"
                                                                            CornerRadius="12"
                                                                            Effect="{StaticResource NodeShadow}">
                                                                            <Border.Style>
                                                                                <Style TargetType="Border">
                                                                                    <!--  Dark card with a category-colored accent border  -->
                                                                                    <Setter Property="Background">
                                                                                        <Setter.Value>
                                                                                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                                                                <GradientStop Offset="0" Color="#FF161D29" />
                                                                                                <GradientStop Offset="1" Color="#FF0F141D" />
                                                                                            </LinearGradientBrush>
                                                                                        </Setter.Value>
                                                                                    </Setter>
                                                                                    <Setter Property="BorderBrush" Value="{Binding DefinitionId, Converter={StaticResource NodeVisualConverter}, ConverterParameter=Brush}" />
                                                                                    <Setter Property="BorderThickness" Value="2" />
                                                                                    <Style.Triggers>
                                                                                        <DataTrigger Binding="{Binding LastRunStatus}" Value="{x:Static models:NodeRunStatus.Fail}">
                                                                                            <Setter Property="BorderBrush" Value="#E86E6E" />
                                                                                            <Setter Property="Background">
                                                                                                <Setter.Value>
                                                                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                                                                        <GradientStop Offset="0" Color="#8f2f2f" />
                                                                                                        <GradientStop Offset="1" Color="#6a1f1f" />
                                                                                                    </LinearGradientBrush>
                                                                                                </Setter.Value>
                                                                                            </Setter>
                                                                                        </DataTrigger>
                                                                                        <DataTrigger Binding="{Binding Type}" Value="{x:Static models:NodeType.Start}">
                                                                                            <Setter Property="BorderBrush" Value="{StaticResource EditorPrimaryBrush}" />
                                                                                        </DataTrigger>
                                                                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                                            <Setter Property="BorderBrush" Value="{StaticResource EditorPrimaryBrush}" />
                                                                                            <Setter Property="BorderThickness" Value="2" />
                                                                                            <Setter Property="Effect">
                                                                                                <Setter.Value>
                                                                                                    <DropShadowEffect
                                                                                                        BlurRadius="10"
                                                                                                        Opacity="0.22"
                                                                                                        ShadowDepth="0"
                                                                                                        Color="#FF4AB6FF" />
                                                                                                </Setter.Value>
                                                                                            </Setter>
                                                                                        </DataTrigger>
                                                                                        <!--  Currently executing node wins over every other state.  -->
                                                                                        <DataTrigger Binding="{Binding IsCurrent}" Value="True">
                                                                                            <Setter Property="BorderBrush" Value="#9FFF9F" />
                                                                                        </DataTrigger>
                                                                                    </Style.Triggers>
                                                                                </Style>
                                                                            </Border.Style>

                                                                            <Grid>
                                                                                <!--  Header/description rows are fixed so transition port anchors stay deterministic (see NodeConnectorConverter.OutPortFirstY).  -->
                                                                                <Grid.RowDefinitions>
                                                                                    <RowDefinition Height="34" />
                                                                                    <RowDefinition Height="40" />
                                                                                    <RowDefinition Height="Auto" />
                                                                                    <RowDefinition Height="Auto" />
                                                                                </Grid.RowDefinitions>

                                                                                <Border
                                                                                    Grid.RowSpan="4"
                                                                                    Width="4"
                                                                                    Margin="-6,-2,0,-2"
                                                                                    HorizontalAlignment="Left"
                                                                                    Background="{Binding DefinitionId, Converter={StaticResource NodeVisualConverter}, ConverterParameter=Brush}"
                                                                                    CornerRadius="2" />

                                                                                <Grid>
                                                                                    <Grid.ColumnDefinitions>
                                                                                        <ColumnDefinition Width="Auto" />
                                                                                        <ColumnDefinition Width="*" />
                                                                                        <ColumnDefinition Width="Auto" />
                                                                                    </Grid.ColumnDefinitions>
                                                                                    <Border
                                                                                        Grid.Column="0"
                                                                                        Width="24"
                                                                                        Height="24"
                                                                                        Background="{Binding DefinitionId, Converter={StaticResource NodeVisualConverter}, ConverterParameter=SurfaceBrush}"
                                                                                        CornerRadius="4">
                                                                                        <iconPacks:PackIconMaterial
                                                                                            Width="16"
                                                                                            Height="16"
                                                                                            HorizontalAlignment="Center"
                                                                                            VerticalAlignment="Center"
                                                                                            Foreground="{Binding DefinitionId, Converter={StaticResource NodeVisualConverter}, ConverterParameter=Brush}"
                                                                                            Kind="{Binding DefinitionId, Converter={StaticResource NodeVisualConverter}, ConverterParameter=Icon}" />
                                                                                    </Border>
                                                                                    <StackPanel
                                                                                        Grid.Column="1"
                                                                                        Margin="6,0,0,0"
                                                                                        Orientation="Vertical">
                                                                                        <TextBlock
                                                                                            FontWeight="SemiBold"
                                                                                            Foreground="{DynamicResource MahApps.Brushes.IdealForeground}"
                                                                                            Text="{Binding Title}" />
                                                                                        <TextBlock
                                                                                            FontSize="11"
                                                                                            Foreground="{DynamicResource MahApps.Brushes.IdealForeground}"
                                                                                            Opacity="0.7"
                                                                                            Text="{Binding DefinitionTitle}" />
                                                                                    </StackPanel>
                                                                                    <Border
                                                                                        Grid.Column="2"
                                                                                        Padding="6,2"
                                                                                        HorizontalAlignment="Right"
                                                                                        Background="{DynamicResource MahApps.Brushes.Accent}"
                                                                                        CornerRadius="4">
                                                                                        <Border.Visibility>
                                                                                            <MultiBinding Converter="{StaticResource EqualityToVisibilityConverter}">
                                                                                                <Binding Path="Id" />
                                                                                                <Binding Path="DataContext.Script.StartNodeId" RelativeSource="{RelativeSource AncestorType=UserControl}" />
                                                                                            </MultiBinding>
                                                                                        </Border.Visibility>
                                                                                        <TextBlock
                                                                                            FontSize="10"
                                                                                            FontWeight="Bold"
                                                                                            Foreground="{DynamicResource MahApps.Brushes.AccentForeground}"
                                                                                            Text="Start" />
                                                                                    </Border>
                                                                                </Grid>

                                                                                <TextBlock
                                                                                    Grid.Row="1"
                                                                                    Margin="0,6,0,0"
                                                                                    VerticalAlignment="Top"
                                                                                    Foreground="{DynamicResource MahApps.Brushes.IdealForeground}"
                                                                                    Opacity="0.8"
                                                                                    Text="{Binding Description}"
                                                                                    TextTrimming="CharacterEllipsis"
                                                                                    TextWrapping="Wrap"
                                                                                    ToolTip="{Binding Description}" />

                                                                                <!--
                                                                                    Transition out-ports: one labeled row per edge; row order = evaluation priority.
                                                                                    Row height must match NodeConnectorConverter.OutPortRowHeight.
                                                                                -->
                                                                                <StackPanel Grid.Row="2" Margin="0,4,0,0">
                                                                                    <ItemsControl ItemsSource="{Binding Transitions}">
                                                                                        <ItemsControl.ItemTemplate>
                                                                                            <DataTemplate>
                                                                                                <Grid Height="22" Background="Transparent">
                                                                                                    <TextBlock
                                                                                                        Margin="0,0,4,0"
                                                                                                        HorizontalAlignment="Right"
                                                                                                        VerticalAlignment="Center"
                                                                                                        FontSize="10"
                                                                                                        Foreground="{DynamicResource MahApps.Brushes.IdealForeground}"
                                                                                                        Opacity="0.85"
                                                                                                        TextTrimming="CharacterEllipsis">
                                                                                                        <TextBlock.Text>
                                                                                                            <MultiBinding Converter="{StaticResource TransitionPortLabelConverter}">
                                                                                                                <Binding Path="Trigger" />
                                                                                                                <Binding Path="ConditionKey" />
                                                                                                                <Binding Path="ExpectedValue" />
                                                                                                                <Binding Path="IsFallback" />
                                                                                                                <Binding Path="Label" />
                                                                                                            </MultiBinding>
                                                                                                        </TextBlock.Text>
                                                                                                    </TextBlock>
                                                                                                    <Ellipse
                                                                                                        Width="14"
                                                                                                        Height="14"
                                                                                                        Margin="0,0,-19,0"
                                                                                                        HorizontalAlignment="Right"
                                                                                                        VerticalAlignment="Center"
                                                                                                        Cursor="Hand"
                                                                                                        Fill="{Binding DataContext.DefinitionId, RelativeSource={RelativeSource AncestorType=Thumb}, Converter={StaticResource NodeVisualConverter}, ConverterParameter=Brush}"
                                                                                                        PreviewMouseLeftButtonDown="TransitionPort_OnMouseDown"
                                                                                                        Stroke="{DynamicResource MahApps.Brushes.Gray9}"
                                                                                                        StrokeThickness="1.5"
                                                                                                        ToolTip="Drag to retarget this transition; click to edit its criteria in the inspector" />
                                                                                                </Grid>
                                                                                            </DataTemplate>
                                                                                        </ItemsControl.ItemTemplate>
                                                                                    </ItemsControl>
                                                                                    <Grid Height="20" Background="Transparent">
                                                                                        <TextBlock
                                                                                            Margin="0,0,4,0"
                                                                                            HorizontalAlignment="Right"
                                                                                            VerticalAlignment="Center"
                                                                                            FontSize="10"
                                                                                            Foreground="{DynamicResource MahApps.Brushes.IdealForeground}"
                                                                                            Opacity="0.5"
                                                                                            Text="new" />
                                                                                        <Ellipse
                                                                                            Width="14"
                                                                                            Height="14"
                                                                                            Margin="0,0,-19,0"
                                                                                            HorizontalAlignment="Right"
                                                                                            VerticalAlignment="Center"
                                                                                            Cursor="Hand"
                                                                                            Fill="{DynamicResource MahApps.Brushes.Gray9}"
                                                                                            Opacity="0.7"
                                                                                            PreviewMouseLeftButtonDown="OutPort_OnMouseDown"
                                                                                            Stroke="{Binding DefinitionId, Converter={StaticResource NodeVisualConverter}, ConverterParameter=Brush}"
                                                                                            StrokeDashArray="2 1"
                                                                                            StrokeThickness="1.5"
                                                                                            ToolTip="Drag to another node to add a transition" />
                                                                                    </Grid>
                                                                                </StackPanel>

                                                                                <StackPanel Grid.Row="3" Orientation="Horizontal">
                                                                                    <Border
                                                                                        Padding="6,2"
                                                                                        Background="{Binding DefinitionId, Converter={StaticResource NodeVisualConverter}, ConverterParameter=SurfaceBrush}"
                                                                                        CornerRadius="4">
                                                                                        <TextBlock
                                                                                            FontSize="10"
                                                                                            FontWeight="SemiBold"
                                                                                            Foreground="{Binding DefinitionId, Converter={StaticResource NodeVisualConverter}, ConverterParameter=Brush}"
                                                                                            Text="{Binding DefinitionId, Converter={StaticResource NodeVisualConverter}, ConverterParameter=CategoryTitle}" />
                                                                                    </Border>
                                                                                    <TextBlock
                                                                                        Margin="8,0,0,0"
                                                                                        VerticalAlignment="Center"
                                                                                        FontSize="11"
                                                                                        Foreground="{DynamicResource MahApps.Brushes.IdealForeground}"
                                                                                        Opacity="0.8"
                                                                                        Text="{Binding ActionText}"
                                                                                        TextWrapping="Wrap" />
                                                                                    <Border
                                                                                        Margin="8,0,0,0"
                                                                                        Padding="6,2"
                                                                                        Background="{DynamicResource MahApps.Brushes.Gray8}"
                                                                                        CornerRadius="4">
                                                                                        <TextBlock
                                                                                            FontSize="10"
                                                                                            Foreground="{DynamicResource MahApps.Brushes.IdealForeground}"
                                                                                            Opacity="0.8"
                                                                                            Text="{Binding DwellMilliseconds, StringFormat={}{0} ms}" />
                                                                                    </Border>
                                                                                </StackPanel>
                                                                            </Grid>
                                                                        </Border>

                                                                        <!--  In-port (transition target). Center must match NodeConnectorConverter.InPortX/PortY.  -->
                                                                        <Ellipse
                                                                            Width="14"
                                                                            Height="14"
                                                                            Margin="0,24,0,0"
                                                                            HorizontalAlignment="Left"
                                                                            VerticalAlignment="Top"
                                                                            Fill="{DynamicResource MahApps.Brushes.Gray9}"
                                                                            IsHitTestVisible="False"
                                                                            Stroke="{Binding DefinitionId, Converter={StaticResource NodeVisualConverter}, ConverterParameter=Brush}"
                                                                            StrokeThickness="1.5" />

                                                                    </Grid>
                                                                </Border>
                                                                <views:ScriptDashboardCard Visibility="{Binding DefinitionId, Converter={StaticResource DefinitionIdVisibilityConverter}, ConverterParameter=ui.scriptDashboard}" />
                                                            </Grid>
                                                        </ControlTemplate>
                                                    </Thumb.Template>
                                                </Thumb>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <!--  Selection box overlay  -->
                                    <Canvas x:Name="SelectionOverlay" IsHitTestVisible="False" />

                                    <!--  Empty-state hint  -->
                                    <Border
                                        MaxWidth="420"
                                        Margin="0,120,0,0"
                                        Padding="22,18"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Top"
                                        Background="#26101620"
                                        BorderBrush="{StaticResource EditorPrimaryMutedBrush}"
                                        BorderThickness="1"
                                        CornerRadius="12"
                                        IsHitTestVisible="False"
                                        Visibility="{Binding IsCanvasEmpty, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <StackPanel HorizontalAlignment="Center">
                                            <iconPacks:PackIconMaterial
                                                Width="34"
                                                Height="34"
                                                HorizontalAlignment="Center"
                                                Foreground="{StaticResource EditorPrimaryBrush}"
                                                Kind="GraphOutline"
                                                Opacity="0.85" />
                                            <TextBlock
                                                Margin="0,10,0,0"
                                                HorizontalAlignment="Center"
                                                FontSize="15"
                                                FontWeight="SemiBold"
                                                Foreground="{DynamicResource MahApps.Brushes.IdealForeground}"
                                                Text="Empty canvas" />
                                            <TextBlock
                                                Margin="0,6,0,0"
                                                HorizontalAlignment="Center"
                                                FontSize="12"
                                                Foreground="{DynamicResource MahApps.Brushes.IdealForeground}"
                                                Opacity="0.75"
                                                Text="Add a node from the Catalog on the left to get started. The first node becomes the Start node automatically."
                                                TextAlignment="Center"
                                                TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </ScrollViewer>

                            <!--
                                Mini-map overlay. Draggable via the top handle; the opaque rectangle tracks
                                the visible viewport as you pan/zoom. Visibility/auto-hide handled in code-behind.
                            -->
                            <views:MiniMapView x:Name="MiniMap" />
                        </Grid>

                    </Border>
                </Grid>
            </Border>

            <GridSplitter
                Grid.Column="3"
                Width="6"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                Background="{StaticResource EditorPrimaryMutedBrush}"
                ResizeBehavior="PreviousAndNext"
                ResizeDirection="Columns"
                ShowsPreview="True"
                Visibility="{Binding IsRightCollapsed, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Inverted}" />

            <views:InspectorPanel Grid.Column="4" />
        </Grid>
    </Grid>
</UserControl>
