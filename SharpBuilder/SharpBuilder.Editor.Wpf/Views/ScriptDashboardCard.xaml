<UserControl
    x:Class="SharpBuilder.Editor.Wpf.Views.ScriptDashboardCard"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="http://metro.mahapps.com/winfx/xaml/controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
    xmlns:mahApps="http://metro.mahapps.com/winfx/xaml/controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:views="clr-namespace:SharpBuilder.Editor.Wpf.Views"
    mc:Ignorable="d">

    <!--
        On-canvas session dashboard card for a ui.scriptDashboard node. DataContext is the
        NodeModel (inherited from the node template); editor/dashboard state is reached through
        the hosting NodeEditorControl. Extracted from NodeEditorControl.xaml.
    -->
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Themes/EditorStyles.xaml" />
                <ResourceDictionary Source="Themes/DashboardStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Border
        Width="{Binding DashboardWidth}"
        Height="{Binding DashboardHeight}"
        MinWidth="360"
        MinHeight="240"
        Padding="12"
        Background="#EE101620"
        BorderBrush="{Binding DefinitionId, Converter={StaticResource NodeVisualConverter}, ConverterParameter=Brush}"
        BorderThickness="1.5"
        CornerRadius="8"
        Effect="{StaticResource NodeShadow}"
        Visibility="{Binding DefinitionId, Converter={StaticResource DefinitionIdVisibilityConverter}, ConverterParameter=ui.scriptDashboard}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border
                Padding="10,7"
                Background="{Binding DefinitionId, Converter={StaticResource NodeVisualConverter}, ConverterParameter=SurfaceBrush}"
                BorderBrush="{Binding DefinitionId, Converter={StaticResource NodeVisualConverter}, ConverterParameter=Brush}"
                BorderThickness="0,0,0,2"
                CornerRadius="6,6,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Border
                        Width="30"
                        Height="30"
                        Background="#33000000"
                        CornerRadius="6">
                        <iconPacks:PackIconMaterial
                            Width="18"
                            Height="18"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Foreground="{Binding DefinitionId, Converter={StaticResource NodeVisualConverter}, ConverterParameter=Brush}"
                            Kind="{Binding DefinitionId, Converter={StaticResource NodeVisualConverter}, ConverterParameter=Icon}" />
                    </Border>
                    <StackPanel
                        Grid.Column="1"
                        Margin="8,0,0,0"
                        VerticalAlignment="Center">
                        <TextBlock
                            FontSize="15"
                            FontWeight="Bold"
                            Foreground="#FFFFFFFF"
                            Text="{Binding Title}" />
                        <TextBlock
                            FontSize="10.5"
                            Foreground="#CCFFFFFF"
                            Text="{Binding ActionText}"
                            TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                    <Border
                        Grid.Column="2"
                        Padding="7,3"
                        VerticalAlignment="Center"
                        Background="#40000000"
                        CornerRadius="5">
                        <TextBlock
                            FontSize="10"
                            FontWeight="SemiBold"
                            Foreground="#FFFFFFFF"
                            Text="Canvas UI" />
                    </Border>
                </Grid>
            </Border>

            <TabControl
                Grid.Row="1"
                Margin="0,12,0,0"
                Background="Transparent"
                BorderThickness="0"
                Visibility="{Binding Converter={StaticResource NodeParameterBoolConverter}, ConverterParameter=collapsed|Invert|Visibility}">
                <TabItem Header="Runtime" Style="{StaticResource DashboardTabItem}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="0,8,0,0">
                            <UniformGrid Columns="3">
                                <Border Style="{StaticResource DashboardMetricCard}" ToolTip="Account/session this dashboard is reading from (the logged-in player, or design mode when no game client is attached)">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource DashboardMetricLabel}" Text="Session" />
                                        <TextBlock
                                            Style="{StaticResource DashboardMetricValue}"
                                            Text="{Binding DataContext.Dashboard.Session, RelativeSource={RelativeSource AncestorType=views:NodeEditorControl}}"
                                            TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource DashboardMetricCard}" ToolTip="Time the graph has spent running this session">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource DashboardMetricLabel}" Text="Graph runtime" />
                                        <TextBlock Style="{StaticResource DashboardMetricValue}" Text="{Binding DataContext.Dashboard.Runtime, RelativeSource={RelativeSource AncestorType=views:NodeEditorControl}}" />
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource DashboardMetricCard}" ToolTip="How long SharpBuilder has been open">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource DashboardMetricLabel}" Text="Builder uptime" />
                                        <TextBlock Style="{StaticResource DashboardMetricValue}" Text="{Binding DataContext.Dashboard.Uptime, RelativeSource={RelativeSource AncestorType=views:NodeEditorControl}}" />
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource DashboardMetricCard}">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource DashboardMetricLabel}" Text="Mode" />
                                        <TextBlock Style="{StaticResource DashboardMetricValue}" Text="{Binding DataContext.Dashboard.RunMode, RelativeSource={RelativeSource AncestorType=views:NodeEditorControl}}" />
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource DashboardMetricCard}">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource DashboardMetricLabel}" Text="Current node" />
                                        <TextBlock Style="{StaticResource DashboardMetricValue}" Text="{Binding DataContext.Dashboard.CurrentNode, RelativeSource={RelativeSource AncestorType=views:NodeEditorControl}}" />
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource DashboardMetricCard}">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource DashboardMetricLabel}" Text="Graph" />
                                        <TextBlock Style="{StaticResource DashboardMetricValue}" Text="{Binding DataContext.Dashboard.GraphSummary, RelativeSource={RelativeSource AncestorType=views:NodeEditorControl}}" />
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource DashboardMetricCard}">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource DashboardMetricLabel}" Text="Signals" />
                                        <TextBlock Style="{StaticResource DashboardMetricValue}" Text="{Binding DataContext.Dashboard.SignalSummary, RelativeSource={RelativeSource AncestorType=views:NodeEditorControl}}" />
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource DashboardMetricCard}">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource DashboardMetricLabel}" Text="Updated" />
                                        <TextBlock Style="{StaticResource DashboardMetricValue}" Text="{Binding DataContext.Dashboard.LastUpdated, RelativeSource={RelativeSource AncestorType=views:NodeEditorControl}}" />
                                    </StackPanel>
                                </Border>
                            </UniformGrid>
                            <WrapPanel Margin="0,2,0,2">
                                <Button
                                    Command="{Binding DataContext.Dashboard.ResetTimerCommand, RelativeSource={RelativeSource AncestorType=views:NodeEditorControl}}"
                                    Style="{StaticResource ScriptControlButton}"
                                    ToolTip="Reset the graph runtime clock to zero">
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial
                                            Width="12"
                                            Height="12"
                                            VerticalAlignment="Center"
                                            Kind="TimerOutline" />
                                        <TextBlock Margin="5,0,0,0" Text="Reset timer" />
                                    </StackPanel>
                                </Button>
                                <Button
                                    Command="{Binding DataContext.Dashboard.ResetXpCommand, RelativeSource={RelativeSource AncestorType=views:NodeEditorControl}}"
                                    Style="{StaticResource ScriptControlButton}"
                                    ToolTip="Re-baseline XP tracking (gained / XP per hour restart from now)">
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial
                                            Width="12"
                                            Height="12"
                                            VerticalAlignment="Center"
                                            Kind="StarCircleOutline" />
                                        <TextBlock Margin="5,0,0,0" Text="Reset XP" />
                                    </StackPanel>
                                </Button>
                                <Button
                                    Command="{Binding DataContext.Dashboard.ResetItemsCommand, RelativeSource={RelativeSource AncestorType=views:NodeEditorControl}}"
                                    Style="{StaticResource ScriptControlButton}"
                                    ToolTip="Clear tracked items and re-baseline item flow">
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial
                                            Width="12"
                                            Height="12"
                                            VerticalAlignment="Center"
                                            Kind="PackageVariantClosed" />
                                        <TextBlock Margin="5,0,0,0" Text="Reset items" />
                                    </StackPanel>
                                </Button>
                            </WrapPanel>
                            <Border
                                Margin="0,4,0,0"
                                Padding="10"
                                Background="#24101824"
                                BorderBrush="{StaticResource EditorPrimaryMutedBrush}"
                                BorderThickness="1"
                                CornerRadius="6">
                                <TextBlock
                                    Foreground="{DynamicResource MahApps.Brushes.IdealForeground}"
                                    Text="{Binding DataContext.Status, RelativeSource={RelativeSource AncestorType=views:NodeEditorControl}}"
                                    TextWrapping="Wrap" />
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>
                <TabItem Header="XP" Style="{StaticResource DashboardTabItem}">
                    <Grid Margin="0,8,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Border
                            Margin="0,0,0,8"
                            Padding="8"
                            Background="#24101824"
                            BorderBrush="{StaticResource EditorPrimaryMutedBrush}"
                            BorderThickness="1"
                            CornerRadius="6">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock
                                    VerticalAlignment="Center"
                                    Foreground="{DynamicResource MahApps.Brushes.IdealForeground}"
                                    Text="{Binding DataContext.Dashboard.XpStatus, RelativeSource={RelativeSource AncestorType=views:NodeEditorControl}}"
                                    TextTrimming="CharacterEllipsis" />
                                <TextBlock
                                    Grid.Column="1"
                                    Margin="12,0,0,0"
                                    VerticalAlignment="Center"
                                    FontFamily="Consolas"
                                    Foreground="{DynamicResource MahApps.Brushes.IdealForeground}"
                                    Text="{Binding DataContext.Dashboard.TotalXpGained, RelativeSource={RelativeSource AncestorType=views:NodeEditorControl}, StringFormat=Gained {0:N0}}" />
                                <TextBlock
                                    Grid.Column="2"
                                    Margin="12,0,0,0"
                                    VerticalAlignment="Center"
                                    FontFamily="Consolas"
                                    Foreground="{DynamicResource MahApps.Brushes.IdealForeground}"
                                    Text="{Binding DataContext.Dashboard.ActiveSkillCount, RelativeSource={RelativeSource AncestorType=views:NodeEditorControl}, StringFormat=Active {0}}" />
                                <mahApps:ToggleSwitch
                                    Grid.Column="3"
                                    Margin="14,0,0,0"
                                    VerticalAlignment="Center"
                                    Header="Active only"
                                    IsOn="{Binding DataContext.Dashboard.XpActiveOnly, RelativeSource={RelativeSource AncestorType=views:NodeEditorControl}, Mode=TwoWay}"
                                    OffContent=""
                                    OnContent="" />
                            </Grid>
                        </Border>
                        <DataGrid
                            Grid.Row="1"
                            ItemsSource="{Binding DataContext.Dashboard.SkillsView, RelativeSource={RelativeSource AncestorType=views:NodeEditorControl}}"
                            Style="{StaticResource DashboardDataGrid}">
                            <DataGrid.Columns>
                                <DataGridTextColumn
                                    Width="*"
                                    Binding="{Binding Name}"
                                    Header="Skill" />
                                <DataGridTextColumn Binding="{Binding Level}" Header="Lvl" />
                                <DataGridTextColumn Binding="{Binding Xp, StringFormat=N0}" Header="XP" />
                                <DataGridTextColumn Binding="{Binding XpGained, StringFormat=N0}" Header="Gained" />
                                <DataGridTextColumn Binding="{Binding XpPerHour, StringFormat=N0}" Header="XP/hr" />
                                <DataGridTextColumn Binding="{Binding XpToNext, StringFormat=N0}" Header="To next" />
                                <DataGridTextColumn Binding="{Binding Eta}" Header="ETA" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </TabItem>
                <TabItem Header="Items" Style="{StaticResource DashboardTabItem}">
                    <Grid Margin="0,8,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Border
                            Margin="0,0,0,8"
                            Padding="8"
                            Background="#24101824"
                            BorderBrush="{StaticResource EditorPrimaryMutedBrush}"
                            BorderThickness="1"
                            CornerRadius="6">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock
                                    VerticalAlignment="Center"
                                    Foreground="{DynamicResource MahApps.Brushes.IdealForeground}"
                                    Text="{Binding DataContext.Dashboard.ItemsStatus, RelativeSource={RelativeSource AncestorType=views:NodeEditorControl}}"
                                    TextTrimming="CharacterEllipsis" />
                                <TextBlock
                                    Grid.Column="1"
                                    Margin="12,0,0,0"
                                    VerticalAlignment="Center"
                                    FontFamily="Consolas"
                                    Foreground="{DynamicResource MahApps.Brushes.IdealForeground}"
                                    Text="{Binding DataContext.Dashboard.ItemsGpPerHour, RelativeSource={RelativeSource AncestorType=views:NodeEditorControl}, StringFormat=GP/hr {0:N0}}" />
                                <mahApps:ToggleSwitch
                                    Grid.Column="2"
                                    Margin="14,0,0,0"
                                    VerticalAlignment="Center"
                                    Header="Active only"
                                    IsOn="{Binding DataContext.Dashboard.ItemsActiveOnly, RelativeSource={RelativeSource AncestorType=views:NodeEditorControl}, Mode=TwoWay}"
                                    OffContent=""
                                    OnContent="" />
                            </Grid>
                        </Border>
                        <DataGrid
                            Grid.Row="1"
                            ItemsSource="{Binding DataContext.Dashboard.ItemsView, RelativeSource={RelativeSource AncestorType=views:NodeEditorControl}}"
                            Style="{StaticResource DashboardDataGrid}">
                            <DataGrid.Columns>
                                <DataGridTextColumn
                                    Width="*"
                                    Binding="{Binding Name}"
                                    Header="Item" />
                                <DataGridTextColumn Binding="{Binding In, StringFormat=N0}" Header="In" />
                                <DataGridTextColumn Binding="{Binding Out, StringFormat=N0}" Header="Out" />
                                <DataGridTextColumn Binding="{Binding Net, StringFormat=N0}" Header="Net" />
                                <DataGridTextColumn Binding="{Binding PerHour, StringFormat=N1}" Header="/hr" />
                                <DataGridTextColumn Binding="{Binding UnitValue, StringFormat=N0}" Header="Value" />
                                <DataGridTextColumn Binding="{Binding GpPerHour, StringFormat=N0}" Header="GP/hr" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </TabItem>
            </TabControl>

            <Border
                Grid.Row="1"
                Margin="0,10,0,0"
                Padding="8"
                Background="#24101824"
                BorderBrush="{StaticResource EditorPrimaryMutedBrush}"
                BorderThickness="1"
                CornerRadius="6"
                Visibility="{Binding Converter={StaticResource NodeParameterBoolConverter}, ConverterParameter=collapsed|Visibility}">
                <TextBlock
                    FontSize="11"
                    Foreground="{DynamicResource MahApps.Brushes.Gray6}"
                    Text="Collapsed. Select this node and clear 'Collapse panel' to show the tabs." />
            </Border>

            <!--  Resize grip (drag to resize the dashboard card)  -->
            <Thumb
                Grid.Row="1"
                Width="16"
                Height="16"
                Margin="0,0,-6,-6"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Cursor="SizeNWSE"
                DragDelta="DashboardResize_DragDelta"
                ToolTip="Drag to resize the dashboard">
                <Thumb.Template>
                    <ControlTemplate TargetType="Thumb">
                        <Border Background="Transparent">
                            <iconPacks:PackIconMaterial
                                Width="13"
                                Height="13"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Bottom"
                                Foreground="{DynamicResource MahApps.Brushes.Gray5}"
                                Kind="ResizeBottomRight" />
                        </Border>
                    </ControlTemplate>
                </Thumb.Template>
            </Thumb>
        </Grid>
    </Border>
</UserControl>
