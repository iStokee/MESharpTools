<UserControl
    x:Class="SharpBuilder.Editor.Wpf.Views.InspectorPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="http://metro.mahapps.com/winfx/xaml/controls"
    xmlns:converters="clr-namespace:SharpBuilder.Editor.Wpf.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
    xmlns:mahApps="http://metro.mahapps.com/winfx/xaml/controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="clr-namespace:SharpBuilder.Core.Models;assembly=SharpBuilder.Core"
    xmlns:utils="clr-namespace:SharpBuilder.Editor.Wpf.Utilities"
    xmlns:viewModels="clr-namespace:SharpBuilder.Editor.Wpf.ViewModels"
    mc:Ignorable="d">

    <!--
        Inspector column: script controls, node/transition editors, validation, run log,
        signals, and the collapsed rail. DataContext is the editor view model.
        Extracted from NodeEditorControl.xaml.
    -->
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Themes/EditorStyles.xaml" />
                <ResourceDictionary Source="Themes/NodeParamTemplates.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Border
        Padding="0"
        Style="{StaticResource PanelCard}">
        <Grid>
            <!--  Expanded inspector: header + scrollable sections  -->
            <Grid Visibility="{Binding IsRightCollapsed, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Inverted}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Style="{StaticResource EditorColumnHeader}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <ToggleButton
                            Grid.Column="0"
                            IsChecked="{Binding IsRightCollapsed, Mode=TwoWay}"
                            Style="{StaticResource RailToggleButton}"
                            ToolTip="Collapse inspector">
                            <iconPacks:PackIconMaterial
                                Width="16"
                                Height="16"
                                Kind="ChevronRight" />
                        </ToggleButton>
                        <Border
                            Grid.Column="1"
                            Width="30"
                            Height="30"
                            Margin="10,0,0,0"
                            VerticalAlignment="Center"
                            Background="{StaticResource EditorPrimaryMutedBrush}"
                            CornerRadius="7">
                            <iconPacks:PackIconMaterial
                                Width="16"
                                Height="16"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Foreground="{DynamicResource MahApps.Brushes.Accent}"
                                Kind="Tune" />
                        </Border>
                        <StackPanel
                            Grid.Column="2"
                            Margin="10,0,0,0"
                            VerticalAlignment="Center">
                            <TextBlock
                                FontSize="16"
                                FontWeight="SemiBold"
                                Foreground="{DynamicResource MahApps.Brushes.IdealForeground}"
                                Text="Inspector" />
                            <TextBlock
                                FontSize="11"
                                Foreground="{DynamicResource MahApps.Brushes.Gray7}"
                                Text="Script, signals, and the selected node" />
                        </StackPanel>
                    </Grid>
                </Border>

                <!--  Content (hidden when collapsed)  -->
                <ScrollViewer
                    x:Name="InspectorScrollViewer"
                    Grid.Row="1"
                    HorizontalScrollBarVisibility="Disabled"
                    VerticalScrollBarVisibility="Auto"
                    Visibility="{Binding IsRightCollapsed, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Inverted}">
                    <Grid Width="{Binding ViewportWidth, ElementName=InspectorScrollViewer}">
                        <StackPanel Margin="16,12,16,16">
                            <Expander Margin="0,0,0,8" IsExpanded="True">
                                <Expander.Header>
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial
                                            Width="16"
                                            Height="16"
                                            Foreground="{DynamicResource MahApps.Brushes.Accent}"
                                            Kind="ScriptText" />
                                        <TextBlock
                                            Margin="8,0,0,0"
                                            FontSize="14"
                                            FontWeight="SemiBold"
                                            Foreground="{DynamicResource MahApps.Brushes.IdealForeground}"
                                            Text="Script" />
                                    </StackPanel>
                                </Expander.Header>
                                <StackPanel Margin="4,6,4,0">
                                    <TextBlock
                                        Margin="0,0,0,8"
                                        FontSize="12"
                                        Foreground="{DynamicResource MahApps.Brushes.IdealForeground}"
                                        Opacity="0.85"
                                        Text="Define script metadata and file operations. Load a template to bootstrap a graph quickly."
                                        TextWrapping="Wrap" />
                                    <Grid Margin="0,2,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <TextBlock
                                            Grid.Row="0"
                                            Grid.Column="0"
                                            Foreground="{DynamicResource MahApps.Brushes.IdealForeground}"
                                            Text="Name" />
                                        <TextBox
                                            Grid.Row="0"
                                            Grid.Column="1"
                                            Margin="8,0,0,0"
                                            Text="{Binding Script.Name, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBlock
                                            Grid.Row="1"
                                            Grid.Column="0"
                                            Margin="0,8,0,0"
                                            Foreground="{DynamicResource MahApps.Brushes.IdealForeground}"
                                            Text="Description" />
                                        <TextBox
                                            Grid.Row="1"
                                            Grid.Column="1"
                                            Height="60"
                                            Margin="8,8,0,0"
                                            AcceptsReturn="True"
                                            Text="{Binding Script.Description, UpdateSourceTrigger=PropertyChanged}"
                                            TextWrapping="Wrap" />
                                    </Grid>

                                    <WrapPanel Margin="0,12,0,0">
                                        <Button
                                            Command="{Binding NewScriptCommand}"
                                            Style="{StaticResource ScriptControlButton}"
                                            ToolTip="New script (Ctrl+N)">
                                            <StackPanel Orientation="Horizontal">
                                                <iconPacks:PackIconMaterial
                                                    Width="12"
                                                    Height="12"
                                                    VerticalAlignment="Center"
                                                    Kind="FilePlusOutline" />
                                                <TextBlock Margin="5,0,0,0" Text="New" />
                                            </StackPanel>
                                        </Button>
                                        <Button
                                            Command="{Binding LoadScriptCommand}"
                                            Style="{StaticResource ScriptControlButton}"
                                            ToolTip="Load script (Ctrl+O)">
                                            <StackPanel Orientation="Horizontal">
                                                <iconPacks:PackIconMaterial
                                                    Width="12"
                                                    Height="12"
                                                    VerticalAlignment="Center"
                                                    Kind="FolderOpenOutline" />
                                                <TextBlock Margin="5,0,0,0" Text="Load" />
                                            </StackPanel>
                                        </Button>
                                        <Button
                                            Command="{Binding SaveScriptCommand}"
                                            Style="{StaticResource ScriptControlSaveButton}"
                                            ToolTip="Save script (Ctrl+S)">
                                            <StackPanel Orientation="Horizontal">
                                                <iconPacks:PackIconMaterial
                                                    Width="12"
                                                    Height="12"
                                                    VerticalAlignment="Center"
                                                    Kind="ContentSave" />
                                                <TextBlock Margin="5,0,0,0" Text="Save" />
                                            </StackPanel>
                                        </Button>
                                        <Button
                                            Command="{Binding ExportScriptCommand}"
                                            Style="{StaticResource ScriptControlButton}"
                                            ToolTip="Export script (Ctrl+Shift+S)">
                                            <StackPanel Orientation="Horizontal">
                                                <iconPacks:PackIconMaterial
                                                    Width="12"
                                                    Height="12"
                                                    VerticalAlignment="Center"
                                                    Kind="FileExport" />
                                                <TextBlock Margin="5,0,0,0" Text="Export" />
                                            </StackPanel>
                                        </Button>
                                    </WrapPanel>

                                    <!--  Save state + status (relocated from the canvas toolbar)  -->
                                    <StackPanel Margin="0,10,0,0" Orientation="Horizontal">
                                        <Border
                                            Margin="0,0,8,0"
                                            Padding="8,4"
                                            VerticalAlignment="Center"
                                            Background="#33FFC857"
                                            BorderBrush="#66FFC857"
                                            BorderThickness="1"
                                            CornerRadius="6"
                                            ToolTip="The graph has changes that are not saved to disk yet (Ctrl+S)"
                                            Visibility="{Binding IsDirty, Converter={StaticResource BoolToVisibilityConverter}}">
                                            <StackPanel Orientation="Horizontal">
                                                <iconPacks:PackIconMaterial
                                                    Width="12"
                                                    Height="12"
                                                    VerticalAlignment="Center"
                                                    Foreground="#FFC857"
                                                    Kind="ContentSaveAlert" />
                                                <TextBlock
                                                    Margin="6,0,0,0"
                                                    VerticalAlignment="Center"
                                                    FontSize="11"
                                                    Foreground="#FFC857"
                                                    Text="Unsaved" />
                                            </StackPanel>
                                        </Border>
                                        <Border
                                            Padding="8,4"
                                            VerticalAlignment="Center"
                                            Background="{StaticResource EditorPrimarySurfaceBrush}"
                                            BorderBrush="{StaticResource EditorPrimaryMutedBrush}"
                                            BorderThickness="1"
                                            CornerRadius="6">
                                            <StackPanel Orientation="Horizontal">
                                                <iconPacks:PackIconMaterial
                                                    Width="12"
                                                    Height="12"
                                                    VerticalAlignment="Center"
                                                    Foreground="{DynamicResource MahApps.Brushes.Accent}"
                                                    Kind="InformationOutline" />
                                                <TextBlock
                                                    Margin="6,0,0,0"
                                                    VerticalAlignment="Center"
                                                    FontSize="11"
                                                    Foreground="{DynamicResource MahApps.Brushes.Accent}"
                                                    Text="{Binding Status}"
                                                    TextTrimming="CharacterEllipsis"
                                                    ToolTip="{Binding Status}" />
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </StackPanel>
                            </Expander>

                            <Expander Margin="0,0,0,8" IsExpanded="{Binding IsGraphExplanationOpen, Mode=TwoWay}">
                                <Expander.Header>
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial
                                            Width="16"
                                            Height="16"
                                            Foreground="{DynamicResource MahApps.Brushes.Accent}"
                                            Kind="FileSearchOutline" />
                                        <TextBlock
                                            Margin="8,0,0,0"
                                            FontSize="14"
                                            FontWeight="SemiBold"
                                            Foreground="{DynamicResource MahApps.Brushes.IdealForeground}"
                                            Text="Explain / Dry Run" />
                                    </StackPanel>
                                </Expander.Header>
                                <StackPanel Margin="4,6,4,0">
                                    <TextBlock
                                        Margin="0,0,0,8"
                                        FontSize="12"
                                        FontWeight="SemiBold"
                                        Foreground="{DynamicResource MahApps.Brushes.IdealForeground}"
                                        Text="{Binding GraphExplanationSummary}"
                                        TextWrapping="Wrap" />
                                    <ItemsControl ItemsSource="{Binding GraphExplanationLines}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock
                                                    Margin="0,0,0,5"
                                                    FontSize="11"
                                                    Foreground="{DynamicResource MahApps.Brushes.Gray7}"
                                                    Text="{Binding}"
                                                    TextWrapping="Wrap" />
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Expander>

                            <!--  Validation results from the last run attempt; click an issue to select its node.  -->
                            <Expander Margin="0,0,0,8" IsExpanded="{Binding IsValidationOpen, Mode=TwoWay}">
                                <Expander.Header>
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial
                                            Width="16"
                                            Height="16"
                                            Foreground="{DynamicResource MahApps.Brushes.Accent}"
                                            Kind="AlertCircleOutline" />
                                        <TextBlock
                                            Margin="8,0,0,0"
                                            FontSize="14"
                                            FontWeight="SemiBold"
                                            Foreground="{DynamicResource MahApps.Brushes.IdealForeground}"
                                            Text="Validation" />
                                    </StackPanel>
                                </Expander.Header>
                                <StackPanel Margin="4,6,4,0">
                                    <TextBlock
                                        Margin="0,0,0,6"
                                        FontSize="11"
                                        Foreground="{DynamicResource MahApps.Brushes.Gray7}"
                                        Text="Issues found before the last run. Click one to select the offending node."
                                        TextWrapping="Wrap" />
                                    <ItemsControl ItemsSource="{Binding ValidationIssues}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button
                                                    Margin="0,0,0,4"
                                                    Padding="6,4"
                                                    HorizontalAlignment="Stretch"
                                                    HorizontalContentAlignment="Left"
                                                    Background="#22000000"
                                                    BorderThickness="0"
                                                    Command="{Binding DataContext.SelectValidationIssueCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    Cursor="Hand">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock
                                                            VerticalAlignment="Top"
                                                            FontSize="11"
                                                            FontWeight="SemiBold"
                                                            Text="{Binding Severity}">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Foreground" Value="#FFC857" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding Severity}" Value="Error">
                                                                            <Setter Property="Foreground" Value="#E86E6E" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                        <TextBlock
                                                            Margin="8,0,0,0"
                                                            MaxWidth="240"
                                                            FontSize="11"
                                                            Foreground="{DynamicResource MahApps.Brushes.IdealForeground}"
                                                            Text="{Binding Message}"
                                                            TextWrapping="Wrap" />
                                                    </StackPanel>
                                                </Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <TextBlock
                                        FontSize="11"
                                        Foreground="{DynamicResource MahApps.Brushes.Gray7}"
                                        Text="No issues recorded yet — they appear when a run is validated.">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ValidationIssues.Count}" Value="0">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </Expander>

                            <!--  Bounded run log: node results, diagnostics, faults. Auto-opens on engine faults.  -->
                            <Expander Margin="0,0,0,8" IsExpanded="{Binding IsRunLogOpen, Mode=TwoWay}">
                                <Expander.Header>
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial
                                            Width="16"
                                            Height="16"
                                            Foreground="{DynamicResource MahApps.Brushes.Accent}"
                                            Kind="TextBoxOutline" />
                                        <TextBlock
                                            Margin="8,0,0,0"
                                            FontSize="14"
                                            FontWeight="SemiBold"
                                            Foreground="{DynamicResource MahApps.Brushes.IdealForeground}"
                                            Text="Run Log" />
                                    </StackPanel>
                                </Expander.Header>
                                <StackPanel Margin="4,6,4,0">
                                    <ScrollViewer MaxHeight="220" VerticalScrollBarVisibility="Auto">
                                        <ItemsControl ItemsSource="{Binding RunLog}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel Margin="0,1" Orientation="Horizontal">
                                                        <TextBlock
                                                            FontFamily="Consolas"
                                                            FontSize="11"
                                                            Foreground="{DynamicResource MahApps.Brushes.Gray7}"
                                                            Text="{Binding TimeLabel}" />
                                                        <TextBlock
                                                            Margin="8,0,0,0"
                                                            MaxWidth="240"
                                                            FontSize="11"
                                                            Text="{Binding Message}"
                                                            TextWrapping="Wrap">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Foreground" Value="{DynamicResource MahApps.Brushes.IdealForeground}" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding Kind}" Value="Success">
                                                                            <Setter Property="Foreground" Value="#6EE86E" />
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding Kind}" Value="Fail">
                                                                            <Setter Property="Foreground" Value="#FFC857" />
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding Kind}" Value="Error">
                                                                            <Setter Property="Foreground" Value="#E86E6E" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                    <Button
                                        Margin="0,8,0,0"
                                        Command="{Binding ClearRunLogCommand}"
                                        Content="Clear log" />
                                </StackPanel>
                            </Expander>

                            <Expander Margin="0,0,0,8" IsExpanded="False">
                                <Expander.Header>
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial
                                            Width="16"
                                            Height="16"
                                            Foreground="{DynamicResource MahApps.Brushes.Accent}"
                                            Kind="Pulse" />
                                        <TextBlock
                                            Margin="8,0,0,0"
                                            FontSize="14"
                                            FontWeight="SemiBold"
                                            Foreground="{DynamicResource MahApps.Brushes.IdealForeground}"
                                            Text="State &amp; Signals" />
                                    </StackPanel>
                                </Expander.Header>
                                <StackPanel Margin="4,6,4,0">
                                    <TextBlock
                                        Margin="0,0,0,8"
                                        FontSize="12"
                                        Foreground="{DynamicResource MahApps.Brushes.IdealForeground}"
                                        Opacity="0.85"
                                        Text="Booleans used as transition condition keys. Toggle values to set the starting state for the next run; while running they update live from node outputs."
                                        TextWrapping="Wrap" />
                                    <TextBlock
                                        Margin="0,0,0,6"
                                        Foreground="{DynamicResource MahApps.Brushes.IdealForeground}"
                                        Text="Signals" />
                                    <ItemsControl ItemsSource="{Binding Signals}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0,4">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <CheckBox IsChecked="{Binding Value, Mode=TwoWay}" />
                                                    <TextBox
                                                        Grid.Column="1"
                                                        Margin="8,0,0,0"
                                                        Text="{Binding Key, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <Button
                                        Margin="0,8,0,0"
                                        Command="{Binding ClearTrailCommand}"
                                        Content="Clear highlights" />
                                </StackPanel>
                            </Expander>

                            <Expander Margin="0,0,0,8" IsExpanded="True">
                                <Expander.Header>
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial
                                            Width="16"
                                            Height="16"
                                            Foreground="{DynamicResource MahApps.Brushes.Accent}"
                                            Kind="VectorDifference" />
                                        <TextBlock
                                            Margin="8,0,0,0"
                                            FontSize="14"
                                            FontWeight="SemiBold"
                                            Foreground="{DynamicResource MahApps.Brushes.IdealForeground}"
                                            Text="Node" />
                                    </StackPanel>
                                </Expander.Header>
                                <StackPanel Margin="4,6,4,0">
                                    <TextBlock
                                        Margin="0,0,0,8"
                                        FontSize="12"
                                        Foreground="{DynamicResource MahApps.Brushes.IdealForeground}"
                                        Opacity="0.85"
                                        Text="Edit the selected canvas node. Choose a definition first, then fill required parameters and notes."
                                        TextWrapping="Wrap" />
                                    <DockPanel>
                                        <Border
                                            Margin="0,0,8,0"
                                            Padding="8,2"
                                            HorizontalAlignment="Left"
                                            Background="{DynamicResource MahApps.Brushes.Accent}"
                                            CornerRadius="8"
                                            Visibility="{Binding CanEditNode, Converter={StaticResource BoolToVisibilityConverter}}">
                                            <TextBlock
                                                FontSize="11"
                                                FontWeight="SemiBold"
                                                Foreground="{DynamicResource MahApps.Brushes.AccentForeground}"
                                                Text="{Binding SelectedNodes.Count, StringFormat={}{0} selected}" />
                                        </Border>
                                        <TextBlock
                                            Foreground="{DynamicResource MahApps.Brushes.Gray7}"
                                            Text="Click a node on canvas to select, or drag to box-select multiple."
                                            TextWrapping="Wrap"
                                            Visibility="{Binding CanEditNode, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=True, FallbackValue=Visible}" />
                                    </DockPanel>

                                    <TextBlock
                                        Margin="0,8,0,0"
                                        Foreground="{DynamicResource MahApps.Brushes.IdealForeground}"
                                        Text="Definition" />
                                    <ComboBox
                                        Margin="0,6,0,8"
                                        DisplayMemberPath="Title"
                                        ItemsSource="{Binding Definitions}"
                                        SelectedItem="{Binding SelectedNodeDefinition, Mode=TwoWay}" />

                                    <Grid DataContext="{Binding SelectedNode}">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Foreground="{DynamicResource MahApps.Brushes.IdealForeground}" Text="Title" />
                                        <TextBox
                                            Grid.Column="1"
                                            Margin="8,0,0,0"
                                            Text="{Binding Title, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                                        <TextBlock
                                            Grid.Row="1"
                                            Margin="0,8,0,0"
                                            Foreground="{DynamicResource MahApps.Brushes.IdealForeground}"
                                            Text="Description" />
                                        <TextBox
                                            Grid.Row="1"
                                            Grid.Column="1"
                                            Height="60"
                                            Margin="8,8,0,0"
                                            AcceptsReturn="True"
                                            Text="{Binding Description, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                            TextWrapping="Wrap" />

                                        <TextBlock
                                            Grid.Row="2"
                                            Margin="0,8,0,0"
                                            Foreground="{DynamicResource MahApps.Brushes.IdealForeground}"
                                            Text="Type" />
                                        <TextBlock
                                            Grid.Row="2"
                                            Grid.Column="1"
                                            Margin="8,8,0,0"
                                            Foreground="{DynamicResource MahApps.Brushes.IdealForeground}"
                                            Text="{Binding Type}" />

                                        <TextBlock
                                            Grid.Row="3"
                                            Margin="0,8,0,0"
                                            Foreground="{DynamicResource MahApps.Brushes.IdealForeground}"
                                            Text="Dwell (ms)" />
                                        <TextBox
                                            Grid.Row="3"
                                            Grid.Column="1"
                                            Margin="8,8,0,0"
                                            Text="{Binding DwellMilliseconds, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                                        <TextBlock
                                            Grid.Row="4"
                                            Margin="0,8,0,0"
                                            Foreground="{DynamicResource MahApps.Brushes.IdealForeground}"
                                            Text="Notes" />
                                        <TextBox
                                            Grid.Row="4"
                                            Grid.Column="1"
                                            Margin="8,8,0,0"
                                            Text="{Binding ActionText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                            TextWrapping="Wrap" />
                                    </Grid>

                                    <!--  Calibrate this interaction node from a real in-game click (action opcode + route offset vary per target)  -->
                                    <Border
                                        Margin="0,12,0,0"
                                        Padding="8"
                                        Background="{DynamicResource MahApps.Brushes.Control.Background}"
                                        BorderBrush="{DynamicResource MahApps.Brushes.Accent}"
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        Visibility="{Binding CanCaptureSelectedNode, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <StackPanel>
                                            <Button
                                                HorizontalAlignment="Left"
                                                Command="{Binding CaptureFromGameCommand}"
                                                Content="Capture from game"
                                                ToolTip="Click the object/NPC in-game, then press this to fill action opcode, route offset, id and distance from the real click." />
                                            <TextBlock
                                                Margin="0,6,0,0"
                                                FontSize="11"
                                                Text="{Binding CaptureStatus}"
                                                TextWrapping="Wrap">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{DynamicResource MahApps.Brushes.Gray6}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding CaptureDriftState}" Value="match">
                                                                <Setter Property="Foreground" Value="#6EE86E" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding CaptureDriftState}" Value="drift">
                                                                <Setter Property="Foreground" Value="#FFC857" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding CaptureDriftState}" Value="filled">
                                                                <Setter Property="Foreground" Value="#7DD3FC" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>
                                    </Border>

                                    <Border
                                        Margin="0,12,0,0"
                                        Padding="10"
                                        Background="#1218202D"
                                        BorderBrush="{StaticResource PanelBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="8">
                                        <StackPanel>
                                            <DockPanel Margin="0,0,0,10">
                                                <Border
                                                    Padding="7,3"
                                                    Background="{StaticResource EditorPrimaryMutedBrush}"
                                                    CornerRadius="6"
                                                    DockPanel.Dock="Right">
                                                    <TextBlock
                                                        FontSize="11"
                                                        FontWeight="SemiBold"
                                                        Foreground="{DynamicResource MahApps.Brushes.IdealForeground}"
                                                        Text="{Binding ParameterBindings.Count, StringFormat={}{0} fields}" />
                                                </Border>
                                                <StackPanel Orientation="Horizontal">
                                                    <iconPacks:PackIconMaterial
                                                        Width="15"
                                                        Height="15"
                                                        VerticalAlignment="Center"
                                                        Foreground="{DynamicResource MahApps.Brushes.Accent}"
                                                        Kind="FormTextbox" />
                                                    <TextBlock
                                                        Margin="8,0,0,0"
                                                        FontWeight="SemiBold"
                                                        Foreground="{DynamicResource MahApps.Brushes.IdealForeground}"
                                                        Text="Parameters" />
                                                </StackPanel>
                                            </DockPanel>

                                            <ItemsControl ItemTemplate="{StaticResource NodeParamBindingTemplate}" ItemsSource="{Binding ParameterBindings}" />

                                            <!--  Advanced tuning params, collapsed by default to cut clutter on heavy nodes  -->
                                            <Expander
                                                Margin="0,0,0,0"
                                                IsExpanded="False"
                                                Visibility="{Binding HasAdvancedParameters, Converter={StaticResource BoolToVisibilityConverter}}">
                                                <Expander.Header>
                                                    <StackPanel Orientation="Horizontal">
                                                        <iconPacks:PackIconMaterial
                                                            Width="14"
                                                            Height="14"
                                                            VerticalAlignment="Center"
                                                            Foreground="{DynamicResource MahApps.Brushes.Gray6}"
                                                            Kind="Tune" />
                                                        <TextBlock
                                                            Margin="8,0,0,0"
                                                            FontSize="12"
                                                            FontWeight="SemiBold"
                                                            Foreground="{DynamicResource MahApps.Brushes.IdealForeground}"
                                                            Text="{Binding AdvancedParameterBindings.Count, StringFormat=Advanced ({0})}" />
                                                    </StackPanel>
                                                </Expander.Header>
                                                <ItemsControl
                                                    Margin="0,8,0,0"
                                                    ItemTemplate="{StaticResource NodeParamBindingTemplate}"
                                                    ItemsSource="{Binding AdvancedParameterBindings}" />
                                            </Expander>
                                        </StackPanel>
                                    </Border>

                                    <WrapPanel Margin="0,10,0,0">
                                        <Button
                                            Margin="0,0,6,6"
                                            Command="{Binding AddNodeCommand}"
                                            Content="Add node" />
                                        <Button
                                            Margin="0,0,6,6"
                                            Command="{Binding RemoveNodeCommand}"
                                            Content="Remove node"
                                            IsEnabled="{Binding CanEditNode}" />
                                        <Button
                                            Margin="0,0,6,6"
                                            Command="{Binding SetAsStartCommand}"
                                            Content="Set as start"
                                            IsEnabled="{Binding CanEditNode}" />
                                    </WrapPanel>
                                </StackPanel>
                            </Expander>

                            <Expander Margin="0,0,0,8" IsExpanded="False">
                                <Expander.Header>
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial
                                            Width="16"
                                            Height="16"
                                            Foreground="{DynamicResource MahApps.Brushes.Accent}"
                                            Kind="SignDirection" />
                                        <TextBlock
                                            Margin="8,0,0,0"
                                            FontSize="14"
                                            FontWeight="SemiBold"
                                            Foreground="{DynamicResource MahApps.Brushes.IdealForeground}"
                                            Text="Transitions" />
                                    </StackPanel>
                                </Expander.Header>
                                <StackPanel Margin="4,6,4,0">
                                    <TextBlock
                                        Margin="0,0,0,8"
                                        FontSize="12"
                                        Foreground="{DynamicResource MahApps.Brushes.IdealForeground}"
                                        Opacity="0.85"
                                        Text="Transitions evaluate top to bottom. 'On success'/'On fail' edges react to the node's result first, then condition keys, then the fallback."
                                        TextWrapping="Wrap" />
                                    <DockPanel Margin="0,0,0,6">
                                        <Button
                                            Command="{Binding AddTransitionCommand}"
                                            Content="Add transition"
                                            DockPanel.Dock="Right"
                                            IsEnabled="{Binding CanEditTransitions}" />
                                    </DockPanel>

                                    <ListBox
                                        HorizontalContentAlignment="Stretch"
                                        BorderThickness="0"
                                        ItemsSource="{Binding SelectedNode.Transitions}"
                                        ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                        SelectedItem="{Binding SelectedTransition, Mode=TwoWay}">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Border
                                                    Margin="0,0,0,8"
                                                    Padding="10"
                                                    HorizontalAlignment="Stretch"
                                                    Background="{DynamicResource MahApps.Brushes.Gray9}"
                                                    BorderBrush="{DynamicResource MahApps.Brushes.Gray7}"
                                                    BorderThickness="1"
                                                    CornerRadius="8">
                                                    <Grid>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="Auto" />
                                                        </Grid.RowDefinitions>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>

                                                        <TextBlock Foreground="{DynamicResource MahApps.Brushes.IdealForeground}" Text="Target" />
                                                        <ComboBox
                                                            Grid.Column="1"
                                                            Margin="6,0,0,0"
                                                            DisplayMemberPath="Title"
                                                            ItemsSource="{Binding DataContext.Script.Nodes, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            SelectedValue="{Binding ToNodeId, Mode=TwoWay}"
                                                            SelectedValuePath="Id" />

                                                        <TextBlock
                                                            Grid.Row="1"
                                                            Margin="0,8,0,0"
                                                            Foreground="{DynamicResource MahApps.Brushes.IdealForeground}"
                                                            Text="Trigger" />
                                                        <ComboBox
                                                            Grid.Row="1"
                                                            Grid.Column="1"
                                                            Margin="6,8,0,0"
                                                            ItemsSource="{Binding DataContext.TransitionTriggers, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            SelectedItem="{Binding Trigger, Mode=TwoWay}"
                                                            ToolTip="Gate this edge on the node's execution result. 'Any' keeps signal-only behavior." />

                                                        <TextBlock
                                                            Grid.Row="2"
                                                            Margin="0,8,0,0"
                                                            Foreground="{DynamicResource MahApps.Brushes.IdealForeground}"
                                                            Text="Condition key" />
                                                        <ComboBox
                                                            Grid.Row="2"
                                                            Grid.Column="1"
                                                            Margin="6,8,0,0"
                                                            IsEditable="True"
                                                            ItemsSource="{Binding DataContext.SignalSuggestions, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            Text="{Binding ConditionKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                                                        <WrapPanel
                                                            Grid.Row="3"
                                                            Grid.ColumnSpan="2"
                                                            Margin="0,8,0,0"
                                                            Orientation="Horizontal">
                                                            <CheckBox
                                                                Margin="0,0,8,6"
                                                                Content="Expect true"
                                                                IsChecked="{Binding ExpectedValue, Mode=TwoWay}" />
                                                            <CheckBox
                                                                Margin="0,0,8,6"
                                                                Content="Fallback"
                                                                IsChecked="{Binding IsFallback, Mode=TwoWay}" />
                                                            <TextBox
                                                                Width="140"
                                                                Margin="0,0,8,6"
                                                                Text="{Binding Label, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                ToolTip="Label" />
                                                            <Button
                                                                Margin="0,0,4,6"
                                                                Padding="6,2"
                                                                Command="{Binding DataContext.MoveTransitionUpCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                CommandParameter="{Binding}"
                                                                Content="▲"
                                                                ToolTip="Move up (evaluated earlier)" />
                                                            <Button
                                                                Margin="0,0,8,6"
                                                                Padding="6,2"
                                                                Command="{Binding DataContext.MoveTransitionDownCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                CommandParameter="{Binding}"
                                                                Content="▼"
                                                                ToolTip="Move down (evaluated later)" />
                                                            <Button
                                                                Margin="0,0,8,6"
                                                                Command="{Binding DataContext.RemoveTransitionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                CommandParameter="{Binding}"
                                                                Content="Remove" />
                                                        </WrapPanel>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </StackPanel>
                            </Expander>
                        </StackPanel>
                    </Grid>
                </ScrollViewer>
            </Grid>

            <!--  Collapsed inspector rail  -->
            <Border
                Background="{StaticResource RailSurfaceBrush}"
                CornerRadius="13"
                Visibility="{Binding IsRightCollapsed, Converter={StaticResource BoolToVisibilityConverter}}">
                <Grid Margin="0,14">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <ToggleButton
                        Grid.Row="0"
                        HorizontalAlignment="Center"
                        IsChecked="{Binding IsRightCollapsed, Mode=TwoWay}"
                        Style="{StaticResource RailToggleButton}"
                        ToolTip="Expand inspector">
                        <iconPacks:PackIconMaterial
                            Width="16"
                            Height="16"
                            Kind="ChevronLeft" />
                    </ToggleButton>
                    <TextBlock
                        Grid.Row="1"
                        Margin="0,16"
                        VerticalAlignment="Center"
                        Style="{StaticResource RailCaption}"
                        Text="INSPECTOR" />
                    <Border
                        Grid.Row="2"
                        Width="32"
                        Height="32"
                        HorizontalAlignment="Center"
                        Background="{StaticResource EditorPrimaryMutedBrush}"
                        CornerRadius="9">
                        <iconPacks:PackIconMaterial
                            Width="16"
                            Height="16"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Foreground="{DynamicResource MahApps.Brushes.Accent}"
                            Kind="Tune" />
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Border>
</UserControl>
