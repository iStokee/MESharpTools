<UserControl
    x:Class="MESharp.Views.CacheHubView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="clr-namespace:MESharp.ViewModels"
    d:DataContext="{d:DesignInstance Type=vm:CacheHubViewModel}"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{DynamicResource App.BackgroundBrush}"
    Foreground="{DynamicResource App.ForegroundBrush}">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </UserControl.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Style="{StaticResource Hub.Card}">
            <StackPanel>
                <TextBlock Text="RS3 Cache" Style="{StaticResource Hub.PageTitle}" />
                <TextBlock Style="{StaticResource Hub.HintText}"
                           Text="Browse and version-track the chisel/gazproj cache dumps, and see what the game cache has loaded." />
            </StackPanel>
        </Border>

        <TabControl Grid.Row="1" Background="Transparent" BorderThickness="0">

            <!-- ============ STATUS ============ -->
            <TabItem Header="Status">
                <Grid Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="1.4*" />
                    </Grid.ColumnDefinitions>

                    <!-- Game cache -->
                    <Border Grid.Column="0" Style="{StaticResource Hub.Card}" Margin="0,0,8,0">
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal">
                                <TextBlock Text="Game cache" Style="{StaticResource Hub.SectionHeader}" />
                                <Button Content="Refresh" Margin="10,0,0,0" Padding="8,2"
                                        Command="{Binding RefreshGameStatusCommand}" />
                            </StackPanel>
                            <TextBlock DockPanel.Dock="Top" Style="{StaticResource Hub.HintText}"
                                       Text="{Binding GameStatusText}" Margin="0,0,0,8" />
                            <DataGrid ItemsSource="{Binding GameTypes}" AutoGenerateColumns="False"
                                      IsReadOnly="True" HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                                      Background="Transparent" RowBackground="Transparent">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="*" />
                                    <DataGridTextColumn Header="Loaded" Binding="{Binding Loaded}" Width="Auto" />
                                    <DataGridTextColumn Header="Total" Binding="{Binding Total}" Width="Auto" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </DockPanel>
                    </Border>

                    <!-- Chisel dumps -->
                    <Border Grid.Column="1" Style="{StaticResource Hub.Card}">
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal">
                                <TextBlock Text="Chisel dumps" Style="{StaticResource Hub.SectionHeader}" />
                                <Button Content="Check versions" Margin="10,0,0,0" Padding="8,2"
                                        Command="{Binding RefreshChiselStatusCommand}" />
                                <Button Content="Download stale" Margin="6,0,0,0" Padding="8,2"
                                        Command="{Binding DownloadAllCommand}" />
                            </StackPanel>
                            <TextBlock DockPanel.Dock="Bottom" Style="{StaticResource Hub.HintText}"
                                       Margin="0,8,0,0" Text="{Binding DumpDirectory}" />
                            <DataGrid ItemsSource="{Binding ChiselCategories}" AutoGenerateColumns="False"
                                      IsReadOnly="True" HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                                      Background="Transparent" RowBackground="Transparent">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Category" Binding="{Binding DisplayName}" Width="*" />
                                    <DataGridTextColumn Header="Local" Binding="{Binding LocalText}" Width="Auto" />
                                    <DataGridTextColumn Header="Status" Binding="{Binding StatusText}" Width="Auto" />
                                    <DataGridTemplateColumn Header="" Width="Auto">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button Content="Download" Padding="8,1"
                                                        Command="{Binding DataContext.DownloadCategoryCommand,
                                                                  RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                        CommandParameter="{Binding}" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </DockPanel>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ============ BROWSE ============ -->
            <TabItem Header="Browse">
                <Grid Margin="0,8,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Style="{StaticResource Hub.Card}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Category" Style="{StaticResource Hub.FieldLabel}" VerticalAlignment="Center" />
                            <ComboBox Width="180" Margin="6,0,0,0"
                                      ItemsSource="{Binding BrowseCategoryOptions}"
                                      SelectedItem="{Binding SelectedBrowseCategory}"
                                      DisplayMemberPath="DisplayName" />
                            <Button Content="Load" Margin="6,0,0,0" Padding="10,2" Command="{Binding LoadBrowseCommand}" />
                            <TextBlock Text="Search" Style="{StaticResource Hub.FieldLabel}" VerticalAlignment="Center" Margin="14,0,0,0" />
                            <TextBox Width="220" Margin="6,0,0,0" Text="{Binding BrowseSearch, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Text="{Binding BrowseStatus}" Style="{StaticResource Hub.HintText}"
                                       VerticalAlignment="Center" Margin="14,0,0,0" />
                        </StackPanel>
                    </Border>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.2*" />
                            <ColumnDefinition Width="1.8*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Style="{StaticResource Hub.InsetCard}" Margin="0,0,8,0">
                            <DataGrid ItemsSource="{Binding BrowseEntries}" SelectedItem="{Binding SelectedBrowseEntry}"
                                      AutoGenerateColumns="False" IsReadOnly="True" HeadersVisibility="Column"
                                      GridLinesVisibility="Horizontal" Background="Transparent" RowBackground="Transparent">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Key" Binding="{Binding Key}" Width="Auto" />
                                    <DataGridTextColumn Header="Name" Binding="{Binding Display}" Width="*" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>

                        <Border Grid.Column="1" Style="{StaticResource Hub.InsetCard}">
                            <TextBox Text="{Binding SelectedEntryJson, Mode=OneWay}" IsReadOnly="True"
                                     FontFamily="Consolas" VerticalScrollBarVisibility="Auto"
                                     HorizontalScrollBarVisibility="Auto" TextWrapping="NoWrap"
                                     Background="Transparent" BorderThickness="0" />
                        </Border>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- ============ COMPARE / GAP ============ -->
            <TabItem Header="Compare">
                <Grid Margin="0,8,0,0">
                    <Border Style="{StaticResource Hub.Card}">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top" Text="API gap report" Style="{StaticResource Hub.SectionHeader}" />
                            <TextBlock DockPanel.Dock="Top" Style="{StaticResource Hub.HintText}" Margin="0,0,0,8"
                                       Text="What the chisel reference exposes vs. what the C# API surfaces. 'gap' rows are demand-driven — build the export when a script needs it." />
                            <DataGrid ItemsSource="{Binding GapRows}" AutoGenerateColumns="False" IsReadOnly="True"
                                      HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                                      Background="Transparent" RowBackground="Transparent">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="Auto" />
                                    <DataGridTextColumn Header="API class" Binding="{Binding ApiClass}" Width="Auto" />
                                    <DataGridTextColumn Header="Status" Binding="{Binding ExposedText}" Width="Auto" />
                                    <DataGridTextColumn Header="Notes" Binding="{Binding Notes}" Width="*" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </DockPanel>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ============ DIFF ============ -->
            <TabItem Header="Diff">
                <Grid Margin="0,8,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Style="{StaticResource Hub.Card}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Category" Style="{StaticResource Hub.FieldLabel}" VerticalAlignment="Center" />
                            <ComboBox Width="180" Margin="6,0,0,0"
                                      ItemsSource="{Binding DiffCategoryOptions}"
                                      SelectedItem="{Binding SelectedDiffCategory}"
                                      DisplayMemberPath="DisplayName" />
                            <Button Content="Load diff" Margin="6,0,0,0" Padding="10,2" Command="{Binding LoadDiffCommand}" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="1" Style="{StaticResource Hub.InsetCard}">
                        <TextBox Text="{Binding DiffText, Mode=OneWay}" IsReadOnly="True" FontFamily="Consolas"
                                 VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                                 TextWrapping="NoWrap" Background="Transparent" BorderThickness="0" />
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- Busy bar -->
        <Border Grid.Row="2" Style="{StaticResource Hub.Card}" Margin="0,8,0,0"
                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}">
            <StackPanel Orientation="Horizontal">
                <ProgressBar IsIndeterminate="True" Width="120" Height="6" VerticalAlignment="Center" />
                <TextBlock Text="{Binding BusyText}" Style="{StaticResource Hub.HintText}" Margin="10,0,0,0" VerticalAlignment="Center" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
